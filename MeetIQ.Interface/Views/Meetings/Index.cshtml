 *@




@model IEnumerable<Meeting>
@using MeetIQ.Domain.Enums
@{
    ViewData["Title"] = "Meetings";

    var now = DateTime.UtcNow;
    var live = Model.Where(m => m.Status == MeetingStatus.InProgress).ToList();
    var missed = Model.Where(m => m.Status == MeetingStatus.Scheduled && m.ScheduledAt < now).OrderByDescending(m => m.ScheduledAt).ToList();
    var upcoming = Model.Where(m => m.Status == MeetingStatus.Scheduled && m.ScheduledAt >= now).OrderBy(m => m.ScheduledAt).ToList();
    var past = Model.Where(m => m.Status == MeetingStatus.Ended || m.Status == MeetingStatus.Cancelled).OrderByDescending(m => m.ScheduledAt).ToList();
}

<div class="space-y-6">

    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-white font-semibold text-lg">Meetings</h2>
            <p class="text-slate-500 text-sm mt-0.5">All your scheduled and past video calls</p>
        </div>
        <a asp-action="Create"
           class="flex items-center gap-2 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-xl transition-colors shadow-glow">
            <i data-lucide="video" class="w-4 h-4"></i>
            New Meeting
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="flex flex-col items-center justify-center py-20 text-center">
            <div class="w-16 h-16 rounded-2xl bg-brand-900/30 border border-brand-800/40 flex items-center justify-center mb-4">
                <i data-lucide="video-off" class="w-8 h-8 text-brand-600"></i>
            </div>
            <p class="text-white font-medium mb-1">No meetings yet</p>
            <p class="text-slate-500 text-sm mb-6">Schedule your first video call to get started</p>
            <a asp-action="Create" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-xl transition-colors">
                Schedule Meeting
            </a>
        </div>
    }
    else
    {
        <!-- ── Live Now ── -->
        @if (live.Any())
        {
            <section>
                <p class="text-xs uppercase tracking-widest text-slate-600 font-semibold mb-3">Live Now</p>
                <div class="space-y-2">
                    @foreach (var m in live)
                    {
                        <div class="group flex items-center gap-4 bg-surface-card border border-red-500/30 hover:border-red-500/60 rounded-2xl px-5 py-4 transition-all cursor-pointer"
                             onclick="location.href='@Url.Action("Details","Meetings", new { id = m.Id })'">
                            <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 bg-red-500/10 border border-red-500/20">
                                <i data-lucide="radio" class="w-5 h-5 text-red-400"></i>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-white font-medium text-sm truncate">@m.Title</p>
                                <p class="text-slate-500 text-xs mt-0.5">
                                    @m.ScheduledAt.ToLocalTime().ToString("MMM d, yyyy · h:mm tt")
                                    &nbsp;·&nbsp; Host: @(m.Host?.UserName ?? "Unknown")
                                    &nbsp;·&nbsp; @m.Participants.Count participant@(m.Participants.Count != 1 ? "s" : "")
                                </p>
                            </div>
                            <div class="flex items-center gap-3 shrink-0">
                                <span class="flex items-center gap-1.5 text-xs font-medium text-red-400 bg-red-500/10 border border-red-500/20 px-2.5 py-1 rounded-full">
                                    <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
                                    Live
                                </span>
                                <a href="@Url.Action("Join","Meetings", new { id = m.Id })"
                                   onclick="event.stopPropagation()"
                                   class="px-3 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-xs font-semibold rounded-lg transition-colors">
                                    Join
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </section>
        }

        <!-- ── Missed (scheduled but time has passed) ── -->
        @if (missed.Any())
        {
            <section>
                <div class="flex items-center gap-2 mb-3">
                    <p class="text-xs uppercase tracking-widest text-amber-600 font-semibold">Missed</p>
                    <span class="text-[10px] font-semibold bg-amber-500/10 border border-amber-500/20 text-amber-500 px-1.5 py-0.5 rounded-full">@missed.Count</span>
                </div>
                <div class="space-y-2">
                    @foreach (var m in missed)
                    {
                        var missedAgo = now - m.ScheduledAt;
                        var agoText = missedAgo.TotalMinutes < 60
                        ? $"{(int)missedAgo.TotalMinutes}m ago"
                        : missedAgo.TotalHours < 24
                        ? $"{(int)missedAgo.TotalHours}h ago"
                        : $"{(int)missedAgo.TotalDays}d ago";

                        <div class="group flex items-center gap-4 bg-surface-card border border-amber-500/20 hover:border-amber-500/40 rounded-2xl px-5 py-4 transition-all cursor-pointer"
                             onclick="location.href='@Url.Action("Details","Meetings", new { id = m.Id })'">

                            <!-- Missed icon -->
                            <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 bg-amber-500/10 border border-amber-500/20">
                                <i data-lucide="clock-alert" class="w-5 h-5 text-amber-500"></i>
                            </div>

                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2">
                                    <p class="text-white font-medium text-sm truncate">@m.Title</p>
                                </div>
                                <p class="text-slate-500 text-xs mt-0.5">
                                    Scheduled @m.ScheduledAt.ToLocalTime().ToString("MMM d · h:mm tt")
                                    &nbsp;·&nbsp; Host: @(m.Host?.UserName ?? "Unknown")
                                </p>
                            </div>

                            <div class="flex items-center gap-3 shrink-0">
                                <!-- "X ago" indicator -->
                                <span class="text-xs font-medium text-amber-500 bg-amber-500/10 border border-amber-500/20 px-2.5 py-1 rounded-full flex items-center gap-1.5">
                                    <i data-lucide="clock" class="w-3 h-3"></i>
                                    @agoText
                                </span>
                                <!-- Still allow joining — meeting room still exists -->
                                <a href="@Url.Action("Join","Meetings", new { id = m.Id })"
                                   onclick="event.stopPropagation()"
                                   class="px-3 py-1.5 bg-amber-600/20 hover:bg-amber-600/30 border border-amber-600/30 text-amber-400 text-xs font-semibold rounded-lg transition-colors">
                                    Start Late
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </section>
        }

        <!-- ── Upcoming ── -->
        @if (upcoming.Any())
        {
            <section>
                <p class="text-xs uppercase tracking-widest text-slate-600 font-semibold mb-3">Upcoming</p>
                <div class="space-y-2">
                    @foreach (var m in upcoming)
                    {
                        var timeUntil = m.ScheduledAt - now;
                        var soonClass = timeUntil.TotalMinutes <= 15 ? "text-brand-400" : "text-slate-600";
                        var soonText = timeUntil.TotalMinutes <= 60
                        ? $"in {(int)timeUntil.TotalMinutes}m"
                        : timeUntil.TotalHours < 24
                        ? $"in {(int)timeUntil.TotalHours}h"
                        : m.ScheduledAt.ToLocalTime().ToString("MMM d · h:mm tt");

                        <div class="group flex items-center gap-4 bg-surface-card border border-surface-border hover:border-brand-800 rounded-2xl px-5 py-4 transition-all cursor-pointer"
                             onclick="location.href='@Url.Action("Details","Meetings", new { id = m.Id })'">
                            <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 bg-brand-900/30 border border-brand-800/30">
                                <i data-lucide="video" class="w-5 h-5 text-brand-400"></i>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-white font-medium text-sm truncate">@m.Title</p>
                                <p class="text-slate-500 text-xs mt-0.5">
                                    @m.ScheduledAt.ToLocalTime().ToString("MMM d, yyyy · h:mm tt")
                                    &nbsp;·&nbsp; Host: @(m.Host?.UserName ?? "Unknown")
                                    &nbsp;·&nbsp; @m.Participants.Count participant@(m.Participants.Count != 1 ? "s" : "")
                                </p>
                            </div>
                            <div class="flex items-center gap-3 shrink-0">
                                <span class="text-xs font-medium @soonClass">@soonText</span>
                                <span class="text-xs font-medium text-brand-400 bg-brand-500/10 border border-brand-500/20 px-2.5 py-1 rounded-full">
                                    Scheduled
                                </span>
                                <a href="@Url.Action("Join","Meetings", new { id = m.Id })"
                                   onclick="event.stopPropagation()"
                                   class="px-3 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-xs font-semibold rounded-lg transition-colors">
                                    Join
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </section>
        }

        <!-- ── Past ── -->
        @if (past.Any())
        {
            <section>
                <p class="text-xs uppercase tracking-widest text-slate-600 font-semibold mb-3">Past</p>
                <div class="space-y-2">
                    @foreach (var m in past)
                    {
                        TimeSpan? dur = m.StartedAt.HasValue && m.EndedAt.HasValue
                        ? m.EndedAt.Value - m.StartedAt.Value
                        : null;

                        <div class="group flex items-center gap-4 bg-surface-card border border-surface-border hover:border-slate-600 rounded-2xl px-5 py-4 transition-all cursor-pointer opacity-75 hover:opacity-100"
                             onclick="location.href='@Url.Action("Details","Meetings", new { id = m.Id })'">
                            <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 bg-slate-800/50 border border-slate-700/30">
                                <i data-lucide="video" class="w-5 h-5 text-slate-600"></i>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-white font-medium text-sm truncate">@m.Title</p>
                                <p class="text-slate-500 text-xs mt-0.5">
                                    @m.ScheduledAt.ToLocalTime().ToString("MMM d, yyyy · h:mm tt")
                                    &nbsp;·&nbsp; Host: @(m.Host?.UserName ?? "Unknown")
                                    &nbsp;·&nbsp; @m.Participants.Count participant@(m.Participants.Count != 1 ? "s" : "")
                                    @if (dur.HasValue)
                                    {
                                        <span>&nbsp;·&nbsp; @((int)dur.Value.TotalMinutes)m</span>
                                    }
                                </p>
                            </div>
                            <div class="flex items-center gap-3 shrink-0">
                                <span class="text-xs font-medium text-slate-500 bg-slate-800 border border-slate-700 px-2.5 py-1 rounded-full">
                                    Ended
                                </span>
                                <a href="@Url.Action("Details","Meetings", new { id = m.Id })"
                                   onclick="event.stopPropagation()"
                                   class="px-3 py-1.5 bg-slate-800 hover:bg-slate-700 text-slate-300 text-xs font-semibold rounded-lg transition-colors">
                                    View
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </section>
        }
    }
</div>

@section Scripts {
    <script>lucide.createIcons();</script>
}
