@{
    ViewData["Title"] = "Something went wrong";
    Layout = null;
    var requestId = ViewData["RequestId"]?.ToString();
    var errorMsg = TempData["ErrorMessage"]?.ToString();
}

<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Error – MeetIQ</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            400: '#5a8eff', 500: '#3366ff',
                            600: '#1a44f5', 700: '#1332e1',
                        },
                        surface: {
                            DEFAULT: '#0f1117', card: '#161b27',
                            border: '#1f2637', hover: '#1c2235',
                        }
                    },
                    fontFamily: {
                        sans: ['"DM Sans"', 'sans-serif'],
                        display: ['"Syne"', 'sans-serif'],
                        mono: ['"DM Mono"', 'monospace'],
                    },
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&family=Syne:wght@600;700;800&display=swap" rel="stylesheet" />

    <style>
        .dot-grid {
            background-image: radial-gradient(circle, #1f2637 1px, transparent 1px);
            background-size: 28px 28px;
        }

        .orb {
            position: absolute;
            border-radius: 50%;
            pointer-events: none;
            background: radial-gradient(circle, rgba(239,68,68,0.07) 0%, transparent 70%);
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            pointer-events: none;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
        }
    </style>
</head>

<body class="h-full bg-surface font-sans text-slate-300 antialiased">
    <div class="relative min-h-screen dot-grid flex flex-col items-center justify-center px-6">

        <!-- Red-tinted orb for error feel -->
        <div class="orb w-[500px] h-[500px] top-0 left-1/2 -translate-x-1/2 -translate-y-1/2"></div>

        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 mb-12">
            <div class="w-7 h-7 rounded-lg bg-brand-600 flex items-center justify-center shrink-0">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white"
                     stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 20h5v-2a4 4 0 0 0-4-4h-1" />
                    <path d="M9 20H4v-2a4 4 0 0 1 4-4h1" />
                    <circle cx="12" cy="8" r="4" />
                </svg>
            </div>
            <span class="text-white font-semibold font-display text-[16px]">
                Meet<span class="text-brand-400">IQ</span>
            </span>
        </a>

        <!-- Card -->
        <div class="relative z-10 w-full max-w-md text-center">

            <!-- 500 code -->
            <p class="font-display text-[96px] font-bold leading-none text-surface-border select-none mb-2">
                500
            </p>

            <!-- Icon -->
            <div class="w-14 h-14 rounded-2xl bg-red-500/5 border border-red-500/20
                    flex items-center justify-center mx-auto mb-6">
                <svg class="w-6 h-6 text-red-400" xmlns="http://www.w3.org/2000/svg"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="8" x2="12" y2="12" />
                    <line x1="12" y1="16" x2="12.01" y2="16" />
                </svg>
            </div>

            <h1 class="font-display text-2xl font-bold text-white mb-3">Something went wrong</h1>

            <!-- Error message from TempData (safe user-facing message) -->
            <p class="text-slate-500 text-sm leading-relaxed mb-2 max-w-sm mx-auto">
                @(string.IsNullOrEmpty(errorMsg)
                    ? "An unexpected error occurred on our end. Please try again or contact support if the problem persists."
                    : errorMsg)
            </p>

            <!-- Actions -->
            <div class="flex items-center justify-center gap-3 flex-wrap mt-8">
                <a href="/"
                   class="inline-flex items-center gap-2 px-5 py-2.5 bg-brand-600 hover:bg-brand-500
                      text-white text-sm font-semibold rounded-xl transition-colors">
                    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                        <polyline points="9 22 9 12 15 12 15 22" />
                    </svg>
                    Go to Dashboard
                </a>
                <button onclick="location.reload()"
                        class="inline-flex items-center gap-2 px-5 py-2.5 border border-surface-border
                           hover:border-brand-700 text-slate-300 hover:text-white text-sm
                           rounded-xl transition-colors">
                    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="23 4 23 10 17 10" />
                        <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" />
                    </svg>
                    Try again
                </button>
            </div>

            <!-- Request ID for support -->
            @if (!string.IsNullOrEmpty(requestId))
            {
                <div class="mt-8 rounded-xl border border-surface-border bg-surface-card px-4 py-3 text-left">
                    <p class="text-[10px] font-mono text-slate-600 uppercase tracking-wider mb-1">Request ID</p>
                    <p class="text-[11px] font-mono text-slate-500 break-all">@requestId</p>
                    <p class="text-[10px] text-slate-700 mt-1">Share this with support if you need help.</p>
                </div>
            }
        </div>
    </div>
</body>
</html>
