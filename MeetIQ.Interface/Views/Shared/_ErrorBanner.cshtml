@if (TempData["ErrorMessage"] != null)
{
    var code = TempData["ErrorCode"]?.ToString();
    var message = TempData["ErrorMessage"]!.ToString();

    var is401 = code == "401";
    var is404 = code == "404";

    var borderColor = is401 ? "border-yellow-500/20" :
                      is404 ? "border-slate-500/20" :
                              "border-red-500/20";

    var bgColor = is401 ? "bg-yellow-500/5" :
                  is404 ? "bg-slate-500/5" :
                          "bg-red-500/5";

    var textColor = is401 ? "text-yellow-400" :
                    is404 ? "text-slate-400" :
                            "text-red-400";

    <div id="error-banner"
         class="flex items-start gap-3 px-4 py-3 mb-6 rounded-xl border @borderColor @bgColor">
        <svg class="w-4 h-4 shrink-0 mt-0.5 @textColor" xmlns="http://www.w3.org/2000/svg"
             viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            @if (is401)
            {
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                <line x1="12" y1="8" x2="12" y2="12" />
                <line x1="12" y1="16" x2="12.01" y2="16" />
            }
            else if (is404)
            {
                <circle cx="11" cy="11" r="8" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
                <line x1="11" y1="8" x2="11" y2="14" />
                <line x1="8" y1="11" x2="14" y2="11" />
            }
            else
            {
                <circle cx="12" cy="12" r="10" />
                <line x1="12" y1="8" x2="12" y2="12" />
                <line x1="12" y1="16" x2="12.01" y2="16" />
            }
        </svg>
        <div class="flex-1 flex items-start justify-between gap-4">
            <p class="text-xs leading-relaxed @textColor">@message</p>
            <button type="button"
                    onclick="document.getElementById('error-banner').remove()"
                    class="shrink-0 @textColor opacity-60 hover:opacity-100 transition-opacity mt-0.5">
                <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2.5"
                     stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18" />
                    <line x1="6" y1="6" x2="18" y2="18" />
                </svg>
            </button>
        </div>
    </div>
}