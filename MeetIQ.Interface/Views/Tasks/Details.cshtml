@using MeetIQ.Application.Features.Tasks.DTOs
@model TaskDetailsDto
@{
    ViewData["Title"] = Model.Title;

    var (priColor, priLabel) = Model.Priority switch
    {
        "High" => ("bg-red-500/10 text-red-400 border-red-500/20", "High"),
        "Medium" => ("bg-amber-500/10 text-amber-400 border-amber-500/20", "Medium"),
        _ => ("bg-slate-500/10 text-slate-400 border-slate-500/20", "Low"),
    };

    var (stColor, stLabel) = Model.Status switch
    {
        "InProgress" => ("bg-brand-500/10 text-brand-400 border-brand-500/20", "In Progress"),
        "Done" => ("bg-emerald-500/10 text-emerald-400 border-emerald-500/20", "Done"),
        "Cancelled" => ("bg-slate-500/10 text-slate-500 border-slate-700", "Cancelled"),
        _ => ("bg-slate-500/10 text-slate-400 border-slate-500/20", "To Do"),
    };
}

<!-- ── BREADCRUMB ── -->
<div class="flex items-center gap-2 text-xs text-slate-500 mb-6">
    <a href="@Url.Action("Index", "Tasks")" class="hover:text-slate-300 transition-colors">Tasks</a>
    <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
    <span class="text-slate-400 truncate max-w-[240px]">@Model.Title</span>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <!-- ── MAIN CARD ── -->
    <div class="lg:col-span-2 space-y-5">

        <!-- Header -->
        <div class="bg-surface-card border border-surface-border rounded-xl p-6">
            <div class="flex items-start justify-between gap-4 mb-4">
                <div class="flex items-center gap-2 flex-wrap">
                    <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md border text-[11px] font-semibold @priColor">
                        <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
                        @priLabel Priority
                    </span>
                    <span id="status-badge" class="inline-flex items-center px-2 py-0.5 rounded-md border text-[11px] font-semibold @stColor">
                        @stLabel
                    </span>
                    @if (Model.IsAutoGenerated)
                    {
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-purple-500/10 border border-purple-500/20 text-purple-400 text-[11px] font-semibold">
                            <i data-lucide="sparkles" class="w-3 h-3"></i>
                            AI Generated
                        </span>
                    }
                </div>
                <a href="@Url.Action("Edit", "Tasks", new { id = Model.Id })"
                   class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-surface-border hover:bg-surface-hover
                          text-slate-300 text-xs font-semibold rounded-lg transition-colors shrink-0">
                    <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
                    Edit
                </a>
            </div>

            <h1 class="text-2xl font-semibold text-white tracking-tight mb-3">@Model.Title</h1>

            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <div class="prose-task text-slate-400 text-sm leading-relaxed">
                    @Html.Raw(Model.Description)
                </div>
            }
            else
            {
                <p class="text-slate-600 text-sm italic">No description provided.</p>
            }
        </div>

        <!-- Change Status -->
        <div class="bg-surface-card border border-surface-border rounded-xl p-5">
            <div class="flex items-center justify-between mb-3">
                <p class="text-xs uppercase tracking-widest text-slate-600 font-semibold">Change Status</p>
                <svg id="status-spinner" class="hidden w-3.5 h-3.5 text-brand-400 animate-spin" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z" />
                </svg>
            </div>
            <div class="flex flex-wrap gap-2" id="status-buttons">
                @foreach (var status in Enum.GetValues<MeetIQ.Domain.Enums.TaskStatus>())
                {
                    var isCurrent = Model.Status == status.ToString();
                    var (btnBase, btnLabel) = status switch
                    {
                        MeetIQ.Domain.Enums.TaskStatus.ToDo => ("border-slate-700 text-slate-400 hover:border-slate-500 hover:text-slate-300", "To Do"),
                        MeetIQ.Domain.Enums.TaskStatus.InProgress => ("border-brand-600/40 text-brand-400 hover:border-brand-500", "In Progress"),
                        MeetIQ.Domain.Enums.TaskStatus.Done => ("border-emerald-600/40 text-emerald-400 hover:border-emerald-500", "Done"),
                        _ => ("border-slate-700 text-slate-400", status.ToString())
                    };

                    <button type="button"
                            data-status-val="@((int)status)"
                            data-status-key="@status"
                            data-status-label="@btnLabel"
                            data-btn-base="@btnBase"
                            onclick="changeStatus(this)"
                            class="status-btn px-3 py-1.5 rounded-lg border text-xs font-semibold transition-all duration-150
                                   @btnBase @(isCurrent ? "opacity-40 cursor-default pointer-events-none" : "cursor-pointer")">
                        <span class="check-mark">@(isCurrent ? "✓ " : "")</span>@btnLabel
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- ── SIDEBAR DETAILS ── -->
    <div class="space-y-4">

        <!-- Meta -->
        <div class="bg-surface-card border border-surface-border rounded-xl p-5 space-y-4">
            <p class="text-xs uppercase tracking-widest text-slate-600 font-semibold">Details</p>

           @*  @if (!string.IsNullOrEmpty(Model.AssigneeName))
            {
                <div class="flex items-center gap-3">
                    <i data-lucide="user" class="w-4 h-4 text-slate-600 shrink-0"></i>
                    <div>
                        <p class="text-[11px] text-slate-600">Assignee</p>
                        <p class="text-sm text-white font-medium">@Model.AssigneeName</p>
                    </div>
                </div>
            } *@

            @if (Model.DueDate.HasValue)
            {
                var overdue = Model.DueDate.Value < DateTime.UtcNow && Model.Status != "Done";
                <div class="flex items-center gap-3">
                    <i data-lucide="calendar" class="w-4 h-4 @(overdue ? "text-red-500" : "text-slate-600") shrink-0"></i>
                    <div>
                        <p class="text-[11px] text-slate-600">Due Date</p>
                        <p class="text-sm @(overdue ? "text-red-400" : "text-white") font-medium">
                            @Model.DueDate.Value.ToString("MMM d, yyyy")
                            @if (overdue)
                            {
                                <text> — Overdue</text>
                            }
                        </p>
                    </div>
                </div>
            }

            @if (Model.MeetingId.HasValue)
            {
                <div class="flex items-center gap-3">
                    <i data-lucide="video" class="w-4 h-4 text-slate-600 shrink-0"></i>
                    <div>
                        <p class="text-[11px] text-slate-600">Source Meeting</p>
                        <a href="/Meetings/@Model.MeetingId"
                           class="text-sm text-brand-400 hover:text-brand-300 font-medium transition-colors">
                            View Meeting →
                        </a>
                    </div>
                </div>
            }
        </div>

        <!-- Danger Zone -->
        <div class="bg-surface-card border border-red-500/10 rounded-xl p-5">
            <p class="text-xs uppercase tracking-widest text-slate-600 font-semibold mb-3">Danger Zone</p>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                  onsubmit="return confirm('Are you sure you want to delete this task? This action cannot be undone.')">
                @Html.AntiForgeryToken()
                <button type="submit"
                        class="w-full flex items-center justify-center gap-2 px-4 py-2
                               border border-red-500/30 hover:border-red-500/60 hover:bg-red-500/10
                               text-red-400 text-sm font-semibold rounded-lg transition-colors">
                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                    Delete Task
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .prose-task p {
            margin-bottom: .6rem;
        }

        .prose-task h2 {
            font-size: 1rem;
            font-weight: 600;
            color: #e2e8f0;
            margin: 1rem 0 .4rem;
        }

        .prose-task h3 {
            font-size: .9rem;
            font-weight: 600;
            color: #cbd5e1;
            margin: .8rem 0 .35rem;
        }

        .prose-task strong {
            color: #e2e8f0;
            font-weight: 600;
        }

        .prose-task em {
            font-style: italic;
        }

        .prose-task s {
            opacity: .5;
        }

        .prose-task a {
            color: #5a8eff;
            text-decoration: underline;
        }

        .prose-task ul {
            list-style: disc;
            padding-left: 1.4rem;
            margin-bottom: .6rem;
        }

        .prose-task ol {
            list-style: decimal;
            padding-left: 1.4rem;
            margin-bottom: .6rem;
        }

        .prose-task li {
            margin-bottom: .25rem;
        }

        .prose-task blockquote {
            border-left: 3px solid #3366ff;
            color: #94a3b8;
            padding-left: 12px;
            margin: .6rem 0;
        }

        .prose-task pre {
            background: #0f1117;
            border: 1px solid #1f2637;
            border-radius: 8px;
            padding: 10px 14px;
            font-family: 'DM Mono', monospace;
            font-size: .8rem;
            color: #93c5fd;
            overflow-x: auto;
            margin: .6rem 0;
        }

        .prose-task code {
            background: #0f1117;
            border-radius: 4px;
            padding: 1px 5px;
            font-family: 'DM Mono', monospace;
            font-size: .8rem;
            color: #93c5fd;
        }

        /* Toast */
        #status-toast {
            transition: opacity .3s, transform .3s;
        }

            #status-toast.hide {
                opacity: 0;
                transform: translateY(6px);
                pointer-events: none;
            }
    </style>

    <!-- Toast element (lives outside the grid so it floats) -->
    <div id="status-toast"
         class="hide fixed bottom-6 right-6 z-50 flex items-center gap-2.5 px-4 py-3
                bg-surface-card border border-surface-border rounded-xl shadow-xl text-sm font-medium text-white">
        <span id="toast-icon" class="text-base"></span>
        <span id="toast-msg"></span>
    </div>

    <script>
        lucide.createIcons();

        const TASK_ID = '@Model.Id';
        const TOKEN = document.querySelector('input[name="__RequestVerificationToken"]')?.value
            ?? document.cookie.match(/XSRF-TOKEN=([^;]+)/)?.[1] ?? '';

        // Maps status key → badge classes + label
        const STATUS_META = {
            'ToDo': { cls: 'bg-slate-500/10 text-slate-400 border-slate-500/20', label: 'To Do' },
            'InProgress': { cls: 'bg-brand-500/10 text-brand-400 border-brand-500/20', label: 'In Progress' },
            'Done': { cls: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20', label: 'Done' },
            'Cancelled': { cls: 'bg-slate-500/10 text-slate-500 border-slate-700', label: 'Cancelled' },
        };

        async function changeStatus(btn) {
            const statusVal = btn.dataset.statusVal;
            const statusKey = btn.dataset.statusKey;
            const statusLabel = btn.dataset.statusLabel;

            // Show spinner
            const spinner = document.getElementById('status-spinner');
            spinner.classList.remove('hidden');
            btn.disabled = true;

            try {
                const res = await fetch('/Tasks/ChangeStatus', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': TOKEN,
                        'X-Requested-With': 'XMLHttpRequest',
                    },
                    body: new URLSearchParams({ taskId: TASK_ID, status: statusVal }),
                });

                if (!res.ok) throw new Error('Request failed: ' + res.status);

                // ── Update badge ──
                const badge = document.getElementById('status-badge');
                const meta = STATUS_META[statusKey] || { cls: '', label: statusLabel };
                badge.className = 'inline-flex items-center px-2 py-0.5 rounded-md border text-[11px] font-semibold ' + meta.cls;
                badge.textContent = meta.label;

                // ── Update buttons active state ──
                document.querySelectorAll('.status-btn').forEach(b => {
                    const isCurrent = b.dataset.statusKey === statusKey;
                    b.querySelector('.check-mark').textContent = isCurrent ? '✓ ' : '';
                    b.disabled = false;
                    if (isCurrent) {
                        b.classList.add('opacity-40', 'cursor-default', 'pointer-events-none');
                    } else {
                        b.classList.remove('opacity-40', 'cursor-default', 'pointer-events-none');
                        b.classList.add('cursor-pointer');
                    }
                });

                showToast('✓', 'Status updated to ' + statusLabel, 'text-emerald-400');

            } catch (err) {
                showToast('✕', 'Failed to update status', 'text-red-400');
                btn.disabled = false;
            } finally {
                spinner.classList.add('hidden');
            }
        }

        let toastTimer;
        function showToast(icon, msg, iconCls) {
            const toast = document.getElementById('status-toast');
            const iconEl = document.getElementById('toast-icon');
            const msgEl = document.getElementById('toast-msg');

            iconEl.textContent = icon;
            iconEl.className = 'text-base ' + iconCls;
            msgEl.textContent = msg;

            toast.classList.remove('hide');
            clearTimeout(toastTimer);
            toastTimer = setTimeout(() => toast.classList.add('hide'), 2800);
        }
    </script>
}
