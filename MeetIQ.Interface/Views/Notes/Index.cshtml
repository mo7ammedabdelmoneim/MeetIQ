@model NotesIndexViewModel
@{
    ViewData["Title"] = "Notes";
}

<!-- TOOLBAR -->
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div>
        <h2 class="text-lg font-semibold text-white">Notes</h2>
        <p class="text-xs text-slate-500 mt-0.5" id="notes-count">
            @Model.TotalCount note@(Model.TotalCount == 1 ? "" : "s")
        </p>
    </div>
    <a asp-action="Create"
       class="flex items-center gap-2 px-4 py-2 bg-brand-600 hover:bg-brand-500
              text-white text-sm font-semibold rounded-lg transition-colors shadow-glow self-start sm:self-auto">
        <i data-lucide="plus" class="w-4 h-4"></i>
        New Note
    </a>
</div>

<!-- FILTERS -->
<div class="flex flex-col sm:flex-row gap-3 mb-6">
    <!-- Search -->
    <div class="relative flex-1 max-w-sm">
        <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500 pointer-events-none"></i>
        <input type="text"
               id="search-input"
               value="@Model.SearchQuery"
               placeholder="Search notes…"
               class="w-full pl-9 pr-4 py-2 bg-surface-card border border-surface-border rounded-lg text-sm text-slate-200
                      placeholder-slate-600 focus:outline-none focus:border-brand-600 transition-colors" />
    </div>

    <!-- Tag filter -->
    <select id="tag-select"
            class="px-3 py-2 bg-surface-card border border-surface-border rounded-lg text-sm text-slate-300
                   focus:outline-none focus:border-brand-600 transition-colors">
        <option value="">All Tags</option>
        @foreach (var t in Model.AllTags)
        {
            <option value="@t" selected="@(Model.SelectedTag == t)">@t</option>
        }
    </select>

    <!-- Type filter pills -->
    <div class="flex gap-1.5" id="filter-pills">
        @foreach (var (label, val, icon) in new[] {
        ("All",    "all",    "layers"),
        ("Manual", "manual", "pencil"),
        ("AI",     "ai",     "sparkles")
        })
        {
            var active = (Model.FilterType ?? "all") == val;
            <button type="button"
                    data-filter="@val"
                    class="filter-pill flex items-center gap-1.5 px-3 py-2 rounded-lg text-xs font-medium transition-colors
                           @(active ? "bg-brand-600 text-white" : "bg-surface-card border border-surface-border text-slate-400 hover:text-white hover:border-brand-600")">
                <i data-lucide="@icon" class="w-3.5 h-3.5"></i>
                @label
            </button>
        }
    </div>
</div>

<!-- SUCCESS BANNER -->
@if (TempData["Success"] is string msg)
{
    <div class="flex items-center gap-3 px-4 py-3 mb-6 bg-emerald-500/10 border border-emerald-500/25 rounded-lg text-emerald-400 text-sm">
        <i data-lucide="check-circle-2" class="w-4 h-4 shrink-0"></i>
        @msg
    </div>
}

<!-- NOTES GRID (AJAX target) -->
<div id="notes-grid">
    @await Html.PartialAsync("_NotesGrid", Model)
</div>

@section Scripts {
    <script>
        // ── State ────────────────────────────────────────────────────────────
        let state = {
            q: '@Html.Raw(Model.SearchQuery ?? "")',
            tag: '@Html.Raw(Model.SelectedTag ?? "")',
            filter: '@Html.Raw(Model.FilterType ?? "all")',
            page: 1
        };

        let searchTimer = null;

        // ── Fetch & render ───────────────────────────────────────────────────
        async function loadNotes() {
            const params = new URLSearchParams();
            if (state.q) params.set('q', state.q);
            if (state.tag) params.set('tag', state.tag);
            if (state.filter !== 'all') params.set('filter', state.filter);
            if (state.page > 1) params.set('page', state.page);

            // Update URL without reload
            const newUrl = params.toString()
                ? `${location.pathname}?${params}`
                : location.pathname;
            history.replaceState(null, '', newUrl);

            // Show skeleton
            document.getElementById('notes-grid').innerHTML = skeletonHtml();

            try {
                params.set('partial', '1');   // tells controller to return partial
                const res = await fetch(`${location.pathname}?${params}`, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                const html = await res.text();
                document.getElementById('notes-grid').innerHTML = html;

                // Update count label
                const countEl = document.getElementById('notes-count');
                const total = document.getElementById('notes-total-count');
                if (total && countEl) {
                    const n = parseInt(total.dataset.count);
                    countEl.textContent = n + (n === 1 ? ' note' : ' notes');
                }

                lucide.createIcons();
            } catch (e) {
                document.getElementById('notes-grid').innerHTML =
                    `<p class="text-slate-500 text-sm py-12 text-center">Something went wrong. Please try again.</p>`;
            }
        }

        // ── Search input — debounced 350ms ───────────────────────────────────
        document.getElementById('search-input').addEventListener('input', function () {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(() => {
                state.q = this.value.trim();
                state.page = 1;
                loadNotes();
            }, 1000);
        });

        // ── Tag select — instant ─────────────────────────────────────────────
        document.getElementById('tag-select').addEventListener('change', function () {
            state.tag = this.value;
            state.page = 1;
            loadNotes();
        });

        // ── Filter pills — instant ───────────────────────────────────────────
        document.getElementById('filter-pills').addEventListener('click', function (e) {
            const btn = e.target.closest('.filter-pill');
            if (!btn) return;

            // Visual active state
            document.querySelectorAll('.filter-pill').forEach(p => {
                p.classList.remove('bg-brand-600', 'text-white');
                p.classList.add('bg-surface-card', 'border', 'border-surface-border',
                    'text-slate-400', 'hover:text-white', 'hover:border-brand-600');
            });
            btn.classList.add('bg-brand-600', 'text-white');
            btn.classList.remove('bg-surface-card', 'border', 'border-surface-border',
                'text-slate-400', 'hover:text-white', 'hover:border-brand-600');

            state.filter = btn.dataset.filter;
            state.page = 1;
            loadNotes();
        });

        // ── Pagination (delegated — grid is replaced on each load) ───────────
        document.getElementById('notes-grid').addEventListener('click', function (e) {
            const btn = e.target.closest('[data-page]');
            if (!btn) return;
            e.preventDefault();
            state.page = parseInt(btn.dataset.page);
            loadNotes();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        // ── Tag click from inside a card (delegated) ─────────────────────────
        document.getElementById('notes-grid').addEventListener('click', function (e) {
            const tagBtn = e.target.closest('[data-tag-filter]');
            if (!tagBtn) return;
            e.preventDefault();
            e.stopPropagation();

            const tagName = tagBtn.dataset.tagFilter;
            state.tag = tagName;
            state.page = 1;

            // Sync the select dropdown
            const sel = document.getElementById('tag-select');
            if (sel) sel.value = tagName;

            loadNotes();
        });

        // ── Skeleton placeholder ─────────────────────────────────────────────
        function skeletonHtml() {
        }
//     </script>
// }
