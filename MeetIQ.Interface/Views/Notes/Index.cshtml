@using MeetIQ.Application.Interfaces.Services
@model NotesIndexViewModel
@{
    ViewData["Title"] = "Notes";
}

<!-- TOOLBAR -->
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div>
        <h2 class="text-lg font-semibold text-white">Notes</h2>
        <p class="text-xs text-slate-500 mt-0.5">@Model.TotalCount note@(Model.TotalCount == 1 ? "" : "s")</p>
    </div>
    <a asp-action="Create"
       class="flex items-center gap-2 px-4 py-2 bg-brand-600 hover:bg-brand-500
              text-white text-sm font-semibold rounded-lg transition-colors shadow-glow self-start sm:self-auto">
        <i data-lucide="plus" class="w-4 h-4"></i>
        New Note
    </a>
</div>

<!-- FILTERS -->
<form method="get" class="flex flex-col sm:flex-row gap-3 mb-6">
    <!-- Search -->
    <div class="relative flex-1 max-w-sm">
        <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500 pointer-events-none"></i>
        <input type="text" name="q" value="@Model.SearchQuery"
               placeholder="Search notes…"
               class="w-full pl-9 pr-4 py-2 bg-surface-card border border-surface-border rounded-lg text-sm text-slate-200
                      placeholder-slate-600 focus:outline-none focus:border-brand-600 transition-colors" />
    </div>

    <!-- Tag filter -->
    <select name="tag"
            class="px-3 py-2 bg-surface-card border border-surface-border rounded-lg text-sm text-slate-300
                   focus:outline-none focus:border-brand-600 transition-colors">
        <option value="">All Tags</option>
        @foreach (var t in Model.AllTags)
        {
            <option value="@t" selected="@(Model.SelectedTag == t)">@t</option>
        }
    </select>

    <!-- Type filter pills -->
    <div class="flex gap-1.5">
        @foreach (var (label, val, icon) in new[] {
        ("All",    "all",    "layers"),
        ("Manual", "manual", "pencil"),
        ("AI",     "ai",     "sparkles")
        })
        {
            var active = (Model.FilterType ?? "all") == val;
            <a asp-action="Index"
               asp-route-q="@Model.SearchQuery"
               asp-route-tag="@Model.SelectedTag"
               asp-route-filter="@val"
               class="flex items-center gap-1.5 px-3 py-2 rounded-lg text-xs font-medium transition-colors
                      @(active ? "bg-brand-600 text-white" : "bg-surface-card border border-surface-border text-slate-400 hover:text-white hover:border-brand-600")">
                <i data-lucide="@icon" class="w-3.5 h-3.5"></i>
                @label
            </a>
        }
    </div>
</form>

<!-- SUCCESS BANNER -->
@if (TempData["Success"] is string msg)
{
    <div class="flex items-center gap-3 px-4 py-3 mb-6 bg-emerald-500/10 border border-emerald-500/25 rounded-lg text-emerald-400 text-sm">
        <i data-lucide="check-circle-2" class="w-4 h-4 shrink-0"></i>
        @msg
    </div>
}

<!-- NOTES GRID  -->
@if (!Model.Notes.Any())
{
    <div class="flex flex-col items-center justify-center py-24 text-center">
        <div class="w-16 h-16 rounded-2xl bg-surface-card border border-surface-border flex items-center justify-center mb-4">
            <i data-lucide="notebook-pen" class="w-8 h-8 text-slate-600"></i>
        </div>
        <p class="text-slate-400 font-medium mb-1">No notes yet</p>
        <p class="text-slate-600 text-sm mb-4">
            @(string.IsNullOrEmpty(Model.SearchQuery) ? "Create your first note to get started." : "No notes match your search.")
        </p>
        <a asp-action="Create"
           class="flex items-center gap-2 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg transition-colors">
            <i data-lucide="plus" class="w-4 h-4"></i>
            New Note
        </a>
    </div>
}
else
{
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
        @foreach (var note in Model.Notes)
        {
            <a asp-action="Details" asp-route-id="@note.Id"
               class="group flex flex-col bg-surface-card border border-surface-border rounded-xl p-5
                      hover:border-brand-600/50 hover:shadow-glow transition-all duration-200">

                <!-- Top row: badges + date -->
                <div class="flex items-center gap-2 mb-3">
                    @if (note.IsAutoGenerated)
                    {
                        <span class="flex items-center gap-1 px-2 py-0.5 rounded-full bg-violet-500/15 text-violet-400 text-[10px] font-semibold uppercase tracking-wide">
                            <i data-lucide="sparkles" class="w-3 h-3"></i> AI
                        </span>
                    }
                    @if (note.IsEdited && note.IsAutoGenerated)
                    {
                        <span class="flex items-center gap-1 px-2 py-0.5 rounded-full bg-amber-500/15 text-amber-400 text-[10px] font-semibold uppercase tracking-wide">
                            <i data-lucide="pencil" class="w-3 h-3"></i> Edited
                        </span>
                    }
                    <span class="ml-auto text-[11px] text-slate-600">
                        @note.UpdatedAt.ToString("MMM d")
                    </span>
                </div>

                <!-- Title -->
                <h3 class="text-sm font-semibold text-white group-hover:text-brand-300 transition-colors line-clamp-2 mb-2">
                    @note.Title
                </h3>

                <!-- Snippet -->
                <p class="text-xs text-slate-500 leading-relaxed line-clamp-3 flex-1">
                    @note.ContentSnippet
                </p>

                <!-- Footer -->
                <div class="mt-4 pt-3 border-t border-surface-border flex flex-wrap items-center gap-x-3 gap-y-1.5">
                    @if (!string.IsNullOrEmpty(note.MeetingTitle))
                    {
                        <span class="flex items-center gap-1 text-[11px] text-slate-500">
                            <i data-lucide="video" class="w-3 h-3 text-brand-500"></i>
                            @Truncate(note.MeetingTitle, 22)
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(note.CalendarEventTitle))
                    {
                        <span class="flex items-center gap-1 text-[11px] text-slate-500">
                            <i data-lucide="calendar" class="w-3 h-3 text-brand-500"></i>
                            @Truncate(note.CalendarEventTitle, 22)
                        </span>
                    }
                    @foreach (var tag in note.Tags.Take(3))
                    {
                        <span class="px-2 py-0.5 rounded-full bg-surface-border text-[10px] text-slate-400">#@tag</span>
                    }
                    @if (note.Tags.Count() > 3)
                    {
                        <span class="text-[10px] text-slate-600">+@(note.Tags.Count() - 3) more</span>
                    }
                </div>
            </a>
        }
    </div>
}

@functions {
    static string Truncate(string s, int max) =>
        s.Length <= max ? s : s[..max].TrimEnd() + "…";
}

@section Scripts {
    <script>lucide.createIcons();</script>
}
