@model NoteDetailViewModel
@{
    ViewData["Title"] = Model.Title;
}

<!-- ── BREADCRUMB ────────────────────────────────────────────────────────── -->
<nav class="flex items-center gap-2 text-xs text-slate-600 mb-6">
    <a asp-action="Index" class="hover:text-slate-400 transition-colors">Notes</a>
    <i data-lucide="chevron-right" class="w-3 h-3"></i>
    <span class="text-slate-400 truncate max-w-xs">@Model.Title</span>
</nav>

<div class="flex flex-col lg:flex-row gap-6">

    <!-- ── MAIN CONTENT ──────────────────────────────────────────────────── -->
    <article class="flex-1 min-w-0">
        <div class="bg-surface-card border border-surface-border rounded-xl overflow-hidden">

            <!-- Header -->
            <div class="flex items-start justify-between gap-4 px-6 py-5 border-b border-surface-border">
                <div class="min-w-0 flex-1">
                    <!-- Badges -->
                    <div class="flex flex-wrap items-center gap-2 mb-2">
                        @if (Model.IsAutoGenerated)
                        {
                            <span class="flex items-center gap-1 px-2.5 py-1 rounded-full bg-violet-500/15 text-violet-400 text-xs font-semibold">
                                <i data-lucide="sparkles" class="w-3.5 h-3.5"></i> AI Generated
                            </span>
                        }
                        @if (Model.IsEdited && Model.IsAutoGenerated)
                        {
                            <span class="flex items-center gap-1 px-2.5 py-1 rounded-full bg-amber-500/15 text-amber-400 text-xs font-semibold">
                                <i data-lucide="pencil" class="w-3.5 h-3.5"></i> Manually Edited
                            </span>
                        }
                        @if (!Model.IsAutoGenerated)
                        {
                            <span class="flex items-center gap-1 px-2.5 py-1 rounded-full bg-slate-700/50 text-slate-400 text-xs font-semibold">
                                <i data-lucide="pencil-line" class="w-3.5 h-3.5"></i> Manual Note
                            </span>
                        }
                    </div>
                    <h1 class="text-xl font-semibold text-white leading-snug">@Model.Title</h1>
                </div>

                <!-- Actions -->
                <div class="flex items-center gap-2 shrink-0">
                    <a asp-action="Edit" asp-route-id="@Model.Id"
                       class="flex items-center gap-1.5 px-3 py-1.5 bg-surface-hover border border-surface-border
                              hover:border-brand-600 text-slate-300 hover:text-white text-xs font-medium rounded-lg transition-colors">
                        <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
                        Edit
                    </a>
                    <button onclick="document.getElementById('deleteModal').classList.remove('hidden')"
                            class="flex items-center gap-1.5 px-3 py-1.5 bg-surface-hover border border-surface-border
                                   hover:border-red-500/50 text-slate-400 hover:text-red-400 text-xs font-medium rounded-lg transition-colors">
                        <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                        Delete
                    </button>
                </div>
            </div>

            <!-- ── Rich-text content (Quill read-only render) ── -->
            <div class="ql-snow px-6 py-6">
                <div class="ql-editor note-content">
                    @Html.Raw(Model.Content)
                </div>
            </div>

        </div>
    </article>

    <!-- ── SIDEBAR META ──────────────────────────────────────────────────── -->
    <aside class="w-full lg:w-64 shrink-0 space-y-4">

        <!-- Metadata card -->
        <div class="bg-surface-card border border-surface-border rounded-xl p-5 space-y-4">
            <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-widest">Details</h3>

            <dl class="space-y-3 text-sm">
                <div>
                    <dt class="text-[11px] text-slate-600 uppercase tracking-wide mb-0.5">Author</dt>
                    <dd class="text-slate-300 font-medium">@Model.AuthorName</dd>
                </div>
                <div>
                    <dt class="text-[11px] text-slate-600 uppercase tracking-wide mb-0.5">Created</dt>
                    <dd class="text-slate-400">@Model.CreatedAt.ToString("MMM d, yyyy 'at' HH:mm")</dd>
                </div>
                @if (Model.UpdatedAt != Model.CreatedAt)
                {
                    <div>
                        <dt class="text-[11px] text-slate-600 uppercase tracking-wide mb-0.5">Last Updated</dt>
                        <dd class="text-slate-400">@Model.UpdatedAt.ToString("MMM d, yyyy 'at' HH:mm")</dd>
                    </div>
                }

                @if (Model.MeetingId.HasValue)
                {
                    <div>
                        <dt class="text-[11px] text-slate-600 uppercase tracking-wide mb-0.5">Meeting</dt>
                        <dd>
                            <a asp-controller="Meetings" asp-action="Details" asp-route-id="@Model.MeetingId"
                               class="flex items-center gap-1.5 text-brand-400 hover:text-brand-300 transition-colors text-xs">
                                <i data-lucide="video" class="w-3.5 h-3.5 shrink-0"></i>
                                <span class="truncate">@Model.MeetingTitle</span>
                            </a>
                        </dd>
                    </div>
                }

                @if (Model.CalendarEventId.HasValue)
                {
                    <div>
                        <dt class="text-[11px] text-slate-600 uppercase tracking-wide mb-0.5">Calendar Event</dt>
                        <dd>
                            <a asp-controller="Calendar" asp-action="Details" asp-route-id="@Model.CalendarEventId"
                               class="flex items-center gap-1.5 text-brand-400 hover:text-brand-300 transition-colors text-xs">
                                <i data-lucide="calendar" class="w-3.5 h-3.5 shrink-0"></i>
                                <span class="truncate">@Model.CalendarEventTitle</span>
                            </a>
                        </dd>
                    </div>
                }
            </dl>
        </div>

        <!-- Tags card -->
        @if (Model.Tags.Any())
        {
            <div class="bg-surface-card border border-surface-border rounded-xl p-5">
                <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-3">Tags</h3>
                <div class="flex flex-wrap gap-2">
                    @foreach (var tag in Model.Tags)
                    {
                        <a asp-action="Index" asp-route-tag="@tag"
                           class="px-2.5 py-1 rounded-full bg-surface-border hover:bg-surface-hover text-slate-400 hover:text-white text-xs transition-colors">
                            #@tag
                        </a>
                    }
                </div>
            </div>
        }

        <!-- Quick actions -->
        <div class="bg-surface-card border border-surface-border rounded-xl p-5 space-y-2">
            <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-3">Actions</h3>
            <a asp-action="Create" asp-route-meetingId="@Model.MeetingId"
               class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-slate-400 hover:text-white hover:bg-surface-hover transition-colors">
                <i data-lucide="plus" class="w-4 h-4"></i>
                New Note
            </a>
            <a asp-action="Index"
               class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-slate-400 hover:text-white hover:bg-surface-hover transition-colors">
                <i data-lucide="arrow-left" class="w-4 h-4"></i>
                Back to Notes
            </a>
        </div>
    </aside>
</div>

<!-- ── DELETE CONFIRM MODAL ──────────────────────────────────────────────── -->
<div id="deleteModal"
     class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4">
    <div class="bg-surface-card border border-surface-border rounded-2xl shadow-2xl p-6 w-full max-w-sm">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-red-500/15 flex items-center justify-center">
                <i data-lucide="trash-2" class="w-5 h-5 text-red-400"></i>
            </div>
            <h3 class="text-base font-semibold text-white">Delete Note</h3>
        </div>
        <p class="text-sm text-slate-400 mb-6">
            Are you sure you want to delete <strong class="text-white">"@Model.Title"</strong>?
            This action cannot be undone.
        </p>
        <div class="flex gap-3">
            <button onclick="document.getElementById('deleteModal').classList.add('hidden')"
                    class="flex-1 px-4 py-2 bg-surface-hover border border-surface-border hover:border-slate-500
                           text-slate-300 text-sm font-medium rounded-lg transition-colors">
                Cancel
            </button>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="flex-1">
                @Html.AntiForgeryToken()
                <button type="submit"
                        class="w-full px-4 py-2 bg-red-600 hover:bg-red-500 text-white text-sm font-semibold rounded-lg transition-colors">
                    Delete
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.snow.min.css" rel="stylesheet" />

    <style>
        /* Override Quill snow borders — read-only display only */
        .ql-snow.ql-toolbar {
            display: none;
        }

        .ql-container.ql-snow {
            border: none !important;
        }

        /* Dark theme for note content */
        .note-content {
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            line-height: 1.75;
            color: #cbd5e1;
            padding: 0 !important; /* remove quill default padding — parent px-6 py-6 handles it */
            min-height: unset !important;
        }

            .note-content h1 {
                font-size: 1.5rem;
                font-weight: 600;
                color: #f1f5f9;
                margin-bottom: 0.75rem;
            }

            .note-content h2 {
                font-size: 1.25rem;
                font-weight: 600;
                color: #f1f5f9;
                margin-bottom: 0.5rem;
            }

            .note-content h3 {
                font-size: 1.1rem;
                font-weight: 600;
                color: #e2e8f0;
                margin-bottom: 0.5rem;
            }

            .note-content p {
                margin-bottom: 0.75rem;
                color: #94a3b8;
            }

            .note-content a {
                color: #5a8eff;
                text-decoration: underline;
            }

                .note-content a:hover {
                    color: #8eb6ff;
                }

            .note-content strong {
                color: #e2e8f0;
                font-weight: 600;
            }

            .note-content em {
                color: #94a3b8;
            }

            .note-content ul, .note-content ol {
                padding-left: 1.5rem;
                margin-bottom: 0.75rem;
                color: #94a3b8;
            }

            .note-content li {
                margin-bottom: 0.25rem;
            }

            .note-content blockquote {
                border-left: 3px solid #3366ff;
                padding-left: 1rem;
                margin: 1rem 0;
                color: #64748b;
                font-style: italic;
            }

            .note-content pre.ql-syntax {
                background: #0f1117;
                border: 1px solid #1f2637;
                border-radius: 8px;
                color: #94a3b8;
                padding: 1rem;
                font-family: 'DM Mono', monospace;
                font-size: 13px;
                overflow-x: auto;
                margin: 0.75rem 0;
            }

            .note-content code {
                background: #1f2637;
                color: #8eb6ff;
                padding: 0.15rem 0.4rem;
                border-radius: 4px;
                font-family: 'DM Mono', monospace;
                font-size: 13px;
            }
    </style>

    <script>lucide.createIcons();</script>
}
