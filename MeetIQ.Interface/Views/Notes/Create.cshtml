@using MeetIQ.Application.Interfaces.Services
@model NoteCreateViewModel
@{
    ViewData["Title"] = "New Note";
}

<!-- ── BREADCRUMB ────────────────────────────────────────────────────────── -->
<nav class="flex items-center gap-2 text-xs text-slate-600 mb-6">
    <a asp-action="Index" class="hover:text-slate-400 transition-colors">Notes</a>
    <i data-lucide="chevron-right" class="w-3 h-3"></i>
    <span class="text-slate-400">New Note</span>
</nav>

<form asp-action="Create" method="post" id="noteForm">
    @Html.AntiForgeryToken()

    <div class="flex flex-col lg:flex-row gap-6">

        <!-- ── EDITOR AREA ──────────────────────────────────────────────── -->
        <div class="flex-1 min-w-0 space-y-4">

            <!-- Title -->
            <div class="bg-surface-card border border-surface-border rounded-xl p-5">
                <label asp-for="Title" class="block text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2">Title</label>
                <input asp-for="Title"
                       placeholder="Note title…"
                       class="w-full bg-transparent text-xl font-semibold text-white placeholder-slate-700
                              focus:outline-none border-0 p-0" />
                <span asp-validation-for="Title" class="text-red-400 text-xs mt-1 block"></span>
            </div>

            <!-- Rich-text editor -->
            <div class="bg-surface-card border border-surface-border rounded-xl overflow-hidden">
                <div class="border-b border-surface-border px-4 py-2 flex items-center gap-1 flex-wrap">
                    <span class="text-xs text-slate-600 font-medium mr-2">Content</span>
                    <!-- Quill toolbar -->
                    <div id="toolbar" class="flex items-center gap-0.5 flex-wrap">
                        <button class="ql-bold   ql-btn" title="Bold"></button>
                        <button class="ql-italic ql-btn" title="Italic"></button>
                        <button class="ql-underline ql-btn" title="Underline"></button>
                        <span class="w-px h-4 bg-surface-border mx-1"></span>
                        <button class="ql-list ql-btn" value="ordered" title="Ordered list"></button>
                        <button class="ql-list ql-btn" value="bullet" title="Bullet list"></button>
                        <span class="w-px h-4 bg-surface-border mx-1"></span>
                        <button class="ql-blockquote ql-btn" title="Blockquote"></button>
                        <button class="ql-code-block ql-btn" title="Code block"></button>
                        <span class="w-px h-4 bg-surface-border mx-1"></span>
                        <select class="ql-header" title="Heading">
                            <option value="1">H1</option>
                            <option value="2">H2</option>
                            <option value="3">H3</option>
                            <option selected></option>
                        </select>
                        <span class="w-px h-4 bg-surface-border mx-1"></span>
                        <button class="ql-link ql-btn" title="Link"></button>
                        <button class="ql-clean ql-btn" title="Clear format"></button>
                    </div>
                </div>
                <div id="quill-editor" style="min-height: 340px;" class="px-6 py-4 text-slate-300"></div>
                <!-- Hidden input synced with Quill -->
                <input type="hidden" asp-for="Content" id="ContentInput" />
            </div>
        </div>

        <!-- ── META SIDEBAR ──────────────────────────────────────────────── -->
        <aside class="w-full lg:w-64 shrink-0 space-y-4">

            <!-- Actions -->
            <div class="bg-surface-card border border-surface-border rounded-xl p-4 flex flex-col gap-2">
                <button type="submit"
                        class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-brand-600 hover:bg-brand-500
                               text-white text-sm font-semibold rounded-lg transition-colors shadow-glow">
                    <i data-lucide="save" class="w-4 h-4"></i>
                    Save Note
                </button>
                <a asp-action="Index"
                   class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-surface-hover border border-surface-border
                          hover:border-slate-500 text-slate-400 text-sm font-medium rounded-lg transition-colors">
                    Cancel
                </a>
            </div>

            <!-- Meeting link -->
            <div class="bg-surface-card border border-surface-border rounded-xl p-5 space-y-3">
                <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-widest">Link to Meeting</h3>
                <select asp-for="MeetingId" asp-items="@(new SelectList(Model.Meetings, "Value", "Text"))"
                        class="w-full px-3 py-2 bg-surface border border-surface-border rounded-lg text-sm text-slate-300
                               focus:outline-none focus:border-brand-600 transition-colors">
                    <option value="">— None —</option>
                </select>
            </div>

            <!-- Calendar event link -->
            <div class="bg-surface-card border border-surface-border rounded-xl p-5 space-y-3">
                <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-widest">Link to Calendar Event</h3>
                <select asp-for="CalendarEventId" asp-items="@(new SelectList(Model.CalendarEvents, "Value", "Text"))"
                        class="w-full px-3 py-2 bg-surface border border-surface-border rounded-lg text-sm text-slate-300
                               focus:outline-none focus:border-brand-600 transition-colors">
                    <option value="">— None —</option>
                </select>
            </div>

            <!-- Tags -->
            <div class="bg-surface-card border border-surface-border rounded-xl p-5 space-y-3">
                <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-widest">Tags</h3>
                <input asp-for="TagsInput"
                       id="tagsInput"
                       placeholder="Add tags…"
                       autocomplete="off"
                       class="w-full px-3 py-2 bg-surface border border-surface-border rounded-lg text-sm text-slate-300
                              placeholder-slate-700 focus:outline-none focus:border-brand-600 transition-colors" />
                <p class="text-[11px] text-slate-600">Separate tags with commas, e.g. <em class="text-slate-500">design, frontend</em></p>

                <!-- Tag suggestions -->
                @if (Model.AllTags.Any())
                {
                    <div class="flex flex-wrap gap-1.5 pt-1">
                        @foreach (var tag in Model.AllTags.Take(12))
                        {
                            <button type="button" onclick="addTag('@tag')"
                                    class="px-2 py-0.5 rounded-full bg-surface-border hover:bg-surface-hover text-slate-400 hover:text-white text-xs transition-colors">
                                #@tag
                            </button>
                        }
                    </div>
                }
            </div>
        </aside>
    </div>
</form>

@section Scripts {
    <!-- Quill -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.snow.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.min.js"></script>

    <style>
        /* Dark-theme Quill overrides */
        .ql-toolbar.ql-snow {
            border: none !important;
            padding: 0 !important;
        }

        .ql-container.ql-snow {
            border: none !important;
        }

        .ql-editor {
            color: #cbd5e1;
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            line-height: 1.75;
            min-height: 340px;
        }

            .ql-editor.ql-blank::before {
                color: #334155;
                font-style: normal;
            }

        .ql-snow .ql-stroke {
            stroke: #64748b !important;
        }

        .ql-snow .ql-fill {
            fill: #64748b !important;
        }

        .ql-snow .ql-picker-label {
            color: #64748b !important;
        }

        .ql-snow .ql-toolbar button:hover .ql-stroke,
        .ql-snow .ql-toolbar button.ql-active .ql-stroke {
            stroke: #5a8eff !important;
        }

        .ql-snow .ql-toolbar button:hover .ql-fill,
        .ql-snow .ql-toolbar button.ql-active .ql-fill {
            fill: #5a8eff !important;
        }

        .ql-snow a {
            color: #5a8eff;
        }

        .ql-tooltip {
            background: #161b27 !important;
            border-color: #1f2637 !important;
            color: #cbd5e1 !important;
            box-shadow: none !important;
        }

            .ql-tooltip input[type=text] {
                background: #0f1117 !important;
                border-color: #1f2637 !important;
                color: #cbd5e1 !important;
            }
    </style>

    <script>
        const quill = new Quill('#quill-editor', {
            theme: 'snow',
            modules: { toolbar: '#toolbar' },
            placeholder: 'Write your note here…'
        });

        // Pre-fill if editing (Create = empty, Edit = content from hidden field)
        const existing = document.getElementById('ContentInput').value;
        if (existing) quill.root.innerHTML = existing;

        // Sync before submit
        document.getElementById('noteForm').addEventListener('submit', () => {
            document.getElementById('ContentInput').value = quill.root.innerHTML;
        });

        function addTag(name) {
            const input = document.getElementById('tagsInput');
            const existing = input.value.split(',').map(t => t.trim()).filter(Boolean);
            if (!existing.includes(name)) {
                input.value = [...existing, name].join(', ');
            }
        }

        lucide.createIcons();
    </script>
}
