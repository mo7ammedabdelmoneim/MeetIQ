@{
    ViewData["Title"] = "Home";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MeetIQ — Smart Meeting Intelligence</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50: '#eef5ff',
                            100: '#d9e8ff',
                            200: '#bcd4ff',
                            300: '#8eb6ff',
                            400: '#5a8eff',
                            500: '#3366ff',
                            600: '#1a44f5',
                            700: '#1332e1',
                            800: '#1629b6',
                            900: '#17278f',
                            950: '#111857',
                        },
                        surface: {
                            DEFAULT: '#0f1117',
                            card: '#161b27',
                            border: '#1f2637',
                            hover: '#1c2235',
                        }
                    },
                    fontFamily: {
                        sans: ['"DM Sans"', 'sans-serif'],
                        display: ['"Syne"', 'sans-serif'],
                        mono: ['"DM Mono"', 'monospace'],
                    },
                }
            }
        }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&family=Syne:wght@600;700;800&display=swap" rel="stylesheet" />
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>

    <style>
        ::-webkit-scrollbar {
            width: 4px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: #1f2637;
            border-radius: 99px;
        }

        /* Grid dot background */
        .dot-grid {
            background-image: radial-gradient(circle, #1f2637 1px, transparent 1px);
            background-size: 28px 28px;
        }

        /* Horizontal rule gradient */
        .hr-fade {
            border: none;
            height: 1px;
            background: linear-gradient(90deg, transparent, #1f2637 20%, #1f2637 80%, transparent);
        }

        /* Feature card border glow on hover */
        .feature-card:hover {
            border-color: rgba(51,102,255,0.35);
        }

        /* Glow orb behind hero text */
        .orb {
            position: absolute;
            width: 600px;
            height: 600px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(26,68,245,0.12) 0%, transparent 70%);
            pointer-events: none;
        }

        /* Step connector line */
        .step-line {
            position: absolute;
            top: 20px;
            left: calc(50% + 28px);
            width: calc(100% - 56px);
            height: 1px;
            background: linear-gradient(90deg, #1f2637, transparent);
        }

        /* Noise overlay */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 0;
        }
    </style>
</head>

<body class="bg-surface font-sans text-slate-300 antialiased overflow-x-hidden">

    <!-- ══════════════════════════════════════
         NAVBAR
    ══════════════════════════════════════ -->
    <header class="fixed top-0 inset-x-0 z-50 border-b border-surface-border bg-surface-card/80 backdrop-blur-md">
        <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">

            <!-- Logo -->
            <a href="/" class="flex items-center gap-2.5">
                <div class="w-7 h-7 rounded-lg bg-brand-600 flex items-center justify-center shrink-0">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.4"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 20h5v-2a4 4 0 0 0-4-4h-1" />
                        <path d="M9 20H4v-2a4 4 0 0 1 4-4h1" />
                        <circle cx="12" cy="8" r="4" />
                    </svg>
                </div>
                <span class="text-white font-semibold tracking-tight text-[16px] font-display">Meet<span class="text-brand-400">IQ</span></span>
            </a>

            <!-- Nav links -->
            <nav class="hidden md:flex items-center gap-1">
                <a href="#features" class="px-3 py-1.5 text-sm text-slate-400 hover:text-white rounded-lg hover:bg-surface-hover transition-colors">Features</a>
                <a href="#how-it-works" class="px-3 py-1.5 text-sm text-slate-400 hover:text-white rounded-lg hover:bg-surface-hover transition-colors">How it works</a>
                <a href="#roles" class="px-3 py-1.5 text-sm text-slate-400 hover:text-white rounded-lg hover:bg-surface-hover transition-colors">Roles</a>
            </nav>

            <!-- CTA -->
            <div class="flex items-center gap-2">
                <a href="/Auth/Login"
                   class="px-3 py-1.5 text-sm text-slate-400 hover:text-white border border-surface-border hover:border-brand-700 rounded-lg transition-colors">
                    Sign in
                </a>
                <a href="/Auth/Register"
                   class="px-3 py-1.5 text-sm font-semibold bg-brand-600 hover:bg-brand-500 text-white rounded-lg transition-colors">
                    Get started
                </a>
            </div>
        </div>
    </header>


    <!-- ══════════════════════════════════════
         HERO
    ══════════════════════════════════════ -->
    <section class="relative dot-grid pt-36 pb-28 overflow-hidden">

        <!-- Glow orbs -->
        <div class="orb -top-40 left-1/2 -translate-x-1/2"></div>
        <div class="orb top-20 -right-60 opacity-50"></div>

        <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">

            <!-- Eyebrow badge -->
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-surface-border bg-surface-card text-xs text-slate-400 font-mono mb-8">
                <span class="w-1.5 h-1.5 rounded-full bg-brand-500"></span>
                AI-Powered Meeting Intelligence
            </div>

            <!-- Headline -->
            <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-[1.08] tracking-tight mb-6">
                Every meeting,<br />
                <span class="text-brand-400">captured & understood.</span>
            </h1>

            <!-- Sub -->
            <p class="text-slate-400 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
                MeetIQ unifies scheduling, video conferencing, AI transcription, smart summaries,
                and task tracking — so nothing falls through the cracks.
            </p>

            <!-- Actions -->
            <div class="flex items-center justify-center gap-3 flex-wrap">
                <a href="/Auth/Register"
                   class="inline-flex items-center gap-2 px-5 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-xl transition-colors">
                    <i data-lucide="arrow-right" class="w-4 h-4"></i>
                    Start for free
                </a>
                <a href="#how-it-works"
                   class="inline-flex items-center gap-2 px-5 py-2.5 border border-surface-border hover:border-brand-700 text-slate-300 hover:text-white text-sm font-medium rounded-xl transition-colors">
                    <i data-lucide="play-circle" class="w-4 h-4"></i>
                    See how it works
                </a>
            </div>

            <!-- Social proof -->
            <p class="mt-8 text-xs text-slate-600 font-mono">No credit card required &nbsp;·&nbsp; Role-based access control &nbsp;·&nbsp; HTTPS / TLS encrypted</p>
        </div>

        <!-- Mock dashboard preview -->
        <div class="relative z-10 max-w-5xl mx-auto px-6 mt-16">
            <div class="rounded-2xl border border-surface-border bg-surface-card overflow-hidden shadow-2xl">

                <!-- Fake window chrome -->
                <div class="flex items-center gap-2 px-4 py-3 border-b border-surface-border bg-surface">
                    <span class="w-2.5 h-2.5 rounded-full bg-surface-border"></span>
                    <span class="w-2.5 h-2.5 rounded-full bg-surface-border"></span>
                    <span class="w-2.5 h-2.5 rounded-full bg-surface-border"></span>
                    <span class="ml-3 font-mono text-xs text-slate-600">meetiq.app / dashboard</span>
                </div>

                <!-- Fake dashboard layout -->
                <div class="flex h-64">
                    <!-- Fake sidebar strip -->
                    <div class="w-48 border-r border-surface-border bg-surface p-3 flex flex-col gap-1.5 shrink-0">
                        <div class="h-6 rounded bg-surface-border/50 w-3/4"></div>
                        <div class="h-5 rounded bg-brand-600/20 w-full flex items-center px-2">
                            <div class="w-2 h-2 rounded bg-brand-500 mr-2"></div>
                            <div class="h-2 rounded bg-brand-400/40 flex-1"></div>
                        </div>
                        <div class="h-5 rounded bg-surface-hover w-full"></div>
                        <div class="h-5 rounded bg-surface-hover w-full"></div>
                        <div class="h-5 rounded bg-surface-hover w-5/6"></div>
                        <div class="mt-3 h-px bg-surface-border w-full"></div>
                        <div class="h-4 rounded bg-surface-border/30 w-1/2 mt-1"></div>
                        <div class="h-5 rounded bg-surface-hover w-full"></div>
                        <div class="h-5 rounded bg-surface-hover w-full"></div>
                    </div>

                    <!-- Fake content area -->
                    <div class="flex-1 p-5 overflow-hidden">
                        <div class="grid grid-cols-3 gap-3 mb-4">
                            <div class="rounded-xl border border-surface-border bg-surface p-3">
                                <div class="h-3 w-16 rounded bg-slate-700 mb-2"></div>
                                <div class="h-6 w-10 rounded bg-brand-600/30 font-mono"></div>
                            </div>
                            <div class="rounded-xl border border-surface-border bg-surface p-3">
                                <div class="h-3 w-12 rounded bg-slate-700 mb-2"></div>
                                <div class="h-6 w-8 rounded bg-surface-border"></div>
                            </div>
                            <div class="rounded-xl border border-surface-border bg-surface p-3">
                                <div class="h-3 w-14 rounded bg-slate-700 mb-2"></div>
                                <div class="h-6 w-10 rounded bg-surface-border"></div>
                            </div>
                        </div>
                        <div class="rounded-xl border border-surface-border bg-surface p-3 space-y-2">
                            <div class="flex items-center gap-2">
                                <div class="w-2 h-2 rounded-full bg-brand-500 shrink-0"></div>
                                <div class="h-3 rounded bg-slate-700 flex-1"></div>
                                <div class="h-3 w-14 rounded bg-surface-border shrink-0"></div>
                            </div>
                            <div class="flex items-center gap-2">
                                <div class="w-2 h-2 rounded-full bg-slate-600 shrink-0"></div>
                                <div class="h-3 rounded bg-surface-border w-2/3"></div>
                                <div class="h-3 w-10 rounded bg-surface-border shrink-0"></div>
                            </div>
                            <div class="flex items-center gap-2">
                                <div class="w-2 h-2 rounded-full bg-slate-600 shrink-0"></div>
                                <div class="h-3 rounded bg-surface-border w-3/4"></div>
                                <div class="h-3 w-12 rounded bg-surface-border shrink-0"></div>
                            </div>
                            <div class="flex items-center gap-2">
                                <div class="w-2 h-2 rounded-full bg-brand-800 shrink-0"></div>
                                <div class="h-3 rounded bg-surface-border w-1/2"></div>
                                <div class="h-3 w-16 rounded bg-surface-border shrink-0"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <hr class="hr-fade" />


    <!-- ══════════════════════════════════════
         STATS STRIP
    ══════════════════════════════════════ -->
    <section class="py-14">
        <div class="max-w-4xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
            <div>
                <p class="font-display text-3xl font-bold text-white">100%</p>
                <p class="text-xs text-slate-500 mt-1 font-mono">Meetings transcribed</p>
            </div>
            <div>
                <p class="font-display text-3xl font-bold text-white">0</p>
                <p class="text-xs text-slate-500 mt-1 font-mono">Manual note-taking</p>
            </div>
            <div>
                <p class="font-display text-3xl font-bold text-white">AI</p>
                <p class="text-xs text-slate-500 mt-1 font-mono">Task extraction</p>
            </div>
            <div>
                <p class="font-display text-3xl font-bold text-white">E2E</p>
                <p class="text-xs text-slate-500 mt-1 font-mono">TLS encrypted</p>
            </div>
        </div>
    </section>

    <hr class="hr-fade" />


    <!-- ══════════════════════════════════════
         FEATURES
    ══════════════════════════════════════ -->
    <section id="features" class="py-24">
        <div class="max-w-6xl mx-auto px-6">

            <!-- Section header -->
            <div class="mb-14">
                <p class="text-xs font-mono text-brand-400 uppercase tracking-widest mb-3">Features</p>
                <h2 class="font-display text-4xl md:text-5xl font-bold text-white leading-tight max-w-xl">
                    Everything your team needs, unified.
                </h2>
            </div>

            <!-- Feature grid -->
            <div class="grid md:grid-cols-3 gap-4">

                <!-- Big feature card (spans 2 cols) -->
                <div class="feature-card md:col-span-2 rounded-2xl border border-surface-border bg-surface-card p-8 transition-colors">
                    <div class="w-10 h-10 rounded-xl bg-brand-600/15 border border-brand-600/20 flex items-center justify-center mb-5">
                        <i data-lucide="mic-2" class="w-5 h-5 text-brand-400"></i>
                    </div>
                    <h3 class="text-white font-semibold text-lg mb-2">AI Transcription & Summarization</h3>
                    <p class="text-slate-500 text-sm leading-relaxed">
                        Whisper API converts every meeting recording to accurate, timestamped text automatically.
                        The AI then distills it into a concise summary, a list of key decisions, and action items
                        — all editable before finalizing.
                    </p>
                    <div class="mt-6 rounded-xl bg-surface border border-surface-border p-4 font-mono text-xs space-y-2">
                        <div class="flex gap-2">
                            <span class="text-brand-400 shrink-0">summary</span>
                            <span class="text-slate-500">→ Q3 roadmap priorities confirmed: auth redesign ships first.</span>
                        </div>
                        <div class="flex gap-2">
                            <span class="text-brand-400 shrink-0">decision</span>
                            <span class="text-slate-500">→ Budget approved for new CI pipeline tooling.</span>
                        </div>
                        <div class="flex gap-2">
                            <span class="text-green-500 shrink-0">action</span>
                            <span class="text-slate-500">→ Ahmed — send vendor comparison doc by Friday.</span>
                        </div>
                    </div>
                </div>

                <!-- Task Management -->
                <div class="feature-card rounded-2xl border border-surface-border bg-surface-card p-8 transition-colors">
                    <div class="w-10 h-10 rounded-xl bg-brand-600/15 border border-brand-600/20 flex items-center justify-center mb-5">
                        <i data-lucide="check-square" class="w-5 h-5 text-brand-400"></i>
                    </div>
                    <h3 class="text-white font-semibold text-lg mb-2">Task Management</h3>
                    <p class="text-slate-500 text-sm leading-relaxed">
                        Action items extracted by AI instantly become tasks. Assign, prioritize, and track them
                        through a Kanban board — all linked back to their source meeting.
                    </p>
                    <!-- Fake kanban -->
                    <div class="mt-6 grid grid-cols-3 gap-2 text-[10px] font-mono">
                        <div class="space-y-1.5">
                            <p class="text-slate-600 uppercase tracking-wider">To Do</p>
                            <div class="rounded bg-surface border border-surface-border p-2 text-slate-500">Write docs</div>
                            <div class="rounded bg-surface border border-surface-border p-2 text-slate-500">Review PR</div>
                        </div>
                        <div class="space-y-1.5">
                            <p class="text-slate-600 uppercase tracking-wider">Active</p>
                            <div class="rounded bg-brand-600/10 border border-brand-600/20 p-2 text-brand-400">Auth flow</div>
                        </div>
                        <div class="space-y-1.5">
                            <p class="text-slate-600 uppercase tracking-wider">Done</p>
                            <div class="rounded bg-surface border border-surface-border p-2 text-slate-600 line-through">Schema</div>
                        </div>
                    </div>
                </div>

                <!-- Calendar -->
                <div class="feature-card rounded-2xl border border-surface-border bg-surface-card p-8 transition-colors">
                    <div class="w-10 h-10 rounded-xl bg-brand-600/15 border border-brand-600/20 flex items-center justify-center mb-5">
                        <i data-lucide="calendar" class="w-5 h-5 text-brand-400"></i>
                    </div>
                    <h3 class="text-white font-semibold text-lg mb-2">Calendar & Scheduling</h3>
                    <p class="text-slate-500 text-sm leading-relaxed">
                        Daily, weekly, and monthly views. Every event is automatically linked to its recordings,
                        notes, and generated tasks.
                    </p>
                </div>

                <!-- Meetings -->
                <div class="feature-card rounded-2xl border border-surface-border bg-surface-card p-8 transition-colors">
                    <div class="w-10 h-10 rounded-xl bg-brand-600/15 border border-brand-600/20 flex items-center justify-center mb-5">
                        <i data-lucide="video" class="w-5 h-5 text-brand-400"></i>
                    </div>
                    <h3 class="text-white font-semibold text-lg mb-2">Integrated Video Meetings</h3>
                    <p class="text-slate-500 text-sm leading-relaxed">
                        One-click meeting creation with automatic Jitsi Meet room generation, participant lobby,
                        host-controlled admission, and screen sharing.
                    </p>
                </div>

                <!-- Notes -->
                <div class="feature-card rounded-2xl border border-surface-border bg-surface-card p-8 transition-colors">
                    <div class="w-10 h-10 rounded-xl bg-brand-600/15 border border-brand-600/20 flex items-center justify-center mb-5">
                        <i data-lucide="notebook-pen" class="w-5 h-5 text-brand-400"></i>
                    </div>
                    <h3 class="text-white font-semibold text-lg mb-2">Smart Notes</h3>
                    <p class="text-slate-500 text-sm leading-relaxed">
                        Rich-text notes with tagging, full-text search, and direct links to meetings or calendar
                        events. AI-generated notes are auto-populated after each session.
                    </p>
                </div>

            </div>
        </div>
    </section>

    <hr class="hr-fade" />


    <!-- ══════════════════════════════════════
         HOW IT WORKS
    ══════════════════════════════════════ -->
    <section id="how-it-works" class="py-24">
        <div class="max-w-6xl mx-auto px-6">

            <div class="mb-14">
                <p class="text-xs font-mono text-brand-400 uppercase tracking-widest mb-3">How it works</p>
                <h2 class="font-display text-4xl md:text-5xl font-bold text-white leading-tight max-w-lg">
                    From meeting to action in minutes.
                </h2>
            </div>

            <div class="grid md:grid-cols-4 gap-6">

                <!-- Step 1 -->
                <div class="relative">
                    <div class="step-line hidden md:block"></div>
                    <div class="w-10 h-10 rounded-xl bg-brand-600 flex items-center justify-center mb-5 text-white font-display font-bold text-sm shrink-0">
                        01
                    </div>
                    <h3 class="text-white font-semibold mb-2">Schedule</h3>
                    <p class="text-slate-500 text-sm leading-relaxed">Create a calendar event and invite your team. A Jitsi room is auto-generated.</p>
                </div>

                <!-- Step 2 -->
                <div class="relative">
                    <div class="step-line hidden md:block"></div>
                    <div class="w-10 h-10 rounded-xl bg-surface-card border border-surface-border flex items-center justify-center mb-5 text-slate-400 font-display font-bold text-sm shrink-0">
                        02
                    </div>
                    <h3 class="text-white font-semibold mb-2">Meet</h3>
                    <p class="text-slate-500 text-sm leading-relaxed">Join directly from MeetIQ. Host controls the lobby, screen sharing included.</p>
                </div>

                <!-- Step 3 -->
                <div class="relative">
                    <div class="step-line hidden md:block"></div>
                    <div class="w-10 h-10 rounded-xl bg-surface-card border border-surface-border flex items-center justify-center mb-5 text-slate-400 font-display font-bold text-sm shrink-0">
                        03
                    </div>
                    <h3 class="text-white font-semibold mb-2">Transcribe</h3>
                    <p class="text-slate-500 text-sm leading-relaxed">When the meeting ends, Whisper API generates a full timestamped transcript automatically.</p>
                </div>

                <!-- Step 4 -->
                <div>
                    <div class="w-10 h-10 rounded-xl bg-surface-card border border-surface-border flex items-center justify-center mb-5 text-slate-400 font-display font-bold text-sm shrink-0">
                        04
                    </div>
                    <h3 class="text-white font-semibold mb-2">Act</h3>
                    <p class="text-slate-500 text-sm leading-relaxed">AI produces a summary, key decisions, and tasks — already assigned and prioritized for your team.</p>
                </div>

            </div>
        </div>
    </section>

    <hr class="hr-fade" />


    <!-- ══════════════════════════════════════
         ROLES
    ══════════════════════════════════════ -->
    <section id="roles" class="py-24">
        <div class="max-w-6xl mx-auto px-6">

            <div class="mb-14">
                <p class="text-xs font-mono text-brand-400 uppercase tracking-widest mb-3">Access Control</p>
                <h2 class="font-display text-4xl md:text-5xl font-bold text-white leading-tight max-w-lg">
                    The right access for every role.
                </h2>
            </div>

            <div class="grid md:grid-cols-2 gap-6">

                <!-- Member -->
                <div class="rounded-2xl border border-surface-border bg-surface-card p-8">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-9 h-9 rounded-lg bg-surface-border flex items-center justify-center">
                            <i data-lucide="user" class="w-4 h-4 text-slate-400"></i>
                        </div>
                        <div>
                            <p class="text-white font-semibold">Member</p>
                            <p class="text-xs text-slate-500 font-mono">Default role</p>
                        </div>
                    </div>
                    <ul class="space-y-3">
                        <li class="flex items-center gap-3 text-sm text-slate-400">
                            <i data-lucide="check" class="w-4 h-4 text-brand-500 shrink-0"></i>
                            Create & join meetings
                        </li>
                        <li class="flex items-center gap-3 text-sm text-slate-400">
                            <i data-lucide="check" class="w-4 h-4 text-brand-500 shrink-0"></i>
                            View transcripts & summaries
                        </li>
                        <li class="flex items-center gap-3 text-sm text-slate-400">
                            <i data-lucide="check" class="w-4 h-4 text-brand-500 shrink-0"></i>
                            Manage personal notes & tasks
                        </li>
                        <li class="flex items-center gap-3 text-sm text-slate-400">
                            <i data-lucide="check" class="w-4 h-4 text-brand-500 shrink-0"></i>
                            Calendar scheduling
                        </li>
                        <li class="flex items-center gap-3 text-sm text-slate-400">
                            <i data-lucide="x" class="w-4 h-4 text-slate-700 shrink-0"></i>
                            <span class="text-slate-600">Admin dashboard</span>
                        </li>
                        <li class="flex items-center gap-3 text-sm text-slate-400">
                            <i data-lucide="x" class="w-4 h-4 text-slate-700 shrink-0"></i>
                            <span class="text-slate-600">User management</span>
                        </li>
                    </ul>
                </div>

                <!-- Administrator -->
