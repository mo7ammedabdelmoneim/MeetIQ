@model MeetingDetailsDto

@{
    ViewData["Title"] = Model.Title;
    var isHost = (bool)ViewBag.IsHost;
    var currentUid = ViewBag.CurrentUid as string;

    var statusConfig = new Dictionary<MeetingStatus, (string Label, string Color)>
    {
        { MeetingStatus.Scheduled,  ("Scheduled",  "text-brand-400 bg-brand-400/10 border-brand-400/20")       },
        { MeetingStatus.InProgress, ("Live",        "text-emerald-400 bg-emerald-400/10 border-emerald-400/20") },
        { MeetingStatus.Ended,      ("Ended",       "text-slate-400 bg-slate-400/10 border-slate-400/20")       },
        { MeetingStatus.Cancelled,  ("Cancelled",   "text-red-400 bg-red-400/10 border-red-400/20")             },
    };
    var (statusLabel, statusColor) = statusConfig[Model.Status];

    var transcriptDone    = Model.TranscriptStatus == TranscriptStatus.Completed;
    var transcriptRunning = Model.TranscriptStatus == TranscriptStatus.Transcribing;
    var transcriptFailed  = Model.TranscriptStatus == TranscriptStatus.Failed;
    var transcriptPending = Model.TranscriptStatus == TranscriptStatus.PendingTranscription;
}

<!-- ══════════════════════════════════════════
     TRANSCRIBE OVERLAY
══════════════════════════════════════════ -->
<div id="transcribe-overlay"
     class="hidden fixed inset-0 z-50 bg-surface/90 backdrop-blur-sm
            flex flex-col items-center justify-center gap-4">
    <div class="bg-surface-card border border-surface-border rounded-2xl p-8
                flex flex-col items-center gap-5 w-80 shadow-2xl">

        <!-- Animated mic icon -->
        <div class="relative flex items-center justify-center w-16 h-16">
            <span class="absolute inline-flex h-full w-full rounded-full bg-brand-500/20 animate-ping"></span>
            <div class="relative w-14 h-14 rounded-full bg-brand-600/20 border border-brand-600/40
                        flex items-center justify-center">
                <i data-lucide="mic-2" class="w-6 h-6 text-brand-400"></i>
            </div>
        </div>

        <div class="text-center">
            <p class="text-white font-semibold text-sm">Transcribing Audio…</p>
            <p class="text-slate-500 text-xs mt-1.5 leading-relaxed">
                Whisper is converting your recording to text.<br/>This may take a minute.
            </p>
        </div>

        <!-- Progress bar (indeterminate) -->
        <div class="w-full bg-surface-border rounded-full h-1 overflow-hidden">
            <div class="h-1 bg-brand-500 rounded-full animate-[progress_2s_ease-in-out_infinite]"
                 style="width: 40%"></div>
        </div>

        <p class="text-slate-600 text-[11px]">Please don't close this tab</p>
    </div>
</div>

<!-- ══════════════════════════════════════════
     ANALYZE OVERLAY
══════════════════════════════════════════ -->
<div id="analyze-overlay"
     class="hidden fixed inset-0 z-50 bg-surface/90 backdrop-blur-sm
            flex flex-col items-center justify-center gap-4">
    <div class="bg-surface-card border border-surface-border rounded-2xl p-8
                flex flex-col items-center gap-5 w-80 shadow-2xl">

        <!-- Animated sparkles icon -->
        <div class="relative flex items-center justify-center w-16 h-16">
            <span class="absolute inline-flex h-full w-full rounded-full bg-violet-500/20 animate-ping"></span>
            <div class="relative w-14 h-14 rounded-full bg-violet-600/20 border border-violet-600/40
                        flex items-center justify-center">
                <i data-lucide="sparkles" class="w-6 h-6 text-violet-400"></i>
            </div>
        </div>

        <div class="text-center">
            <p class="text-white font-semibold text-sm">Analyzing with AI…</p>
            <p class="text-slate-500 text-xs mt-1.5 leading-relaxed">
                generating your summary,<br/>tasks, and notes.
            </p>
        </div>

        <!-- Steps indicator -->
        <div class="w-full space-y-2">
            <div class="flex items-center gap-2 text-xs text-slate-400">
                <div class="w-4 h-4 rounded-full bg-violet-500/20 border border-violet-500/30
                            flex items-center justify-center shrink-0">
                    <i data-lucide="check" class="w-2.5 h-2.5 text-violet-400"></i>
                </div>
                Reading transcript
            </div>
            <div id="step-summary" class="flex items-center gap-2 text-xs text-slate-600">
                <div class="w-4 h-4 rounded-full bg-surface-border flex items-center justify-center shrink-0">
                    <svg class="animate-spin w-2.5 h-2.5 text-violet-400" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
                    </svg>
                </div>
                Generating summary & insights
            </div>
            <div id="step-tasks" class="flex items-center gap-2 text-xs text-slate-600">
                <div class="w-4 h-4 rounded-full bg-surface-border flex items-center justify-center shrink-0">
                    <div class="w-1.5 h-1.5 rounded-full bg-slate-600"></div>
                </div>
                Extracting tasks & notes
            </div>
        </div>

        <!-- Progress bar -->
        <div class="w-full bg-surface-border rounded-full h-1 overflow-hidden">
            <div class="h-1 bg-violet-500 rounded-full animate-[progress_2.5s_ease-in-out_infinite]"
                 style="width: 35%"></div>
        </div>

        <p class="text-slate-600 text-[11px]">Please don't close this tab</p>
    </div>
</div>

<div class="max-w-3xl mx-auto space-y-6">

    <!-- Back -->
    <a href="@Url.Action("Index")"
       class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-slate-300 transition-colors">
        <i data-lucide="arrow-left" class="w-4 h-4"></i>
        Back to Meetings
    </a>

    @if (TempData["Success"] != null)
    {
        <div class="flex items-center gap-3 px-4 py-3 rounded-xl
                    bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm">
            <i data-lucide="check-circle" class="w-4 h-4 shrink-0"></i>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="flex items-center gap-3 px-4 py-3 rounded-xl
                    bg-red-500/10 border border-red-500/20 text-red-400 text-sm">
            <i data-lucide="alert-circle" class="w-4 h-4 shrink-0"></i>
            @TempData["Error"]
        </div>
    }

    <!-- ── HEADER CARD ── -->
    <div class="bg-surface-card border border-surface-border rounded-2xl p-6">
        <div class="flex items-start justify-between gap-4">
            <div class="min-w-0">
                <div class="flex items-center gap-3 flex-wrap mb-3">
                    <h2 class="text-xl font-semibold text-white truncate">@Model.Title</h2>
                    <span class="text-xs font-semibold px-2.5 py-1 rounded-full border @statusColor">
                        @if (Model.Status == MeetingStatus.InProgress)
                        {
                            <span class="inline-flex items-center gap-1.5">
                                <span class="relative flex h-1.5 w-1.5">
                                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                                    <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-500"></span>
                                </span>
                                @statusLabel
                            </span>
                        }
                        else { @statusLabel }
                    </span>
                    @if (isHost)
                    {
                        <span class="text-xs font-semibold px-2.5 py-1 rounded-full border
                                     text-violet-400 bg-violet-400/10 border-violet-400/20">Host</span>
                    }
                </div>

                <div class="space-y-2 text-sm text-slate-500">
                    <div class="flex items-center gap-2">
                        <i data-lucide="calendar" class="w-4 h-4 shrink-0"></i>
                        <span>@Model.ScheduledAt.ToLocalTime().ToString("dddd, MMMM dd yyyy — HH:mm")</span>
                    </div>
                    @if (Model.Duration.HasValue)
                    {
                        <div class="flex items-center gap-2">
                            <i data-lucide="clock" class="w-4 h-4 shrink-0"></i>
                            <span>Duration: @((int)Model.Duration.Value.TotalMinutes) minutes</span>
                        </div>
                    }
                    <div class="flex items-center gap-2">
                        <i data-lucide="users" class="w-4 h-4 shrink-0"></i>
                        <span>@Model.ParticipantsCount participant(s)</span>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex flex-col gap-2 shrink-0">
                @if (Model.Status == MeetingStatus.Scheduled && isHost)
                {
                    <form asp-action="Start" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="meetingId" value="@Model.Id" />
                        <button type="submit"
                                class="w-full flex items-center gap-2 px-4 py-2.5 bg-emerald-600 hover:bg-emerald-500
                                       text-white text-sm font-semibold rounded-xl transition-colors">
                            <i data-lucide="play" class="w-4 h-4"></i>
                            Start Meeting
                        </button>
                    </form>
                }
                @if (Model.Status == MeetingStatus.InProgress)
                {
                    <a href="@Url.Action("Room", new { id = Model.Id })"
                       class="flex items-center gap-2 px-4 py-2.5 bg-brand-600 hover:bg-brand-500
                              text-white text-sm font-semibold rounded-xl transition-colors shadow-glow justify-center">
                        <i data-lucide="video" class="w-4 h-4"></i>
                        Join Room
                    </a>
                    @if (isHost)
                    {
                        <form asp-action="End" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="meetingId" value="@Model.Id" />
                            <button type="submit"
                                    class="w-full flex items-center gap-2 px-4 py-2.5 rounded-xl border
                                           border-red-500/30 text-red-400 hover:bg-red-500/10 text-sm font-medium transition-colors">
                                <i data-lucide="phone-off" class="w-4 h-4"></i>
                                End Meeting
                            </button>
                        </form>
                    }
                }
                @if (Model.Status == MeetingStatus.Scheduled && isHost)
                {
                    <form asp-action="Cancel" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="meetingId" value="@Model.Id" />
                        <button type="submit"
                                class="w-full flex items-center gap-2 px-4 py-2.5 rounded-xl border
                                       border-surface-border text-slate-500 hover:text-red-400
                                       hover:border-red-500/30 text-sm font-medium transition-colors">
                            <i data-lucide="x-circle" class="w-4 h-4"></i>
                            Cancel
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>

    <!-- ── INFO ROW: Recording · Transcript · Summary ── -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

        <!-- Recording -->
        <div class="bg-surface-card border border-surface-border rounded-xl p-4">
            <p class="text-xs text-slate-600 uppercase tracking-wider mb-3">Recording</p>
            @if (Model.HasRecording)
            {
                <div class="flex items-center gap-2 text-sm text-emerald-400 mb-3">
                    <i data-lucide="circle-check" class="w-4 h-4 shrink-0"></i>
                    Audio saved
                </div>
                @if (isHost && !transcriptDone && !transcriptRunning)
                {
                    <form id="transcribe-form" asp-action="Transcribe" method="post"
                          onsubmit="showOverlay('transcribe-overlay')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="meetingId" value="@Model.Id" />
                        <button type="submit"
                                class="w-full flex items-center justify-center gap-1.5 px-3 py-1.5 rounded-lg
                                       bg-brand-600/20 hover:bg-brand-600/30 border border-brand-600/30
                                       text-brand-400 text-xs font-semibold transition-colors">
                            <i data-lucide="wand-2" class="w-3.5 h-3.5"></i>
                            @(transcriptFailed ? "Retry Transcription" : "Transcribe")
                        </button>
                    </form>
                }
                @if (transcriptRunning)
                {
                    <div class="flex items-center gap-2 text-xs text-amber-400 mt-1">
                        <svg class="animate-spin w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
                        </svg>
                        Transcribing…
                    </div>
                }
            }
            else if (Model.Status == MeetingStatus.Ended)
            {
                <p class="text-sm text-slate-600 flex items-center gap-2">
                    <i data-lucide="mic-off" class="w-4 h-4"></i>
                    No recording
                </p>
            }
            else
            {
                <p class="text-sm text-slate-600 flex items-center gap-2">
                    <i data-lucide="clock" class="w-4 h-4"></i>
                    Not started
                </p>
            }
        </div>

        <!-- Transcript -->
        <div class="bg-surface-card border border-surface-border rounded-xl p-4">
            <p class="text-xs text-slate-600 uppercase tracking-wider mb-3">Transcript</p>
            @if (transcriptDone && Model.TranscriptId.HasValue)
            {
                <a href="@Url.Action("Details", "Transcripts", new { id = Model.TranscriptId })"
                   class="flex items-center gap-2 text-sm text-emerald-400 hover:text-emerald-300 transition-colors mb-3">
                    <i data-lucide="mic-2" class="w-4 h-4"></i>
                    View Transcript
                </a>
                @if (!Model.HasSummary && isHost)
                {
                    <button type="button"
                            onclick="startAnalysis()"
                            class="w-full flex items-center justify-center gap-1.5 px-3 py-1.5 rounded-lg
                                       bg-violet-600/20 hover:bg-violet-600/30 border border-violet-600/30
                                       text-violet-400 text-xs font-semibold transition-colors">
                        <i data-lucide="sparkles" class="w-3.5 h-3.5"></i>
                        Analyze Meeting
                    </button>

                }
            }
            else if (transcriptRunning)
            {
                <div class="flex items-center gap-2 text-xs text-amber-400">
                    <svg class="animate-spin w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
                    </svg>
                    Whisper is working…
                </div>
            }
            else if (transcriptFailed)
            {
                <p class="text-sm text-red-400 flex items-center gap-2">
                    <i data-lucide="alert-circle" class="w-4 h-4"></i>
                    Transcription failed
                </p>
            }
            else if (transcriptPending)
            {
                <p class="text-sm text-slate-500 flex items-center gap-2">
                    <i data-lucide="hourglass" class="w-4 h-4"></i>
                    Pending
                </p>
            }
            else
            {
                <p class="text-sm text-slate-600 flex items-center gap-2">
                    <i data-lucide="mic-off" class="w-4 h-4"></i>
                    Not available
                </p>
            }
        </div>

        <!-- Summary -->
        <div class="bg-surface-card border border-surface-border rounded-xl p-4">
            <p class="text-xs text-slate-600 uppercase tracking-wider mb-3">AI Summary</p>
            @if (Model.HasSummary && Model.SummaryId.HasValue)
            {
                <a href="@Url.Action("Details", "Summaries", new { id = Model.SummaryId })"
                   class="flex items-center gap-2 text-sm text-violet-400 hover:text-violet-300 transition-colors">
                    <i data-lucide="sparkles" class="w-4 h-4"></i>
                    View Summary
                </a>
            }
            else if (transcriptDone)
            {
                <p class="text-sm text-slate-500 flex items-center gap-2">
                    <i data-lucide="clock" class="w-4 h-4"></i>
                    Not generated yet
                </p>
            }
            else
            {
                <p class="text-sm text-slate-600 flex items-center gap-2">
                    <i data-lucide="sparkles" class="w-4 h-4"></i>
                    Needs transcript first
                </p>
            }
        </div>
    </div>

    <!-- ── HOST INFO ── -->
    <div class="bg-surface-card border border-surface-border rounded-xl p-4">
        <p class="text-xs text-slate-600 uppercase tracking-wider mb-3">Host</p>
        <div class="flex items-center gap-3">
            @if (!string.IsNullOrEmpty(Model.HostAvatarUrl))
            {
                <img src="@Model.HostAvatarUrl" class="w-8 h-8 rounded-full object-cover shrink-0" />
            }
            else
            {
                <div class="w-8 h-8 rounded-full bg-brand-900 border border-brand-700
                            flex items-center justify-center text-brand-300 text-xs font-semibold shrink-0">
                    @Model.HostName.Substring(0, 1).ToUpper()
                </div>
            }
            <div class="min-w-0">
                <p class="text-sm font-medium text-white truncate">@Model.HostName</p>
                <p class="text-xs text-slate-500 truncate">@Model.HostEmail</p>
            </div>
        </div>
    </div>

    <!-- ── PARTICIPANTS ── -->
    @if (Model.Participants.Any())
    {
        <div class="bg-surface-card border border-surface-border rounded-2xl overflow-hidden">
            <div class="px-5 py-4 border-b border-surface-border">
                <h3 class="text-sm font-semibold text-white flex items-center gap-2">
                    <i data-lucide="users" class="w-4 h-4 text-slate-500"></i>
                    Participants (@Model.Participants.Count)
                </h3>
            </div>
            <div class="divide-y divide-surface-border">
                @foreach (var p in Model.Participants)
                {
                    var duration = p.LeftAt.HasValue
                        ? $"{(int)(p.LeftAt.Value - p.JoinedAt).TotalMinutes}m"
                        : "Still in";

                    <div class="flex items-center justify-between px-5 py-3.5">
                        <div class="flex items-center gap-3">
                            @if (!string.IsNullOrEmpty(p.AvatarUrl))
                            {
                                <img src="@p.AvatarUrl" class="w-7 h-7 rounded-full object-cover shrink-0" />
                            }
                            else
                            {
                                <div class="w-7 h-7 rounded-full bg-surface border border-surface-border
                                            flex items-center justify-center text-slate-400 text-xs font-semibold shrink-0">
                                    @p.FullName.Substring(0, 1).ToUpper()
                                </div>
                            }
                            <div>
                                <p class="text-sm text-white font-medium">@p.FullName</p>
                                <p class="text-xs text-slate-500">@p.Email</p>
                            </div>
                        </div>
                        <div class="text-right">
                            <p class="text-xs text-slate-500">@p.JoinedAt.ToLocalTime().ToString("HH:mm")</p>
                            <p class="text-xs @(p.LeftAt.HasValue ? "text-slate-600" : "text-emerald-500")">@duration</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @if (isHost)
    {
        @await Html.PartialAsync("_InvitePanel", Model)
    }


</div>
    @await Html.PartialAsync("_AnalysisReviewModal")

@section Scripts {
    <style>
        @@keyframes progress {
            0%   { width: 5%;  margin-left: 0; }
            50%  { width: 50%; margin-left: 25%; }
            100% { width: 5%;  margin-left: 95%; }
        }
    </style>

    <script>
        const CSRF_TOKEN = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        const MEETING_ID = '@Model.Id';

        // ── Overlay helper ─────────────────────────────────────────
        function showOverlay(id) {
            document.getElementById(id)?.classList.remove('hidden');
        }

        // ── Animate analyze steps ──────────────────────────────────
        function startAnalyzeSteps() {
            // Step 2 activates after 3s
            setTimeout(() => {
                const s = document.getElementById('step-summary');
                if (s) s.classList.replace('text-slate-600', 'text-violet-400');
            }, 3000);

            // Step 3 activates after 6s
            setTimeout(() => {
                const s = document.getElementById('step-tasks');
                if (s) s.classList.replace('text-slate-600', 'text-violet-400');
            }, 6000);
        }

        // ── Toggle invite box ──────────────────────────────────────
        function toggleInviteBox() {
            const box = document.getElementById('invite-box');
            const btn = document.getElementById('invite-toggle-btn');
            if (!box) return;

            const isHidden = box.classList.contains('hidden');
            box.classList.toggle('hidden', !isHidden);

            if (isHidden) {
                btn.innerHTML = '<i data-lucide="x" class="w-3.5 h-3.5"></i> Cancel';
                btn.classList.remove('bg-brand-600', 'hover:bg-brand-500', 'shadow-glow');
                btn.classList.add('bg-surface-hover', 'border', 'border-surface-border', 'text-slate-400');
                document.getElementById('invite-search')?.focus();
            } else {
                btn.innerHTML = '<i data-lucide="user-plus" class="w-3.5 h-3.5"></i> Invite Someone';
                btn.classList.add('bg-brand-600', 'hover:bg-brand-500', 'shadow-glow');
                btn.classList.remove('bg-surface-hover', 'border', 'border-surface-border', 'text-slate-400');
                const searchInput = document.getElementById('invite-search');
                const resultsBox  = document.getElementById('invite-results');
                if (searchInput) searchInput.value = '';
                if (resultsBox)  { resultsBox.classList.add('hidden'); resultsBox.innerHTML = ''; }
            }
            lucide.createIcons();
        }

        // ── Search wiring ──────────────────────────────────────────
        const searchInput = document.getElementById('invite-search');
        const resultsBox  = document.getElementById('invite-results');
        const loadingEl   = document.getElementById('invite-loading');

        if (searchInput) {
            let debounce = null;
            searchInput.addEventListener('input', () => {
                clearTimeout(debounce);
                const term = searchInput.value.trim();
                if (term.length < 2) {
                    resultsBox.classList.add('hidden');
                    loadingEl?.classList.add('hidden');
                    resultsBox.innerHTML = '';
                    return;
                }
                loadingEl?.classList.remove('hidden');
                resultsBox.classList.add('hidden');
                debounce = setTimeout(() => fetchUsers(term), 300);
            });

            document.addEventListener('click', e => {
                if (!searchInput.contains(e.target) && !resultsBox?.contains(e.target))
                    resultsBox?.classList.add('hidden');
            });
        }

        // ── Fetch users ────────────────────────────────────────────
        async function fetchUsers(term) {
            try {
                const res  = await fetch(`/Meetings/SearchUsers?term=${encodeURIComponent(term)}&meetingId=${MEETING_ID}`);
                const data = await res.json();
                loadingEl?.classList.add('hidden');

                if (!data.length) {
                    resultsBox.innerHTML = `
                        <div class="flex items-center gap-2 px-4 py-3 text-xs text-slate-500">
                            <i data-lucide="search-x" class="w-3.5 h-3.5 shrink-0"></i>
                            No users found matching "<strong class="text-slate-400">${escapeHtml(term)}</strong>"
                        </div>`;
                    resultsBox.classList.remove('hidden');
                    lucide.createIcons();
                    return;
                }

                resultsBox.innerHTML = data.map(u => `
                    <div class="flex items-center justify-between px-4 py-3
                                hover:bg-surface-hover transition-colors
                                border-b border-surface-border last:border-0">
                        <div class="flex items-center gap-3 min-w-0">
                            ${u.avatarUrl
                                ? `<img src="${escapeHtml(u.avatarUrl)}" class="w-8 h-8 rounded-full object-cover shrink-0" />`
                                : `<div class="w-8 h-8 rounded-full bg-surface-card border border-surface-border
                                              flex items-center justify-center text-slate-400 text-xs font-semibold shrink-0">
                                     ${escapeHtml(u.fullName.charAt(0).toUpperCase())}
                                   </div>`}
                            <div class="min-w-0">
                                <p class="text-sm text-white font-medium truncate">${escapeHtml(u.fullName)}</p>
                                <p class="text-xs text-slate-500 truncate">${escapeHtml(u.email)}</p>
                            </div>
                        </div>
                        <button data-user-id="${escapeHtml(u.id)}"
                                class="invite-btn flex items-center gap-1.5 px-3 py-1.5 rounded-lg
                                       bg-brand-600 hover:bg-brand-500 text-white text-xs font-semibold transition-colors shrink-0">
                            <i data-lucide="send" class="w-3.5 h-3.5"></i>
                            Send Invite
                        </button>
                    </div>`).join('');

                resultsBox.classList.remove('hidden');
                lucide.createIcons();
                resultsBox.querySelectorAll('.invite-btn').forEach(btn => {
                    btn.addEventListener('click', () => inviteUser(btn.dataset.userId, btn));
                });
            } catch (err) {
                loadingEl?.classList.add('hidden');
                console.error('Search failed:', err);
            }
        }

        // ── Invite user ────────────────────────────────────────────
        async function inviteUser(userId, btn) {
            btn.disabled = true;
            btn.innerHTML = `<svg class="animate-spin w-3.5 h-3.5" viewBox="0 0 24 24" fill="none">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
            </svg> Sending...`;

            try {
                const formData = new FormData();
                formData.append('meetingId', MEETING_ID);
                formData.append('invitedUserId', userId);
                formData.append('__RequestVerificationToken', CSRF_TOKEN);

                const res = await fetch('/Meetings/Invite', { method: 'POST', body: formData });
                if (res.ok || res.redirected) {
                    window.location.reload();
                } else {
                    throw new Error(`HTTP ${res.status}`);
                }
            } catch (err) {
                console.error('Invite failed:', err);
                btn.disabled = false;
                btn.innerHTML = '<i data-lucide="send" class="w-3.5 h-3.5"></i> Send Invite';
                lucide.createIcons();
                showToast('Failed to send invitation. Please try again.', 'error');
            }
        }

        // ── Toast ──────────────────────────────────────────────────
        function showToast(message, type = 'success') {
            const colors = type === 'error'
                ? 'bg-red-500/10 border-red-500/30 text-red-400'
                : 'bg-emerald-500/10 border-emerald-500/30 text-emerald-400';
            const toast = document.createElement('div');
            toast.className = `fixed bottom-6 left-1/2 -translate-x-1/2 flex items-center gap-2
                               px-4 py-2.5 rounded-xl border text-sm font-medium shadow-lg z-50
                               transition-all duration-200 opacity-0 translate-y-2 ${colors}`;
            toast.textContent = message;
            document.body.appendChild(toast);
            requestAnimationFrame(() => toast.classList.remove('opacity-0', 'translate-y-2'));
            setTimeout(() => {
                toast.classList.add('opacity-0', 'translate-y-2');
                setTimeout(() => toast.remove(), 200);
            }, 3000);
        }

        // ── XSS protection ─────────────────────────────────────────
        function escapeHtml(str) {
            return String(str)
                .replace(/&/g, '&amp;').replace(/</g, '&lt;')
                .replace(/>/g, '&gt;').replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }


        // ══════════════════════════════════════════════════════════
        //  STATE
        // ══════════════════════════════════════════════════════════
        let _preview = null;   // raw AnalysisPreviewDto from server
        let _tasks = [];     // { ...PreviewTaskDto, approved: bool, editing: bool }
        let _notes = [];     // { ...PreviewNoteDto, approved: bool, editing: bool }
        let _activeTab = 'tasks';

        // ══════════════════════════════════════════════════════════
        //  ENTRY — replaces the old Analyze form submit
        //  Wire the "Analyze Meeting" button to this instead of a
        //  normal form POST. Change the button to:
        //      <button type="button" onclick="startAnalysis()">
        // ══════════════════════════════════════════════════════════
        async function startAnalysis() {
            showOverlay('analyze-overlay');
            startAnalyzeSteps();

            try {
                const formData = new FormData();
                formData.append('meetingId', MEETING_ID);
                formData.append('__RequestVerificationToken', CSRF_TOKEN);

                const res = await fetch('/Meetings/PreviewAnalysis', {
                    method: 'POST', body: formData
                });
                const data = await res.json();

                document.getElementById('analyze-overlay')?.classList.add('hidden');

                if (!data.success) {
                    showToast(data.error ?? 'Analysis failed.', 'error');
                    return;
                }

                openReviewModal(data.preview);

            } catch (err) {
                document.getElementById('analyze-overlay')?.classList.add('hidden');
                showToast('Network error. Please try again.', 'error');
                console.error(err);
            }
        }

        // ══════════════════════════════════════════════════════════
        //  OPEN / CLOSE MODAL
        // ══════════════════════════════════════════════════════════
        function openReviewModal(preview) {
            _preview = preview;

            _tasks = (preview.tasks ?? []).map((t, i) => ({
                ...t, tempId: i, approved: true, editing: false
            }));
            _notes = (preview.notes ?? []).map((n, i) => ({
                ...n, tempId: i, approved: true, editing: false
            }));

            renderTasks();
            renderNotes();
            updateCounts();

            const modal = document.getElementById('review-modal');
            const inner = document.getElementById('review-modal-inner');
            modal.classList.remove('hidden');
            requestAnimationFrame(() => {
                inner.classList.remove('scale-95', 'opacity-0');
                inner.classList.add('scale-100', 'opacity-100');
            });

            lucide.createIcons();
        }

        function closeReviewModal() {
            const modal = document.getElementById('review-modal');
            const inner = document.getElementById('review-modal-inner');
            inner.classList.add('scale-95', 'opacity-0');
            inner.classList.remove('scale-100', 'opacity-100');
            setTimeout(() => modal.classList.add('hidden'), 200);
        }

        // ══════════════════════════════════════════════════════════
        //  TABS
        // ══════════════════════════════════════════════════════════
        function switchTab(tab) {
            _activeTab = tab;

            ['tasks', 'notes'].forEach(t => {
                const btn = document.getElementById(`tab-${t}`);
                const panel = document.getElementById(`panel-${t}`);
                if (t === tab) {
                    btn.classList.add('border-violet-500', 'text-violet-400');
                    btn.classList.remove('border-transparent', 'text-slate-500');
                    panel.classList.remove('hidden');
                } else {
                    btn.classList.remove('border-violet-500', 'text-violet-400');
                    btn.classList.add('border-transparent', 'text-slate-500');
                    panel.classList.add('hidden');
                }
            });
        }

        // ══════════════════════════════════════════════════════════
        //  RENDER
        // ══════════════════════════════════════════════════════════
        const PRIORITY_COLOR = {
            high: 'text-red-400 bg-red-400/10 border-red-400/20',
            medium: 'text-amber-400 bg-amber-400/10 border-amber-400/20',
            low: 'text-slate-400 bg-slate-400/10 border-slate-400/20',
        };

        function renderTasks() {
            const el = document.getElementById('panel-tasks');
            if (!_tasks.length) {
                el.innerHTML = emptyState('No tasks extracted from this meeting.');
                return;
            }
            el.innerHTML = _tasks.map(t => taskCard(t)).join('');
            lucide.createIcons();
            // wire edit/save buttons
            _tasks.forEach(t => wireCard('task', t.tempId));
        }

        function renderNotes() {
            const el = document.getElementById('panel-notes');
            if (!_notes.length) {
                el.innerHTML = emptyState('No notes extracted from this meeting.');
                return;
            }
            el.innerHTML = _notes.map(n => noteCard(n)).join('');
            lucide.createIcons();
            _notes.forEach(n => wireCard('note', n.tempId));
        }

        function taskCard(t) {
            const pc = PRIORITY_COLOR[t.priority?.toLowerCase()] ?? PRIORITY_COLOR.low;
            const faded = t.approved ? '' : 'opacity-40';
            return `
                    <div id="task-card-${t.tempId}"
                         class="group relative rounded-xl border transition-all duration-150
                                ${t.approved
                    ? 'bg-surface border-surface-border'
                    : 'bg-surface/50 border-surface-border/50'} ${faded}">

                        <!-- View mode -->
                        <div id="task-view-${t.tempId}" class="p-4">
                            <div class="flex items-start gap-3">
                                <!-- Approve toggle -->
                                <button onclick="toggleApprove('task', ${t.tempId})"
                                        class="mt-0.5 w-5 h-5 rounded-md border-2 shrink-0 transition-colors flex items-center justify-center
                                               ${t.approved
                    ? 'bg-violet-600 border-violet-600'
                    : 'border-surface-border bg-transparent'}">
                                    ${t.approved
                    ? `<i data-lucide="check" class="w-3 h-3 text-white"></i>`
                    : ''}
                                </button>

                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-2 flex-wrap mb-1">
                                        <p class="text-sm font-medium text-white truncate">${escapeHtml(t.title)}</p>
                                        <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full border ${pc}">
                                            ${escapeHtml(t.priority ?? 'Low')}
                                        </span>
                                        ${t.dueDate ? `<span class="text-[10px] text-slate-500 flex items-center gap-1">
                                            <i data-lucide="calendar" class="w-3 h-3"></i>${escapeHtml(t.dueDate)}
                                        </span>` : ''}
                                    </div>
                                    <p class="text-xs text-slate-500 leading-relaxed line-clamp-2">
                                        ${escapeHtml(t.description)}
                                    </p>
                                </div>

                                <!-- Edit btn -->
                                <button id="task-edit-btn-${t.tempId}"
                                        onclick="startEdit('task', ${t.tempId})"
                                        class="shrink-0 opacity-0 group-hover:opacity-100 transition-opacity
                                               text-slate-600 hover:text-slate-300 p-1 rounded-lg hover:bg-surface-hover">
                                    <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Edit mode (hidden) -->
                        <div id="task-edit-${t.tempId}" class="hidden p-4 space-y-3">
                            <div>
                                <label class="text-[10px] text-slate-500 uppercase tracking-wider mb-1 block">Title</label>
                                <input id="task-title-${t.tempId}" value="${escapeHtml(t.title)}"
                                       class="w-full bg-surface border border-surface-border rounded-lg px-3 py-1.5
                                              text-sm text-white focus:outline-none focus:border-violet-500/50 transition-colors"/>
                            </div>
                            <div>
                                <label class="text-[10px] text-slate-500 uppercase tracking-wider mb-1 block">Description</label>
                                <textarea id="task-desc-${t.tempId}" rows="2"
                                          class="w-full bg-surface border border-surface-border rounded-lg px-3 py-1.5
                                                 text-xs text-slate-300 focus:outline-none focus:border-violet-500/50
                                                 transition-colors resize-none leading-relaxed">${escapeHtml(t.description)}</textarea>
                            </div>
                            <div class="flex items-center gap-2">
                                <div class="flex-1">
                                    <label class="text-[10px] text-slate-500 uppercase tracking-wider mb-1 block">Priority</label>
                                    <select id="task-priority-${t.tempId}"
                                            class="w-full bg-surface border border-surface-border rounded-lg px-3 py-1.5
                                                   text-xs text-white focus:outline-none focus:border-violet-500/50 transition-colors">
                                        ${['High', 'Medium', 'Low'].map(p =>
                        `<option value="${p}" ${t.priority === p ? 'selected' : ''}>${p}</option>`
                    ).join('')}
                                    </select>
                                </div>
                                <div class="flex-1">
                                    <label class="text-[10px] text-slate-500 uppercase tracking-wider mb-1 block">Due Date</label>
                                    <input id="task-due-${t.tempId}" type="date" value="${t.dueDate ?? ''}"
                                           class="w-full bg-surface border border-surface-border rounded-lg px-3 py-1.5
                                                  text-xs text-white focus:outline-none focus:border-violet-500/50 transition-colors"/>
                                </div>
                            </div>
                            <div class="flex gap-2 justify-end">
                                <button onclick="cancelEdit('task', ${t.tempId})"
                                        class="px-3 py-1.5 rounded-lg text-xs text-slate-500
                                               hover:text-slate-300 border border-surface-border transition-colors">
                                    Cancel
                                </button>
                                <button onclick="saveEdit('task', ${t.tempId})"
                                        class="px-3 py-1.5 rounded-lg text-xs font-semibold
                                               bg-violet-600 hover:bg-violet-500 text-white transition-colors">
                                    Save
                                </button>
                            </div>
                        </div>
                    </div>`;
        }

        function noteCard(n) {
            const faded = n.approved ? '' : 'opacity-40';
            return `
                    <div id="note-card-${n.tempId}"
                         class="group relative rounded-xl border transition-all duration-150
                                ${n.approved
                    ? 'bg-surface border-surface-border'
                    : 'bg-surface/50 border-surface-border/50'} ${faded}">

                        <!-- View mode -->
                        <div id="note-view-${n.tempId}" class="p-4">
                            <div class="flex items-start gap-3">
                                <button onclick="toggleApprove('note', ${n.tempId})"
                                        class="mt-0.5 w-5 h-5 rounded-md border-2 shrink-0 transition-colors flex items-center justify-center
                                               ${n.approved
                    ? 'bg-violet-600 border-violet-600'
                    : 'border-surface-border bg-transparent'}">
                                    ${n.approved
                    ? `<i data-lucide="check" class="w-3 h-3 text-white"></i>`
                    : ''}
                                </button>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-medium text-white mb-1">${escapeHtml(n.title)}</p>
                                    <p class="text-xs text-slate-500 leading-relaxed line-clamp-2">${escapeHtml(n.content)}</p>
                                </div>
                                <button id="note-edit-btn-${n.tempId}"
                                        onclick="startEdit('note', ${n.tempId})"
                                        class="shrink-0 opacity-0 group-hover:opacity-100 transition-opacity
                                               text-slate-600 hover:text-slate-300 p-1 rounded-lg hover:bg-surface-hover">
                                    <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Edit mode -->
                        <div id="note-edit-${n.tempId}" class="hidden p-4 space-y-3">
                            <div>
                                <label class="text-[10px] text-slate-500 uppercase tracking-wider mb-1 block">Title</label>
                                <input id="note-title-${n.tempId}" value="${escapeHtml(n.title)}"
                                       class="w-full bg-surface border border-surface-border rounded-lg px-3 py-1.5
                                              text-sm text-white focus:outline-none focus:border-violet-500/50 transition-colors"/>
                            </div>
                            <div>
                                <label class="text-[10px] text-slate-500 uppercase tracking-wider mb-1 block">Content</label>
                                <textarea id="note-content-${n.tempId}" rows="3"
                                          class="w-full bg-surface border border-surface-border rounded-lg px-3 py-1.5
                                                 text-xs text-slate-300 focus:outline-none focus:border-violet-500/50
                                                 transition-colors resize-none leading-relaxed">${escapeHtml(n.content)}</textarea>
                            </div>
                            <div class="flex gap-2 justify-end">
                                <button onclick="cancelEdit('note', ${n.tempId})"
                                        class="px-3 py-1.5 rounded-lg text-xs text-slate-500
                                               hover:text-slate-300 border border-surface-border transition-colors">
                                    Cancel
                                </button>
                                <button onclick="saveEdit('note', ${n.tempId})"
                                        class="px-3 py-1.5 rounded-lg text-xs font-semibold
                                               bg-violet-600 hover:bg-violet-500 text-white transition-colors">
                                    Save
                                </button>
                            </div>
                        </div>
                    </div>`;
        }

        function emptyState(msg) {
            return `<div class="flex flex-col items-center gap-2 py-10 text-center">
                        <i data-lucide="inbox" class="w-8 h-8 text-slate-700"></i>
                        <p class="text-sm text-slate-600">${msg}</p>
                    </div>`;
        }

        // ══════════════════════════════════════════════════════════
        //  WIRE CARD INTERACTIONS (after render)
        // ══════════════════════════════════════════════════════════
        function wireCard(type, id) {
            // nothing extra needed — buttons use inline onclick
        }

        // ══════════════════════════════════════════════════════════
        //  APPROVE / REJECT
        // ══════════════════════════════════════════════════════════
        function toggleApprove(type, id) {
            const arr = type === 'task' ? _tasks : _notes;
            const item = arr.find(x => x.tempId === id);
            if (!item) return;

            item.approved = !item.approved;

            // re-render just this card
            const panel = document.getElementById(`panel-${type}s`);
            const card = document.getElementById(`${type}-card-${id}`);
            if (!card) return;

            const tmp = document.createElement('div');
            tmp.innerHTML = type === 'task' ? taskCard(item) : noteCard(item);
            card.replaceWith(tmp.firstElementChild);
            lucide.createIcons();
            wireCard(type, id);
            updateCounts();
        }

        function selectAll(approve) {
            _tasks.forEach(t => t.approved = approve);
            _notes.forEach(n => n.approved = approve);
            renderTasks();
            renderNotes();
            updateCounts();
        }

        // ══════════════════════════════════════════════════════════
        //  INLINE EDIT
        // ══════════════════════════════════════════════════════════
        function startEdit(type, id) {
            document.getElementById(`${type}-view-${id}`)?.classList.add('hidden');
            document.getElementById(`${type}-edit-${id}`)?.classList.remove('hidden');
        }

        function cancelEdit(type, id) {
            document.getElementById(`${type}-edit-${id}`)?.classList.add('hidden');
            document.getElementById(`${type}-view-${id}`)?.classList.remove('hidden');
        }

        function saveEdit(type, id) {
            if (type === 'task') {
                const item = _tasks.find(t => t.tempId === id);
                if (!item) return;
                item.title = document.getElementById(`task-title-${id}`)?.value ?? item.title;
                item.description = document.getElementById(`task-desc-${id}`)?.value ?? item.description;
                item.priority = document.getElementById(`task-priority-${id}`)?.value ?? item.priority;
                item.dueDate = document.getElementById(`task-due-${id}`)?.value || null;
            } else {
                const item = _notes.find(n => n.tempId === id);
                if (!item) return;
                item.title = document.getElementById(`note-title-${id}`)?.value ?? item.title;
                item.content = document.getElementById(`note-content-${id}`)?.value ?? item.content;
            }

            // re-render card
            const arr = type === 'task' ? _tasks : _notes;
            const item = arr.find(x => x.tempId === id);
            const card = document.getElementById(`${type}-card-${id}`);
            if (!card || !item) return;

            const tmp = document.createElement('div');
            tmp.innerHTML = type === 'task' ? taskCard(item) : noteCard(item);
            card.replaceWith(tmp.firstElementChild);
            lucide.createIcons();
        }

        // ══════════════════════════════════════════════════════════
        //  COUNTS
        // ══════════════════════════════════════════════════════════
        function updateCounts() {
            const at = _tasks.filter(t => t.approved).length;
            const an = _notes.filter(n => n.approved).length;
            document.getElementById('tasks-count').textContent = `${at}/${_tasks.length}`;
            document.getElementById('notes-count').textContent = `${an}/${_notes.length}`;

            const total = at + an;
            document.getElementById('confirm-label').textContent =
                total === 0 ? 'Save (nothing selected)' : `Save ${total} item${total !== 1 ? 's' : ''}`;
        }

        // ══════════════════════════════════════════════════════════
        //  CONFIRM — POST to /Meetings/ConfirmAnalysis
        // ══════════════════════════════════════════════════════════
        async function confirmAnalysis() {
            const btn = document.getElementById('confirm-btn');
            btn.disabled = true;
            btn.innerHTML = `<svg class="animate-spin w-3.5 h-3.5" viewBox="0 0 24 24" fill="none">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
                    </svg> Saving…`;

            const approvedTasks = _tasks
                .filter(t => t.approved)
                .map(({ tempId, editing, approved, ...rest }) => rest);

            const approvedNotes = _notes
                .filter(n => n.approved)
                .map(({ tempId, editing, approved, ...rest }) => rest);

            const payload = {
                meetingId: MEETING_ID,
                summary: _preview.summary,
                keyInsights: _preview.keyInsights,
                keyDecisions: _preview.keyDecisions ?? [],
                approvedTasks,
                approvedNotes,
            };

            try {
                const res = await fetch('/Meetings/ConfirmAnalysis', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': CSRF_TOKEN,
                    },
                    body: JSON.stringify(payload),
                });
                const data = await res.json();

                if (data.success) {
                    closeReviewModal();
                    // small delay so modal closes gracefully
                    setTimeout(() => window.location.reload(), 300);
                } else {
                    showToast(data.error ?? 'Save failed.', 'error');
                    btn.disabled = false;
                    btn.innerHTML = '<i data-lucide="save" class="w-3.5 h-3.5"></i> <span>Save items</span>';
                    lucide.createIcons();
                }
            } catch (err) {
                console.error(err);
                showToast('Network error. Please try again.', 'error');
                btn.disabled = false;
                btn.innerHTML = '<i data-lucide="save" class="w-3.5 h-3.5"></i> <span>Save items</span>';
                lucide.createIcons();
            }
        }

        // close on backdrop click
        document.getElementById('review-modal')?.addEventListener('click', function (e) {
            if (e.target === this) closeReviewModal();
        });
    </script>
}