@model CreateMeetingViewModel

@{
    ViewData["Title"] = "New Meeting";
}

<div class="max-w-xl mx-auto">
    <div class="mb-8">
        <div class="flex items-center gap-3 mb-2">
            <div class="w-9 h-9 rounded-xl bg-surface-card border border-surface-border flex items-center justify-center">
                <i data-lucide="video" class="w-4 h-4 text-brand-400"></i>
            </div>
            <h2 class="text-xl font-semibold text-white">Schedule a Meeting</h2>
        </div>
        <p class="text-slate-500 text-sm ml-12">A Jitsi room will be created automatically.</p>
    </div>

    <div class="bg-surface-card border border-surface-border rounded-2xl p-6">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <!-- Title -->
            <div class="mb-6">
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">
                    Meeting Title
                </label>
                <input type="text" name="Title" value="@Model.Title"
                       placeholder="e.g. Weekly Team Sync"
                       class="w-full bg-surface border border-surface-border rounded-xl px-4 py-3 text-sm text-slate-300
                              placeholder-slate-600 focus:outline-none focus:border-brand-600 focus:ring-1
                              focus:ring-brand-600/30 transition-colors" />
                <span asp-validation-for="Title" class="text-xs text-red-400 mt-1 block"></span>
            </div>

            <!-- Scheduled At -->
            <div class="mb-6">
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">
                    Scheduled At
                </label>
                <input type="datetime-local" name="ScheduledAt"
                       value="@Model.ScheduledAt.ToString("yyyy-MM-ddTHH:mm")"
                       min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")"
                       class="w-full bg-surface border border-surface-border rounded-xl px-4 py-3 text-sm text-slate-300
                              focus:outline-none focus:border-brand-600 focus:ring-1 focus:ring-brand-600/30 transition-colors" />
                <span asp-validation-for="ScheduledAt" class="text-xs text-red-400 mt-1 block"></span>
            </div>

            <!-- Info box -->
            <div class="flex items-start gap-3 px-4 py-3 rounded-xl bg-brand-600/10 border border-brand-600/20 mb-6">
                <i data-lucide="info" class="w-4 h-4 text-brand-400 mt-0.5 shrink-0"></i>
                <p class="text-xs text-slate-400 leading-relaxed">
                    A unique Jitsi video room will be generated for this meeting.
                    You can start it at any time from the meeting details page.
                </p>
            </div>

            <!-- Actions -->
            <div class="flex items-center justify-between pt-4 border-t border-surface-border">
                <a href="@Url.Action("Index")"
                   class="text-sm text-slate-500 hover:text-slate-300 transition-colors flex items-center gap-2">
                    <i data-lucide="arrow-left" class="w-4 h-4"></i>
                    Back
                </a>
                <button type="submit"
                        class="flex items-center gap-2 px-5 py-2.5 bg-brand-600 hover:bg-brand-500
                               text-white text-sm font-semibold rounded-xl transition-colors shadow-glow">
                    <i data-lucide="calendar-plus" class="w-4 h-4"></i>
                    Schedule Meeting
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}