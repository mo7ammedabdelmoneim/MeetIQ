@model List<MeetingInvitationDto>

@{
    ViewData["Title"] = "My Invitations";
}

<div class="max-w-2xl mx-auto space-y-6">

    <div>
        <h2 class="text-xl font-semibold text-white">My Invitations</h2>
        <p class="text-slate-500 text-sm mt-0.5">@Model.Count pending invitation(s)</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm">
            <i data-lucide="check-circle" class="w-4 h-4 shrink-0"></i>
            @TempData["Success"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="flex flex-col items-center justify-center py-24 text-center">
            <div class="w-14 h-14 rounded-2xl bg-surface-card border border-surface-border flex items-center justify-center mb-4">
                <i data-lucide="mail" class="w-6 h-6 text-slate-600"></i>
            </div>
            <p class="text-slate-400 font-medium">No pending invitations</p>
        </div>
    }
    else
    {
        <div class="space-y-3">
            @foreach (var inv in Model)
            {
                <div class="bg-surface-card border border-surface-border rounded-xl p-5">
                    <div class="flex items-start justify-between gap-4">
                        <div class="min-w-0">
                            <p class="font-semibold text-white truncate">@inv.MeetingTitle</p>
                            <div class="flex items-center gap-3 mt-1.5 text-xs text-slate-500 flex-wrap">
                                <span class="flex items-center gap-1">
                                    <i data-lucide="calendar" class="w-3 h-3"></i>
                                    @inv.MeetingScheduledAt.ToLocalTime().ToString("MMM dd, yyyy — HH:mm")
                                </span>
                                <span class="flex items-center gap-1">
                                    <i data-lucide="user" class="w-3 h-3"></i>
                                    From @inv.InvitedByName
                                </span>
                            </div>
                        </div>

                        <div class="flex items-center gap-2 shrink-0">
                            <!-- Accept -->
                            <form asp-action="Respond" method="post" class="mb-0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="invitationId" value="@inv.Id" />
                                <input type="hidden" name="meetingId" value="@inv.MeetingId" />
                                <input type="hidden" name="response" value="@((int)InvitationStatus.Accepted)" />
                                <button type="submit"
                                        class="flex items-center gap-1.5 px-3 py-2 rounded-xl bg-emerald-600/20
                                               hover:bg-emerald-600/30 border border-emerald-500/30 text-emerald-400
                                               text-xs font-semibold transition-colors">
                                    <i data-lucide="check" class="w-3.5 h-3.5"></i>
                                    Accept
                                </button>
                            </form>

                            <!-- Decline -->
                            <form asp-action="Respond" method="post" class="mb-0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="invitationId" value="@inv.Id" />
                                <input type="hidden" name="meetingId" value="@inv.MeetingId" />
                                <input type="hidden" name="response" value="@((int)InvitationStatus.Declined)" />
                                <button type="submit"
                                        class="flex items-center gap-1.5 px-3 py-2 rounded-xl border border-surface-border
                                               text-slate-500 hover:text-red-400 hover:border-red-500/30 text-xs font-medium transition-colors">
                                    <i data-lucide="x" class="w-3.5 h-3.5"></i>
                                    Decline
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>