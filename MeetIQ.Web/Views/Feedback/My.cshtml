@model PagedResult<FeedbackListItemDto>

@{
    ViewData["Title"] = "My Feedback Reports";
}

<div class="space-y-6">

    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-xl font-semibold text-white">My Feedback Reports</h2>
            <p class="text-slate-500 text-sm mt-0.5">@Model.TotalCount report(s) submitted</p>
        </div>
        <a href="@Url.Action("Create", "Feedback")"
           class="flex items-center gap-2 px-4 py-2 bg-brand-600 hover:bg-brand-500
                  text-white text-sm font-semibold rounded-xl transition-colors shadow-glow">
            <i data-lucide="plus" class="w-4 h-4"></i>
            New Report
        </a>
    </div>

    <!-- List -->
    @if (!Model.Items.Any())
    {
        <div class="flex flex-col items-center justify-center py-24 text-center">
            <div class="w-14 h-14 rounded-2xl bg-surface-card border border-surface-border flex items-center justify-center mb-4">
                <i data-lucide="flag" class="w-6 h-6 text-slate-600"></i>
            </div>
            <p class="text-slate-400 font-medium mb-1">No feedback submitted yet</p>
            <p class="text-slate-600 text-sm">Report a bug or suggest a feature</p>
        </div>
    }
    else
    {
        <div class="space-y-3">
            @foreach (var item in Model.Items)
            {
                var statusColors = new Dictionary<FeedbackStatus, string>
                                {
                                { FeedbackStatus.Open,      "text-amber-400 bg-amber-400/10 border-amber-400/20" },
                                { FeedbackStatus.InReview,  "text-blue-400 bg-blue-400/10 border-blue-400/20" },
                                { FeedbackStatus.Resolved,  "text-emerald-400 bg-emerald-400/10 border-emerald-400/20" },
                                { FeedbackStatus.Closed,    "text-slate-400 bg-slate-400/10 border-slate-400/20" }
                                };

                                        var typeIcons = new Dictionary<FeedbackType, string>
                                {
                                { FeedbackType.Bug,             "bug" },
                                { FeedbackType.FeatureRequest,  "lightbulb" },
                                { FeedbackType.GeneralFeedback, "message-square" },
                                { FeedbackType.Other,           "more-horizontal" }
                                };

                var statusColor = statusColors[item.Status];
                var typeIcon = typeIcons[item.Type];
                <div class="bg-surface-card border border-surface-border rounded-xl p-4 hover:border-surface-hover transition-colors">
                    <div class="flex items-start justify-between gap-4">
                        <div class="flex items-start gap-3 min-w-0">
                            <div class="w-8 h-8 rounded-lg bg-surface border border-surface-border flex items-center justify-center shrink-0 mt-0.5">
                                <i data-lucide="@typeIcon" class="w-3.5 h-3.5 text-brand-400"></i>
                            </div>
                            <div class="min-w-0">
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="text-xs font-medium text-slate-500">@item.Type.ToString()</span>
                                    <span class="text-slate-700">·</span>
                                    <time class="text-xs text-slate-600">
                                        @item.CreatedAt.ToString("MMM dd, yyyy")
                                    </time>
                                </div>
                                <p class="text-sm text-slate-300 truncate">@item.Message</p>
                            </div>
                        </div>
                        <span class="text-xs font-semibold px-2.5 py-1 rounded-full border @statusColor">
                            @item.Status.ToString()
                        </span>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="flex items-center justify-center gap-2 pt-4">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a href="?page=@i"
                       class="@(i == Model.Page
                           ? "w-8 h-8 rounded-lg bg-brand-600 text-white font-semibold text-sm flex items-center justify-center"
                           : "w-8 h-8 rounded-lg border border-surface-border text-slate-400 hover:text-white hover:border-brand-600 text-sm flex items-center justify-center transition-colors")">
                        @i
                    </a>
                }
            </div>
        }
    }
</div>