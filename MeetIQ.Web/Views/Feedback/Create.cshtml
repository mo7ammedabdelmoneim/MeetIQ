@model CreateFeedbackViewModel

@{
    ViewData["Title"] = "Report an Issue";
}

<div class="max-w-2xl mx-auto">

    <!-- Header -->
    <div class="mb-8">
        <div class="flex items-center gap-3 mb-2">
            <div class="w-9 h-9 rounded-xl bg-surface-card border border-surface-border flex items-center justify-center">
                <i data-lucide="flag" class="w-4 h-4 text-brand-400"></i>
            </div>
            <h2 class="text-xl font-semibold text-white">Report an Issue</h2>
        </div>
        <p class="text-slate-500 text-sm ml-12">
            Found a bug or have a suggestion? We'd love to hear from you.
        </p>
    </div>

    <!-- Success Banner -->
    @if (TempData["Success"] != null)
    {
        <div class="mb-6 flex items-center gap-3 px-4 py-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm">
            <i data-lucide="check-circle" class="w-4 h-4 shrink-0"></i>
            @TempData["Success"]
        </div>
    }

    <!-- Form Card -->
    <div class="bg-surface-card border border-surface-border rounded-2xl p-6">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <!-- Type -->
            <div class="mb-6">
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">
                    Feedback Type
                </label>
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
                    @foreach (FeedbackType type in Enum.GetValues(typeof(FeedbackType)))
                    {
                        var icons = new Dictionary<FeedbackType, string>
                    {
                    { FeedbackType.Bug, "bug" },
                    { FeedbackType.FeatureRequest, "lightbulb" },
                    { FeedbackType.GeneralFeedback, "message-square" },
                    { FeedbackType.Other, "more-horizontal" }
                    };
                        var labels = new Dictionary<FeedbackType, string>
                    {
                    { FeedbackType.Bug, "Bug Report" },
                    { FeedbackType.FeatureRequest, "Feature Request" },
                    { FeedbackType.GeneralFeedback, "General Feedback" },
                    { FeedbackType.Other, "Other" }
                    };

                        <label class="feedback-type-card cursor-pointer">
                            <input type="radio" asp-for="Type" value="@((int)type)"
                                   class="sr-only peer" />
                            <div class="flex flex-col items-center gap-2 px-3 py-4 rounded-xl border border-surface-border
                                        bg-surface hover:border-brand-600/50 hover:bg-surface-hover transition-all
                                        peer-checked:border-brand-500 peer-checked:bg-brand-600/10 text-center">
                                <i data-lucide="@icons[type]" class="w-5 h-5 text-slate-500 peer-checked:text-brand-400"></i>
                                <span class="text-xs font-medium text-slate-400">@labels[type]</span>
                            </div>
                        </label>
                    }
                </div>
                <span asp-validation-for="Type" class="text-xs text-red-400 mt-1 block"></span>
            </div>

            <!-- Message -->
            <div class="mb-6">
                <label asp-for="Message"
                       class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">
                    Message
                </label>
                <textarea asp-for="Message" rows="6"
                          placeholder="Describe the issue or your suggestion in detail..."
                          class="w-full bg-surface border border-surface-border rounded-xl px-4 py-3 text-sm text-slate-300
                                 placeholder-slate-600 focus:outline-none focus:border-brand-600 focus:ring-1 focus:ring-brand-600/30
                                 transition-colors resize-none"></textarea>
                <div class="flex justify-between mt-1">
                    <span asp-validation-for="Message" class="text-xs text-red-400"></span>
                    <span class="text-xs text-slate-600" id="charCount">0 / 2000</span>
                </div>
            </div>

            <!-- Actions -->
            <div class="flex items-center justify-between pt-4 border-t border-surface-border">
                <a href="@Url.Action("My", "Feedback")"
                   class="text-sm text-slate-500 hover:text-slate-300 transition-colors flex items-center gap-2">
                    <i data-lucide="arrow-left" class="w-4 h-4"></i>
                    My Reports
                </a>
                <button type="submit"
                        class="flex items-center gap-2 px-5 py-2.5 bg-brand-600 hover:bg-brand-500
                               text-white text-sm font-semibold rounded-xl transition-colors shadow-glow">
                    <i data-lucide="send" class="w-4 h-4"></i>
                    Submit Report
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Char counter
        const textarea = document.querySelector('textarea[name="Message"]');
        const counter = document.getElementById('charCount');
        textarea?.addEventListener('input', () => {
            counter.textContent = `${textarea.value.length} / 2000`;
        });
    </script>
}