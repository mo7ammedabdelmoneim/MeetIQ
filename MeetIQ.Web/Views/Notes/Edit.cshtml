@model NoteEditViewModel
@{
    ViewData["Title"] = "Edit Note";
}

<!-- ── BREADCRUMB ────────────────────────────────────────────────────────── -->
<nav class="flex items-center gap-2 text-xs text-slate-600 mb-6">
    <a asp-action="Index" class="hover:text-slate-400 transition-colors">Notes</a>
    <i data-lucide="chevron-right" class="w-3 h-3"></i>
    <a asp-action="Details" asp-route-id="@Model.Id"
       class="hover:text-slate-400 transition-colors truncate max-w-xs">@Model.Title</a>
    <i data-lucide="chevron-right" class="w-3 h-3"></i>
    <span class="text-slate-400">Edit</span>
</nav>

@if (Model.IsAutoGenerated)
{
    <div class="flex items-center gap-3 px-4 py-3 mb-6 bg-violet-500/10 border border-violet-500/25 rounded-lg text-violet-300 text-sm">
        <i data-lucide="sparkles" class="w-4 h-4 shrink-0 text-violet-400"></i>
        This note was <strong class="font-semibold text-violet-200">AI-generated</strong>.
        Your edits will be saved and the note will be marked as manually edited.
    </div>
}

<!-- ── TOAST NOTIFICATION ───────────────────────────────────────────────── -->
<div id="toast"
     class="fixed top-5 right-5 z-50 hidden items-center gap-3 px-4 py-3
            bg-surface-card border rounded-xl shadow-2xl text-sm font-medium
            transition-all duration-300 max-w-xs">
    <i id="toast-icon" class="w-4 h-4 shrink-0"></i>
    <span id="toast-msg"></span>
</div>

<form asp-action="Edit" method="post" id="noteForm" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="IsAutoGenerated" />

    <div class="flex flex-col lg:flex-row gap-6">

        <!-- ── EDITOR AREA ──────────────────────────────────────────────── -->
        <div class="flex-1 min-w-0 space-y-4">

            <!-- Title -->
            <div class="bg-surface-card border border-surface-border rounded-xl p-5"
                 id="title-wrapper">
                <label asp-for="Title"
                       class="block text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2">
                    Title <span class="text-red-500">*</span>
                </label>
                <input asp-for="Title"
                       id="titleInput"
                       placeholder="Note title…"
                       class="w-full bg-transparent text-xl font-semibold text-white placeholder-slate-700
                              focus:outline-none border-0 p-0 transition-colors" />
                <span id="title-error" class="hidden text-red-400 text-xs mt-1 flex items-center gap-1">
                    <i data-lucide="alert-circle" class="w-3 h-3"></i>
                    Title is required.
                </span>
            </div>

            <!-- Rich-text editor -->
            <div class="bg-surface-card border border-surface-border rounded-xl overflow-hidden"
                 id="content-wrapper">
                <div class="border-b border-surface-border px-4 py-2 flex items-center gap-1 flex-wrap">
                    <span class="text-xs text-slate-600 font-medium mr-2">
                        Content <span class="text-red-500">*</span>
                    </span>
                    <div id="toolbar" class="flex items-center gap-0.5 flex-wrap">
                        <button class="ql-bold" title="Bold"></button>
                        <button class="ql-italic" title="Italic"></button>
                        <button class="ql-underline" title="Underline"></button>
                        <span class="w-px h-4 bg-surface-border mx-1"></span>
                        <button class="ql-list" value="ordered" title="Ordered list"></button>
                        <button class="ql-list" value="bullet" title="Bullet list"></button>
                        <span class="w-px h-4 bg-surface-border mx-1"></span>
                        <button class="ql-blockquote" title="Blockquote"></button>
                        <button class="ql-code-block" title="Code block"></button>
                        <span class="w-px h-4 bg-surface-border mx-1"></span>
                        <select class="ql-header" title="Heading">
                            <option value="1">H1</option>
                            <option value="2">H2</option>
                            <option value="3">H3</option>
                            <option selected></option>
                        </select>
                        <span class="w-px h-4 bg-surface-border mx-1"></span>
                        <button class="ql-link" title="Link"></button>
                        <button class="ql-clean" title="Clear format"></button>
                    </div>
                </div>
                <div id="quill-editor" style="min-height: 340px;" class="px-6 py-4 text-slate-300"></div>
                <input type="hidden" asp-for="Content" id="ContentInput" />
                <span id="content-error"
                      class="hidden text-red-400 text-xs px-6 pb-3 flex items-center gap-1">
                    <i data-lucide="alert-circle" class="w-3 h-3"></i>
                    Content is required.
                </span>
            </div>
        </div>

        <!-- ── META SIDEBAR ──────────────────────────────────────────────── -->
        <aside class="w-full lg:w-64 shrink-0 space-y-4">

            <!-- Actions -->
            <div class="bg-surface-card border border-surface-border rounded-xl p-4 flex flex-col gap-2">
                <button type="submit"
                        class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-brand-600 hover:bg-brand-500
                               text-white text-sm font-semibold rounded-lg transition-colors shadow-glow">
                    <i data-lucide="save" class="w-4 h-4"></i>
                    Save Changes
                </button>
                <a asp-action="Details" asp-route-id="@Model.Id"
                   class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-surface-hover border border-surface-border
                          hover:border-slate-500 text-slate-400 text-sm font-medium rounded-lg transition-colors">
                    Cancel
                </a>
            </div>

            <!-- Meeting link -->
            <div class="bg-surface-card border border-surface-border rounded-xl p-5 space-y-3">
                <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-widest">Link to Meeting</h3>
                <select asp-for="MeetingId"
                        asp-items="@(new SelectList(Model.Meetings, "Value", "Text"))"
                        class="w-full px-3 py-2 bg-surface border border-surface-border rounded-lg text-sm text-slate-300
                               focus:outline-none focus:border-brand-600 transition-colors">
                    <option value="">— None —</option>
                </select>
            </div>

            <!-- Calendar event link -->
            <div class="bg-surface-card border border-surface-border rounded-xl p-5 space-y-3">
                <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-widest">Link to Calendar Event</h3>
                <select asp-for="CalendarEventId"
                        asp-items="@(new SelectList(Model.CalendarEvents, "Value", "Text"))"
                        class="w-full px-3 py-2 bg-surface border border-surface-border rounded-lg text-sm text-slate-300
                               focus:outline-none focus:border-brand-600 transition-colors">
                    <option value="">— None —</option>
                </select>
            </div>

            <!-- Tags -->
            <div class="bg-surface-card border border-surface-border rounded-xl p-5 space-y-3"
                 id="tags-wrapper">
                <div class="flex items-center justify-between">
                    <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-widest">
                        Tags <span class="text-red-500">*</span>
                    </h3>
                    <span id="tags-badge"
                          class="hidden text-[10px] px-2 py-0.5 rounded-full bg-red-900/40
                                 border border-red-800/50 text-red-400 font-medium">
                        required
                    </span>
                </div>

                <div id="tags-input-wrapper"
                     class="flex items-center gap-2 px-3 py-2 bg-surface border border-surface-border
                            rounded-lg transition-colors focus-within:border-brand-600">
                    <i data-lucide="tag" class="w-3.5 h-3.5 text-slate-600 shrink-0"></i>
                    <input asp-for="TagsInput"
                           id="tagsInput"
                           placeholder="Add tags…"
                           autocomplete="off"
                           class="flex-1 bg-transparent text-sm text-slate-300 placeholder-slate-700
                                  focus:outline-none border-0 p-0 min-w-0" />
                </div>

                <p class="text-[11px] text-slate-600">
                    Separate with commas e.g.
                    <em class="text-slate-500">design, frontend</em>
                </p>

                <span id="tags-error"
                      class="hidden text-red-400 text-xs flex items-center gap-1">
                    <i data-lucide="alert-circle" class="w-3 h-3"></i>
                    Please add at least one tag.
                </span>

                @if (Model.AllTags.Any())
                {
                    <div class="flex flex-wrap gap-1.5 pt-1">
                        @foreach (var tag in Model.AllTags.Take(12))
                        {
                            <button type="button" onclick="addTag('@tag')"
                                    class="px-2 py-0.5 rounded-full bg-surface-border hover:bg-brand-900
                                           hover:text-brand-400 text-slate-400 text-xs transition-colors border
                                           border-transparent hover:border-brand-800">
                                #@tag
                            </button>
                        }
                    </div>
                }
            </div>

            <!-- Danger zone -->
            <div class="bg-surface-card border border-red-500/20 rounded-xl p-5">
                <h3 class="text-xs font-semibold text-red-500/70 uppercase tracking-widest mb-3">Danger Zone</h3>
                <button type="button"
                        onclick="document.getElementById('deleteModal').classList.remove('hidden')"
                        class="w-full flex items-center justify-center gap-2 px-3 py-2 bg-red-500/10 hover:bg-red-500/20
                               border border-red-500/25 text-red-400 text-sm font-medium rounded-lg transition-colors">
                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                    Delete Note
                </button>
            </div>
        </aside>
    </div>
</form>

<!-- ── DELETE CONFIRM MODAL ──────────────────────────────────────────────── -->
<div id="deleteModal"
     class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4">
    <div class="bg-surface-card border border-surface-border rounded-2xl shadow-2xl p-6 w-full max-w-sm">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-red-500/15 flex items-center justify-center">
                <i data-lucide="trash-2" class="w-5 h-5 text-red-400"></i>
            </div>
            <h3 class="text-base font-semibold text-white">Delete Note</h3>
        </div>
        <p class="text-sm text-slate-400 mb-6">
            Are you sure you want to delete
            <strong class="text-white">"@Model.Title"</strong>?
            This action cannot be undone.
        </p>
        <div class="flex gap-3">
            <button onclick="document.getElementById('deleteModal').classList.add('hidden')"
                    class="flex-1 px-4 py-2 bg-surface-hover border border-surface-border hover:border-slate-500
                           text-slate-300 text-sm font-medium rounded-lg transition-colors">
                Cancel
            </button>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="flex-1">
                @Html.AntiForgeryToken()
                <button type="submit"
                        class="w-full px-4 py-2 bg-red-600 hover:bg-red-500 text-white text-sm font-semibold rounded-lg transition-colors">
                    Delete
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.snow.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.min.js"></script>

    <style>
        .ql-toolbar.ql-snow {
            border: none !important;
            padding: 0 !important;
        }

        .ql-container.ql-snow {
            border: none !important;
        }

        .ql-editor {
            color: #cbd5e1;
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            line-height: 1.75;
            min-height: 340px;
        }

            .ql-editor.ql-blank::before {
                color: #334155;
                font-style: normal;
            }

        .ql-snow .ql-stroke {
            stroke: #64748b !important;
        }

        .ql-snow .ql-fill {
            fill: #64748b !important;
        }

        .ql-snow .ql-picker-label {
            color: #64748b !important;
        }

        .ql-snow .ql-toolbar button:hover .ql-stroke,
        .ql-snow .ql-toolbar button.ql-active .ql-stroke {
            stroke: #5a8eff !important;
        }

        .ql-snow .ql-toolbar button:hover .ql-fill,
        .ql-snow .ql-toolbar button.ql-active .ql-fill {
            fill: #5a8eff !important;
        }

        .ql-tooltip {
            background: #161b27 !important;
            border-color: #1f2637 !important;
            color: #cbd5e1 !important;
            box-shadow: none !important;
        }

            .ql-tooltip input[type=text] {
                background: #0f1117 !important;
                border-color: #1f2637 !important;
                color: #cbd5e1 !important;
            }

        .field-error {
            border-color: rgb(239 68 68 / 0.6) !important;
        }

        .field-success {
            border-color: rgb(52 211 153 / 0.5) !important;
        }

        #toast.show {
            display: flex !important;
            animation: slideIn .25s ease;
        }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-8px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>

    <script>
        // ── Quill setup ──────────────────────────────────────────────────────
        const quill = new Quill('#quill-editor', {
            theme: 'snow',
            modules: { toolbar: '#toolbar' },
            placeholder: 'Write your note here…'
        });

        const existing = document.getElementById('ContentInput').value;
        if (existing) quill.root.innerHTML = existing;

        // ── Toast ────────────────────────────────────────────────────────────
        let toastTimer = null;

        function showToast(message, type = 'error') {
            const toast = document.getElementById('toast');
            const toastMsg = document.getElementById('toast-msg');
            const toastIcon = document.getElementById('toast-icon');

            toast.className = toast.className
                .replace(/border-\S+/g, '')
                .replace(/text-\w+-\d+(?:\s|$)/g, '')
                .trim();

            if (type === 'warning') {
                toast.classList.add('border-amber-500/30', 'text-amber-400');
                toastIcon.setAttribute('data-lucide', 'alert-triangle');
            } else if (type === 'success') {
                toast.classList.add('border-emerald-500/30', 'text-emerald-400');
                toastIcon.setAttribute('data-lucide', 'check-circle-2');
            } else {
                toast.classList.add('border-red-500/30', 'text-red-400');
                toastIcon.setAttribute('data-lucide', 'alert-circle');
            }

            toastMsg.textContent = message;
            toast.classList.add('show');
            lucide.createIcons();

            clearTimeout(toastTimer);
            toastTimer = setTimeout(() => toast.classList.remove('show'), 3500);
        }

        // ── Field validators ─────────────────────────────────────────────────
        function setFieldState(wrapperId, errorId, isValid) {
            const wrapper = document.getElementById(wrapperId);
            const error = document.getElementById(errorId);
            if (!wrapper) return;
            if (isValid) {
                wrapper.classList.remove('field-error');
                wrapper.classList.add('field-success');
                error?.classList.add('hidden');
            } else {
                wrapper.classList.add('field-error');
                wrapper.classList.remove('field-success');
                error?.classList.remove('hidden');
                lucide.createIcons();
            }
        }

        function validateTitle() {
            const ok = document.getElementById('titleInput').value.trim().length >= 2;
            setFieldState('title-wrapper', 'title-error', ok);
            return ok;
        }

        function validateContent() {
            const ok = quill.getText().trim().length > 0;
            setFieldState('content-wrapper', 'content-error', ok);
            return ok;
        }

        function validateTags() {
            const val = document.getElementById('tagsInput').value.trim();
            const ok = val.split(',').map(t => t.trim()).filter(Boolean).length > 0;
            const wrapper = document.getElementById('tags-input-wrapper');
            const error = document.getElementById('tags-error');
            const badge = document.getElementById('tags-badge');

            if (ok) {
                wrapper.classList.remove('field-error');
                wrapper.classList.add('field-success');
                error?.classList.add('hidden');
                badge?.classList.add('hidden');
            } else {
                wrapper.classList.add('field-error');
                wrapper.classList.remove('field-success');
                error?.classList.remove('hidden');
                badge?.classList.remove('hidden');
                lucide.createIcons();
            }
            return ok;
        }

        // ── Live validation (after first submit attempt) ──────────────────────
        let submitted = false;

        document.getElementById('titleInput').addEventListener('input', () => {
            if (submitted) validateTitle();
        });

        document.getElementById('tagsInput').addEventListener('input', () => {
            if (submitted) validateTags();
        });

        quill.on('text-change', () => {
            if (submitted) validateContent();
        });

        // ── Submit ───────────────────────────────────────────────────────────
        document.getElementById('noteForm').addEventListener('submit', function (e) {
            submitted = true;

            document.getElementById('ContentInput').value = quill.root.innerHTML;

            const titleOk = validateTitle();
            const contentOk = validateContent();
            const tagsOk = validateTags();

            if (!titleOk || !contentOk || !tagsOk) {
                e.preventDefault();

                const missing = [];
                if (!titleOk) missing.push('title');
                if (!contentOk) missing.push('content');
                if (!tagsOk) missing.push('at least one tag');

                const msg = missing.length === 1
                    ? `Please add a ${missing[0]} before saving.`
                    : `Please fill in: ${missing.join(', ')}.`;

                showToast(msg, 'warning');

                document.querySelector('.field-error')
                    ?.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        });

        // ── Add tag helper ───────────────────────────────────────────────────
        function addTag(name) {
            const input = document.getElementById('tagsInput');
            const parts = input.value.split(',').map(t => t.trim()).filter(Boolean);
            if (!parts.includes(name)) input.value = [...parts, name].join(', ');
            if (submitted) validateTags();
        }

        lucide.createIcons();
    </script>
}
