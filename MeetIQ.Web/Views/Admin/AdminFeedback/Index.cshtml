@model PagedResult<FeedbackListItemDto>

@{
    ViewData["Title"] = "Feedback Reports";
    var currentStatus = ViewBag.CurrentStatus as FeedbackStatus?;
    var currentType = ViewBag.CurrentType as FeedbackType?;
    var currentSearch = ViewBag.CurrentSearch as string;
}

<div class="space-y-6">

    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-xl font-semibold text-white">Feedback Reports</h2>
            <p class="text-slate-500 text-sm mt-0.5">@Model.TotalCount total report(s)</p>
        </div>
    </div>

    <!-- Filters -->
    <form method="get" class="flex flex-wrap items-center gap-3">
        <!-- Search -->
        <div class="relative flex-1 min-w-48">
            <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500 pointer-events-none"></i>
            <input type="text" name="search" value="@currentSearch"
                   placeholder="Search messages..."
                   class="w-full bg-surface-card border border-surface-border rounded-xl pl-9 pr-4 py-2.5
                          text-sm text-slate-300 placeholder-slate-600 focus:outline-none focus:border-brand-600 transition-colors" />
        </div>

        <!-- Status Filter -->
        <select name="status"
                class="bg-surface-card border border-surface-border rounded-xl px-3 py-2.5 text-sm text-slate-300
                       focus:outline-none focus:border-brand-600 transition-colors">
            <option value="">All Statuses</option>
            @foreach (FeedbackStatus s in Enum.GetValues(typeof(FeedbackStatus)))
            {
                <option value="@((int)s)" selected="@(currentStatus == s)">@s</option>
            }
        </select>

        <!-- Type Filter -->
        <select name="type"
                class="bg-surface-card border border-surface-border rounded-xl px-3 py-2.5 text-sm text-slate-300
                       focus:outline-none focus:border-brand-600 transition-colors">
            <option value="">All Types</option>
            @foreach (FeedbackType t in Enum.GetValues(typeof(FeedbackType)))
            {
                <option value="@((int)t)" selected="@(currentType == t)">@t</option>
            }
        </select>

        <button type="submit"
                class="px-4 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-xl transition-colors">
            Filter
        </button>

        @if (currentStatus.HasValue || currentType.HasValue || !string.IsNullOrEmpty(currentSearch))
        {
            <a href="@Url.Action("Index")"
               class="px-4 py-2.5 border border-surface-border hover:border-slate-500 text-slate-400 hover:text-white text-sm rounded-xl transition-colors">
                Clear
            </a>
        }
    </form>

    <!-- Table -->
    @if (!Model.Items.Any())
    {
        <div class="flex flex-col items-center justify-center py-24 text-center">
            <div class="w-14 h-14 rounded-2xl bg-surface-card border border-surface-border flex items-center justify-center mb-4">
                <i data-lucide="inbox" class="w-6 h-6 text-slate-600"></i>
            </div>
            <p class="text-slate-400 font-medium">No feedback reports found</p>
        </div>
    }
    else
    {
        <div class="bg-surface-card border border-surface-border rounded-2xl overflow-hidden">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-surface-border">
                        <th class="text-left px-5 py-3.5 text-xs font-semibold text-slate-500 uppercase tracking-wider">Reporter</th>
                        <th class="text-left px-5 py-3.5 text-xs font-semibold text-slate-500 uppercase tracking-wider">Type</th>
                        <th class="text-left px-5 py-3.5 text-xs font-semibold text-slate-500 uppercase tracking-wider">Message</th>
                        <th class="text-left px-5 py-3.5 text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</th>
                        <th class="text-left px-5 py-3.5 text-xs font-semibold text-slate-500 uppercase tracking-wider">Date</th>
                        <th class="px-5 py-3.5"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-surface-border">
                    @foreach (var item in Model.Items)
                    {
                        var statusColors = new Dictionary<FeedbackStatus, string>
                                            {
                                            { FeedbackStatus.Open,      "text-amber-400 bg-amber-400/10 border-amber-400/20" },
                                            { FeedbackStatus.InReview,  "text-blue-400 bg-blue-400/10 border-blue-400/20" },
                                            { FeedbackStatus.Resolved,  "text-emerald-400 bg-emerald-400/10 border-emerald-400/20" },
                                            { FeedbackStatus.Closed,    "text-slate-400 bg-slate-400/10 border-slate-400/20" }
                                            };

                        var statusColor = statusColors[item.Status];


                        <tr class="hover:bg-surface-hover transition-colors">
                            <td class="px-5 py-4">
                                <div>
                                    <p class="font-medium text-white">@item.ReporterName</p>
                                    <p class="text-xs text-slate-500">@item.ReporterEmail</p>
                                </div>
                            </td>
                            <td class="px-5 py-4 text-slate-400">@item.Type.ToString()</td>
                            <td class="px-5 py-4 max-w-xs">
                                <p class="text-slate-300 truncate">@item.Message</p>
                            </td>
                            <td class="px-5 py-4">
                                <span class="text-xs font-semibold px-2.5 py-1 rounded-full border @statusColor">
                                    @item.Status.ToString()
                                </span>
                            </td>
                            <td class="px-5 py-4 text-slate-500 text-xs">
                                @item.CreatedAt.ToString("MMM dd, yyyy")
                            </td>
                            <td class="px-5 py-4 text-right">
                                <a href="@Url.Action("Details", new { id = item.Id })"
                                   class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg
                  border border-surface-border hover:border-brand-600 text-slate-400
                  hover:text-white text-xs font-medium transition-colors">
                                    <i data-lucide="eye" class="w-3.5 h-3.5"></i>
                                    View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="flex items-center justify-center gap-2 pt-4">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a href="?page=@i&status=@((int?)currentStatus)&type=@((int?)currentType)&search=@currentSearch"
                       class="@(i == Model.Page
                           ? "w-8 h-8 rounded-lg bg-brand-600 text-white font-semibold text-sm flex items-center justify-center"
                           : "w-8 h-8 rounded-lg border border-surface-border text-slate-400 hover:text-white text-sm flex items-center justify-center transition-colors")">
                        @i
                    </a>
                }
            </div>
        }
    }
</div>