@model PagedResult<UserListItemDto>

@{
    ViewData["Title"] = "Users";
    var currentSearch = ViewBag.CurrentSearch as string;
    var currentIsActive = ViewBag.CurrentIsActive as bool?;
    var currentRole = ViewBag.CurrentRole as string;
}

<div class="space-y-6">

    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-xl font-semibold text-white">Users</h2>
            <p class="text-slate-500 text-sm mt-0.5">@Model.TotalCount registered user(s)</p>
        </div>
    </div>

    <!-- Filters -->
    <form method="get" class="flex flex-wrap items-center gap-3">

        <div class="relative flex-1 min-w-48">
            <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500 pointer-events-none"></i>
            <input type="text" name="search" value="@currentSearch"
                   placeholder="Search name or email..."
                   class="w-full bg-surface-card border border-surface-border rounded-xl pl-9 pr-4 py-2.5
                          text-sm text-slate-300 placeholder-slate-600 focus:outline-none focus:border-brand-600 transition-colors" />
        </div>

        <select name="role"
                class="bg-surface-card border border-surface-border rounded-xl px-3 py-2.5 text-sm text-slate-300
                       focus:outline-none focus:border-brand-600 transition-colors">
            <option value="">All Roles</option>
            <option value="Administrator" selected="@(currentRole == Roles.Admin)">Administrator</option>
            <option value="Member" selected="@(currentRole == Roles.User)">Member</option>
        </select>

        <select name="isActive"
                class="bg-surface-card border border-surface-border rounded-xl px-3 py-2.5 text-sm text-slate-300
                       focus:outline-none focus:border-brand-600 transition-colors">
            <option value="">All Statuses</option>
            <option value="true" selected="@(currentIsActive == true)">Active</option>
            <option value="false" selected="@(currentIsActive == false)">Inactive</option>
        </select>

        <button type="submit"
                class="px-4 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-xl transition-colors">
            Filter
        </button>

        @if (!string.IsNullOrEmpty(currentSearch) || currentIsActive.HasValue || !string.IsNullOrEmpty(currentRole))
        {
            <a href="@Url.Action("Index")"
               class="px-4 py-2.5 border border-surface-border hover:border-slate-500 text-slate-400 hover:text-white text-sm rounded-xl transition-colors">
                Clear
            </a>
        }
    </form>

    <!-- Table -->
    @if (!Model.Items.Any())
    {
        <div class="flex flex-col items-center justify-center py-24 text-center">
            <div class="w-14 h-14 rounded-2xl bg-surface-card border border-surface-border flex items-center justify-center mb-4">
                <i data-lucide="users" class="w-6 h-6 text-slate-600"></i>
            </div>
            <p class="text-slate-400 font-medium">No users found</p>
        </div>
    }
    else
    {
        <div class="bg-surface-card border border-surface-border rounded-2xl overflow-hidden">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-surface-border">
                        <th class="text-left px-5 py-3.5 text-xs font-semibold text-slate-500 uppercase tracking-wider">User</th>
                        <th class="text-left px-5 py-3.5 text-xs font-semibold text-slate-500 uppercase tracking-wider">Role</th>
                        <th class="text-left px-5 py-3.5 text-xs font-semibold text-slate-500 uppercase tracking-wider">Meetings</th>
                        <th class="text-left px-5 py-3.5 text-xs font-semibold text-slate-500 uppercase tracking-wider">Tasks</th>
                        <th class="text-left px-5 py-3.5 text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</th>
                        <th class="text-left px-5 py-3.5 text-xs font-semibold text-slate-500 uppercase tracking-wider">Joined</th>
                        <th class="px-5 py-3.5"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-surface-border">
                    @foreach (var user in Model.Items)
                    {
                        var isActive = user.IsActive;

                        <tr class="hover:bg-surface-hover transition-colors">
                            <!-- User -->
                            <td class="px-5 py-4">
                                <div class="flex items-center gap-3">
                                    @if (!string.IsNullOrEmpty(user.AvatarUrl))
                                    {
                                        <img src="@user.AvatarUrl" alt="@user.FullName"
                                             class="w-8 h-8 rounded-full object-cover shrink-0" />
                                    }
                                   
                                    <div class="min-w-0">
                                        <p class="font-medium text-white truncate">@user.FullName</p>
                                        <p class="text-xs text-slate-500 truncate">@user.Email</p>
                                    </div>
                                </div>
                            </td>

                            <!-- Role -->
                            <td class="px-5 py-4">
                                @if (user.Role == Roles.Admin)
                                {
                                    <span class="text-xs font-semibold px-2.5 py-1 rounded-full border
                                                 text-brand-400 bg-brand-400/10 border-brand-400/20">
                                        Admin
                                    </span>
                                }
                                else
                                {
                                    <span class="text-xs font-semibold px-2.5 py-1 rounded-full border
                                                 text-slate-400 bg-slate-400/10 border-slate-400/20">
                                        Member
                                    </span>
                                }
                            </td>

                            <!-- Meetings -->
                            <td class="px-5 py-4 text-slate-400">@user.MeetingsCount</td>

                            <!-- Tasks -->
                            <td class="px-5 py-4 text-slate-400">@user.TasksCount</td>

                            <!-- Status -->
                            <td class="px-5 py-4">
                                @if (isActive)
                                {
                                    <span class="text-xs font-semibold px-2.5 py-1 rounded-full border
                                                 text-emerald-400 bg-emerald-400/10 border-emerald-400/20">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="text-xs font-semibold px-2.5 py-1 rounded-full border
                                                 text-red-400 bg-red-400/10 border-red-400/20">
                                        Inactive
                                    </span>
                                }
                            </td>

                            <!-- Joined -->
                            <td class="px-5 py-4 text-slate-500 text-xs">
                                @user.CreatedAt.ToString("MMM dd, yyyy")
                            </td>

                            <!-- Action -->
                            <td class="px-5 py-4 text-right">
                                <a href="@Url.Action("Details", new { id = user.Id })"
                                   class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg
                                          border border-surface-border hover:border-brand-600 text-slate-400
                                          hover:text-white text-xs font-medium transition-colors">
                                    <i data-lucide="eye" class="w-3.5 h-3.5"></i>
                                    View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="flex items-center justify-center gap-2 pt-4">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a href="?page=@i&search=@currentSearch&isActive=@currentIsActive&role=@currentRole"
                       class="@(i == Model.Page
                           ? "w-8 h-8 rounded-lg bg-brand-600 text-white font-semibold text-sm flex items-center justify-center"
                           : "w-8 h-8 rounded-lg border border-surface-border text-slate-400 hover:text-white text-sm flex items-center justify-center transition-colors")">
                        @i
                    </a>
                }
            </div>
        }
    }
</div>