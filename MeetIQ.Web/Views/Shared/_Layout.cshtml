<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – MeetIQ</title>

    <!-- Tailwind CDN (swap with your build output in production) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50:  '#eef5ff',
                            100: '#d9e8ff',
                            200: '#bcd4ff',
                            300: '#8eb6ff',
                            400: '#5a8eff',
                            500: '#3366ff',
                            600: '#1a44f5',
                            700: '#1332e1',
                            800: '#1629b6',
                            900: '#17278f',
                            950: '#111857',
                        },
                        surface: {
                            DEFAULT: '#0f1117',
                            card:    '#161b27',
                            border:  '#1f2637',
                            hover:   '#1c2235',
                        }
                    },
                    fontFamily: {
                        sans: ['"DM Sans"', 'sans-serif'],
                        mono: ['"DM Mono"', 'monospace'],
                    },
                    boxShadow: {
                        'glow': '0 0 24px 0 rgba(51,102,255,0.18)',
                    }
                }
            }
        }
    </script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- Lucide icons -->
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>

    <style>
        /* Scrollbar */
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #1f2637; border-radius: 99px; }

        /* Sidebar active glow */
        .nav-item-active {
            background: linear-gradient(90deg, rgba(51,102,255,0.18) 0%, transparent 100%);
            border-left: 2px solid #3366ff;
        }

        /* Subtle noise texture on sidebar */
        #sidebar::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.025'/%3E%3C/svg%3E");
            pointer-events: none;
            opacity: 0.4;
        }        
        /* Tooltip */
        [data-tip] { position: relative; }
        [data-tip]:hover::after {
            content: attr(data-tip);
            position: absolute;
            left: calc(100% + 10px);
            top: 50%;
            transform: translateY(-50%);
            white-space: nowrap;
            background: #1f2637;
            color: #e2e8f0;
            font-size: 12px;
            padding: 4px 10px;
            border-radius: 6px;
            pointer-events: none;
            z-index: 50;
        }
    </style>
</head>

<body class="h-full bg-surface font-sans text-slate-300 antialiased">

    @{
        var currentPath = Context.Request.Path.Value?.ToLower() ?? "";

        string NavClass(string href)
        {
            var h = href.ToLower();
            bool active = h == "/"
            ? currentPath == "/"
            : currentPath == h || currentPath.StartsWith(h + "/");

            return active
            ? "nav-item-active flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-white font-medium transition-colors"
            : "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm hover:bg-surface-hover hover:text-white transition-colors";
        }

        string IconClass(string href)
        {
            var h = href.ToLower();
            bool active = h == "/"
            ? currentPath == "/"
            : currentPath == h || currentPath.StartsWith(h + "/");

            return active
            ? "w-4 h-4 text-brand-400 shrink-0"
            : "w-4 h-4 text-slate-500 shrink-0";
        }
    }
<!-- ══════════════════════════════════════════
     APP SHELL  — sidebar + main
══════════════════════════════════════════ -->
<div class="flex h-screen overflow-hidden">

    <!-- ─── SIDEBAR ─── -->
    <aside id="sidebar"
           class="relative flex flex-col w-64 shrink-0 bg-surface-card border-r border-surface-border overflow-y-auto transition-all duration-300">

        <!-- Logo -->
        <div class="flex items-center gap-3 px-5 py-5 border-b border-surface-border">
            <div class="w-8 h-8 rounded-lg bg-brand-600 shadow-glow flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 20h5v-2a4 4 0 0 0-4-4h-1"/>
                    <path d="M9 20H4v-2a4 4 0 0 1 4-4h1"/>
                    <circle cx="12" cy="8" r="4"/>
                    <path d="M22 12h-4"/>
                    <path d="M6 12H2"/>
                </svg>
            </div>
            <span class="text-white font-semibold tracking-tight text-[17px]">Meet<span class="text-brand-400">IQ</span></span>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 px-3 py-4 space-y-0.5">
            <p class="px-3 pb-2 text-[10px] uppercase tracking-widest text-slate-600 font-semibold">Workspace</p>

                <a href="/Home/Dashboard" class="@NavClass("/Home/Dashboard")">
                    <i data-lucide="layout-dashboard" class="@IconClass("/Home/Dashboard")"></i>
                Dashboard
            </a>

            <a href="/Calendar" class="@NavClass("/calendar")">
                <i data-lucide="calendar" class="@IconClass("/calendar")"></i>
                Calendar
            </a>

            <a href="/Meetings" class="@NavClass("/meetings")">
                <i data-lucide="video" class="@IconClass("/meetings")"></i>
                Meetings
            </a>

            <a href="/Notes" class="@NavClass("/notes")">
                <i data-lucide="notebook-pen" class="@IconClass("/notes")"></i>
                Notes
            </a>

            <a href="/Tasks" class="@NavClass("/tasks")">
                <i data-lucide="check-square" class="@IconClass("/tasks")"></i>
                Tasks

                @await Component.InvokeAsync("TasksCount")
            </a>


            <div class="pt-4 pb-1">
                <p class="px-3 pb-2 text-[10px] uppercase tracking-widest text-slate-600 font-semibold">AI Tools</p>
            </div>

            <a href="/Transcripts" class="@NavClass("/transcripts")">
                <i data-lucide="mic-2" class="@IconClass("/transcripts")"></i>
                Transcripts
            </a>

            <a href="/Summaries" class="@NavClass("/summaries")">
                <i data-lucide="sparkles" class="@IconClass("/summaries")"></i>
                Summaries
            </a>

            <!-- Admin only -->
                @if (User.IsInRole(Roles.Admin))
            {
                <div class="pt-4 pb-1">
                    <p class="px-3 pb-2 text-[10px] uppercase tracking-widest text-slate-600 font-semibold">Admin</p>
                </div>

                <a href="/Admin/Users" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm hover:bg-surface-hover hover:text-white transition-colors">
                    <i data-lucide="users" class="w-4 h-4 text-slate-500 shrink-0"></i>
                    Users
                </a>

                <a href="/Admin/Dashboard" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm hover:bg-surface-hover hover:text-white transition-colors">
                    <i data-lucide="activity" class="w-4 h-4 text-slate-500 shrink-0"></i>
                    System Health
                </a>

                <a href="/Admin/Feedback" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm hover:bg-surface-hover hover:text-white transition-colors">
                    <i data-lucide="flag" class="w-4 h-4 text-slate-500 shrink-0"></i>
                    Feedback Reports
                </a>
            }
        </nav>

        <!-- User card (bottom) -->
        <div class="px-3 py-3 border-t border-surface-border">
            <div class="flex items-center gap-3 px-2 py-2 rounded-lg hover:bg-surface-hover transition-colors cursor-pointer group">
                <!-- Avatar placeholder -->
                <div class="w-8 h-8 rounded-full bg-brand-900 border border-brand-700 flex items-center justify-center text-brand-300 text-xs font-semibold shrink-0">
                    @(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "U")
                </div>
                <div class="min-w-0 flex-1">
                        <p class="text-sm text-white font-medium truncate">@(User.FindFirst("FullName")?.Value ?? "ME")</p>
                    <p class="text-[11px] text-slate-500 truncate">
                        @(User.IsInRole(Roles.Admin) ? "Administrator" : "Member")
                    </p>
                </div>
                <i data-lucide="chevrons-up-down" class="w-4 h-4 text-slate-600 group-hover:text-slate-400 shrink-0"></i>
            </div>
        </div>
    </aside>

    <!-- ─── MAIN AREA ─── -->
    <div class="flex flex-col flex-1 min-w-0 overflow-hidden">

        <!-- TOP BAR -->
        <header class="flex items-center justify-between h-14 px-6 border-b border-surface-border bg-surface-card shrink-0">

            <!-- Mobile menu toggle -->
            <button class="md:hidden p-1.5 rounded-lg hover:bg-surface-hover text-slate-400"
                    onclick="document.getElementById('sidebar').classList.toggle('-translate-x-full')">
                <i data-lucide="menu" class="w-5 h-5"></i>
            </button>

            <!-- Page title (injected per page) -->
            <h1 class="text-sm font-semibold text-white tracking-tight hidden md:block">
                @(ViewData["Title"] ?? "Dashboard")
            </h1>

            <!-- Right actions -->
            <div class="flex items-center gap-2 ml-auto">

                <!-- New Meeting CTA -->
                <a href="/Meetings/Create"
                   class="hidden sm:flex items-center gap-2 px-3 py-1.5 bg-brand-600 hover:bg-brand-500
                          text-white text-xs font-semibold rounded-lg transition-colors shadow-glow">
                    <i data-lucide="video" class="w-3.5 h-3.5"></i>
                    New Meeting
                </a>

                <!-- Notifications -->
                @await Component.InvokeAsync("NotificationBell")

                <!-- Feedback -->
                <a href="/Feedback/Create"
                   class="p-2 rounded-lg hover:bg-surface-hover text-slate-400 hover:text-white transition-colors"
                   title="Report an issue">
                    <i data-lucide="flag" class="w-[18px] h-[18px]"></i>
                </a>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <!-- Sign out -->
                    <form asp-controller="Auth" asp-action="Logout" method="post" class="mb-0">
                        <button type="submit"
                                class="p-2 rounded-lg hover:bg-surface-hover text-slate-400 hover:text-red-400 transition-colors"
                                title="Sign out">
                            <i data-lucide="log-out" class="w-[18px] h-[18px]"></i>
                        </button>
                    </form>
                }
                else
                {
                    <a href="/Auth/Login"
                       class="px-3 py-1.5 text-xs font-medium text-brand-400 hover:text-white border border-surface-border hover:border-brand-600 rounded-lg transition-colors">
                        Sign in
                    </a>
                }
            </div>
        </header>

        <!-- PAGE CONTENT -->
        <main class="flex-1 overflow-y-auto bg-surface">
                @await Html.PartialAsync("_ErrorBanner")
            <div class="page-content max-w-7xl mx-auto px-6 py-6">

                @RenderBody()
            </div>
        </main>

        <!-- FOOTER -->
        <footer class="shrink-0 border-t border-surface-border bg-surface-card px-6 py-2.5
                        flex items-center justify-between text-[11px] text-slate-600">
            <span>&copy; @DateTime.Now.Year MeetIQ &mdash; Smart Productivity Platform</span>
            <a asp-controller="Home" asp-action="Privacy"
               class="hover:text-slate-400 transition-colors">Privacy</a>
        </footer>
    </div>
</div>

<!-- Scripts -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
    <script>
        lucide.createIcons();
    </script>
</body>
</html>
