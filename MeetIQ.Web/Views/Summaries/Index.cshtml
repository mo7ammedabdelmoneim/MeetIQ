@model List<SummaryListItemDto>

@{
    ViewData["Title"] = "Summaries";
    Layout = "_Layout";
}

<div class="space-y-6">

    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-xl font-semibold text-white">AI Summaries</h1>
            <p class="text-sm text-slate-500 mt-1">AI-generated summaries from your meetings</p>
        </div>
        <span class="text-xs text-slate-600 bg-surface-card border border-surface-border
                     px-3 py-1.5 rounded-lg font-mono">
            @Model.Count summar@(Model.Count != 1 ? "ies" : "y")
        </span>
    </div>

    @if (!Model.Any())
    {
        <!-- Empty state -->
        <div class="flex flex-col items-center justify-center py-20 text-center">
            <div class="w-14 h-14 rounded-2xl bg-surface-card border border-surface-border
                        flex items-center justify-center mb-4">
                <i data-lucide="sparkles" class="w-6 h-6 text-slate-600"></i>
            </div>
            <p class="text-slate-400 font-medium">No summaries yet</p>
            <p class="text-slate-600 text-sm mt-1">Transcribe a meeting and run AI analysis to generate summaries.</p>
            <a href="@Url.Action("Index", "Meetings")"
               class="mt-4 flex items-center gap-2 px-4 py-2 bg-brand-600 hover:bg-brand-500
                      text-white text-sm font-semibold rounded-xl transition-colors">
                <i data-lucide="video" class="w-4 h-4"></i>
                Go to Meetings
            </a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 gap-4">
            @foreach (var item in Model)
            {
                // Truncate summary preview to ~200 chars
                var preview = string.IsNullOrWhiteSpace(item.SummaryText)
                ? "No summary text."
                : item.SummaryText.Length > 200
                ? item.SummaryText[..200].TrimEnd() + "…"
                : item.SummaryText;

                <div class="bg-surface-card border border-surface-border rounded-2xl p-5
                            hover:border-violet-600/30 transition-colors group">
                    <div class="flex items-start justify-between gap-4 mb-3">
                        <div class="flex items-center gap-3 min-w-0">
                            <div class="w-9 h-9 rounded-xl bg-violet-600/20 border border-violet-600/30
                                        flex items-center justify-center shrink-0">
                                <i data-lucide="sparkles" class="w-4 h-4 text-violet-400"></i>
                            </div>
                            <div class="min-w-0">
                                <p class="text-sm font-semibold text-white truncate">@item.MeetingTitle</p>
                                <div class="flex items-center gap-3 mt-0.5 flex-wrap">
                                    <span class="text-xs text-slate-500">
                                        @item.GeneratedAt.ToLocalTime().ToString("MMM d, yyyy — HH:mm")
                                    </span>
                                    @if (item.IsEdited)
                                    {
                                        <span class="text-xs text-amber-500 flex items-center gap-1">
                                            <i data-lucide="pencil" class="w-3 h-3"></i>
                                            Edited
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-[11px] px-2 py-0.5 rounded-full
                                                     bg-violet-500/10 border border-violet-500/20
                                                     text-violet-400 font-semibold">AI</span>
                                    }
                                </div>
                            </div>
                        </div>

                        <a href="@Url.Action("Details", new { id = item.Id })"
                           class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg shrink-0
                                  bg-violet-600/20 hover:bg-violet-600/30 border border-violet-600/30
                                  text-violet-400 text-xs font-semibold transition-colors">
                            <i data-lucide="eye" class="w-3.5 h-3.5"></i>
                            View
                        </a>
                    </div>

                    <!-- Preview -->
                    <p class="text-slate-500 text-sm leading-relaxed line-clamp-2 ml-12">@preview</p>
                </div>
            }
        </div>
    }
</div>