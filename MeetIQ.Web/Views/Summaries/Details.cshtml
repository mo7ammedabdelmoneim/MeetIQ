@using System.Text.Json
@model SummaryDetailsDto

@{
    ViewData["Title"] = "AI Summary";
    Layout = "_Layout";

    // Parse KeyDecisions JSON array
    List<string> decisions = [];
    if (!string.IsNullOrWhiteSpace(Model.KeyDecisions))
    {
        try { decisions = JsonSerializer.Deserialize<List<string>>(Model.KeyDecisions) ?? []; }
        catch { /* ignore parse errors */ }
    }

    // Parse KeyInsights into bullet lines
    var insights = (Model.KeyInsights ?? string.Empty)
        .Split('\n', StringSplitOptions.RemoveEmptyEntries)
        .Select(l => l.TrimStart('•', ' '))
        .Where(l => !string.IsNullOrWhiteSpace(l))
        .ToList();
}

<div class="max-w-4xl mx-auto space-y-6">

    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-xs text-slate-500">
        <a href="@Url.Action("Index", "Meetings")" class="hover:text-slate-300 transition-colors">Meetings</a>
        <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
        <a href="@Url.Action("Details", "Meetings", new { id = Model.MeetingId })"
           class="hover:text-slate-300 transition-colors truncate max-w-[180px]">@Model.MeetingTitle</a>
        <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
        <span class="text-slate-400">AI Summary</span>
    </div>

    <!-- Header -->
    <div class="bg-surface-card border border-surface-border rounded-2xl p-6">
        <div class="flex items-start justify-between gap-4 flex-wrap">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-xl bg-violet-600/20 border border-violet-600/30
                            flex items-center justify-center shrink-0">
                    <i data-lucide="sparkles" class="w-4 h-4 text-violet-400"></i>
                </div>
                <div>
                    <h1 class="text-lg font-semibold text-white">@Model.MeetingTitle — AI Summary</h1>
                    <div class="flex items-center gap-3 text-xs text-slate-500 mt-1 flex-wrap">
                        <span class="flex items-center gap-1.5">
                            <i data-lucide="calendar" class="w-3.5 h-3.5"></i>
                            Generated @Model.GeneratedAt.ToLocalTime().ToString("MMM d, yyyy — HH:mm")
                        </span>
                        @if (Model.IsEdited && Model.UpdatedAt.HasValue)
                        {
                            <span class="flex items-center gap-1.5 text-amber-500">
                                <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
                                Edited @Model.UpdatedAt.Value.ToLocalTime().ToString("MMM d")
                            </span>
                        }
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full
                                     bg-violet-500/10 border border-violet-500/20 text-violet-400 text-[11px] font-semibold">
                            <i data-lucide="cpu" class="w-3 h-3"></i>
                            AI Generated
                        </span>
                    </div>
                </div>
            </div>

            <div class="flex items-center gap-2 shrink-0">
                <button onclick="copySummary()"
                        class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-surface-border
                               text-slate-400 hover:text-white hover:border-brand-600 text-xs font-medium transition-colors">
                    <i data-lucide="copy" class="w-3.5 h-3.5"></i>
                    Copy
                </button>
                <a href="@Url.Action("Details", "Meetings", new { id = Model.MeetingId })"
                   class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-surface-border
                          text-slate-400 hover:text-white text-xs font-medium transition-colors">
                    <i data-lucide="arrow-left" class="w-3.5 h-3.5"></i>
                    Back
                </a>
            </div>
        </div>
    </div>

    <!-- Summary Text -->
    <div class="bg-surface-card border border-surface-border rounded-2xl overflow-hidden">
        <div class="px-5 py-4 border-b border-surface-border">
            <h2 class="text-sm font-semibold text-white flex items-center gap-2">
                <i data-lucide="align-left" class="w-4 h-4 text-slate-500"></i>
                Executive Summary
            </h2>
        </div>
        <div class="p-6">
            <p id="summary-text" class="text-slate-300 text-sm leading-7 whitespace-pre-wrap">@Model.SummaryText</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <!-- Key Insights -->
        @if (insights.Any())
        {
            <div class="bg-surface-card border border-surface-border rounded-2xl overflow-hidden">
                <div class="px-5 py-4 border-b border-surface-border">
                    <h2 class="text-sm font-semibold text-white flex items-center gap-2">
                        <i data-lucide="lightbulb" class="w-4 h-4 text-amber-400"></i>
                        Key Insights
                    </h2>
                </div>
                <ul class="divide-y divide-surface-border">
                    @foreach (var insight in insights)
                    {
                        <li class="flex items-start gap-3 px-5 py-3.5">
                            <span class="w-1.5 h-1.5 rounded-full bg-amber-400 shrink-0 mt-2"></span>
                            <p class="text-sm text-slate-300 leading-relaxed">@insight</p>
                        </li>
                    }
                </ul>
            </div>
        }

        <!-- Key Decisions -->
        @if (decisions.Any())
        {
            <div class="bg-surface-card border border-surface-border rounded-2xl overflow-hidden">
                <div class="px-5 py-4 border-b border-surface-border">
                    <h2 class="text-sm font-semibold text-white flex items-center gap-2">
                        <i data-lucide="check-square" class="w-4 h-4 text-emerald-400"></i>
                        Key Decisions
                    </h2>
                </div>
                <ul class="divide-y divide-surface-border">
                    @foreach (var (decision, i) in decisions.Select((d, i) => (d, i + 1)))
                    {
                        <li class="flex items-start gap-3 px-5 py-3.5">
                            <span class="w-5 h-5 rounded-md bg-emerald-500/10 border border-emerald-500/20
                                         text-emerald-400 text-[11px] font-bold flex items-center justify-center shrink-0 mt-0.5">
                                @i
                            </span>
                            <p class="text-sm text-slate-300 leading-relaxed">@decision</p>
                        </li>
                    }
                </ul>
            </div>
        }
    </div>

    <!-- Links to Tasks & Notes -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href="@Url.Action("Index", "Tasks")"
           class="bg-surface-card border border-surface-border hover:border-brand-600/50
                  rounded-xl p-4 flex items-center gap-3 transition-colors group">
            <div class="w-9 h-9 rounded-xl bg-brand-600/20 border border-brand-600/30
                        flex items-center justify-center shrink-0">
                <i data-lucide="check-square" class="w-4 h-4 text-brand-400"></i>
            </div>
            <div>
                <p class="text-sm font-semibold text-white group-hover:text-brand-300 transition-colors">View Generated Tasks</p>
                <p class="text-xs text-slate-500">Action items extracted from this meeting</p>
            </div>
            <i data-lucide="chevron-right" class="w-4 h-4 text-slate-600 ml-auto group-hover:text-slate-400"></i>
        </a>

        <a href="@Url.Action("Index", "Notes")"
           class="bg-surface-card border border-surface-border hover:border-violet-600/50
                  rounded-xl p-4 flex items-center gap-3 transition-colors group">
            <div class="w-9 h-9 rounded-xl bg-violet-600/20 border border-violet-600/30
                        flex items-center justify-center shrink-0">
                <i data-lucide="notebook-pen" class="w-4 h-4 text-violet-400"></i>
            </div>
            <div>
                <p class="text-sm font-semibold text-white group-hover:text-violet-300 transition-colors">View Generated Notes</p>
                <p class="text-xs text-slate-500">Key points captured from this meeting</p>
            </div>
            <i data-lucide="chevron-right" class="w-4 h-4 text-slate-600 ml-auto group-hover:text-slate-400"></i>
        </a>
    </div>

</div>

<!-- Copy toast -->
<div id="copy-toast"
     class="fixed bottom-6 left-1/2 -translate-x-1/2 flex items-center gap-2 px-4 py-2.5
            rounded-xl bg-surface-card border border-emerald-500/30 text-emerald-400 text-sm
            font-medium shadow-lg z-50 opacity-0 translate-y-2 transition-all duration-200 pointer-events-none">
    <i data-lucide="check-circle" class="w-4 h-4"></i>
    Summary copied!
</div>

@section Scripts {
    <script>
        function copySummary() {
            const text = document.getElementById('summary-text')?.innerText ?? '';
            navigator.clipboard.writeText(text).then(() => {
                const toast = document.getElementById('copy-toast');
                toast.classList.remove('opacity-0', 'translate-y-2');
                setTimeout(() => toast.classList.add('opacity-0', 'translate-y-2'), 2500);
            });
        }
    </script>
}
