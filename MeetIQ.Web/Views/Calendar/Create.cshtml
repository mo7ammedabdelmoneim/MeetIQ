@model CreateCalendarEventViewModel
@{
    ViewData["Title"] = "New Event";
}

<div class="max-w-2xl mx-auto">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
        <a href="/Calendar" class="hover:text-white transition-colors">Calendar</a>
        <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
        <span class="text-slate-300">New Event</span>
    </nav>

    <div class="bg-surface-card border border-surface-border rounded-xl p-6">
        <h2 class="text-white font-semibold text-lg mb-6">Create Calendar Event</h2>

        <form asp-action="Create" method="post" class="space-y-5" id="eventForm" novalidate>
            @Html.AntiForgeryToken()

            <!-- Title -->
            <div>
                <label asp-for="Title" class="block text-sm font-medium text-slate-300 mb-1.5">
                    Title <span class="text-red-400">*</span>
                </label>
                <input asp-for="Title"
                       class="w-full bg-surface border border-surface-border rounded-lg px-3 py-2.5
                              text-sm text-white placeholder-slate-600 focus:outline-none
                              focus:border-brand-500 transition-colors"
                       placeholder="e.g. Sprint Planning" />
                <span asp-validation-for="Title" class="text-xs text-red-400 mt-1 block"></span>
            </div>

            <!-- Description -->
            <div>
                <label asp-for="Description" class="block text-sm font-medium text-slate-300 mb-1.5">
                    Description
                </label>
                <textarea asp-for="Description" rows="3"
                          class="w-full bg-surface border border-surface-border rounded-lg px-3 py-2.5
                                 text-sm text-white placeholder-slate-600 focus:outline-none
                                 focus:border-brand-500 transition-colors resize-none"
                          placeholder="Optional notes about this event"></textarea>
                <span asp-validation-for="Description" class="text-xs text-red-400 mt-1 block"></span>
            </div>

            <!-- Start / End time -->
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="StartTime" class="block text-sm font-medium text-slate-300 mb-1.5">
                        Start Time <span class="text-red-400">*</span>
                    </label>
                    <input asp-for="StartTime" type="datetime-local" id="startTime"
                           class="w-full bg-surface border border-surface-border rounded-lg px-3 py-2.5
                                  text-sm text-white focus:outline-none focus:border-brand-500 transition-colors" />
                    <span asp-validation-for="StartTime" class="text-xs text-red-400 mt-1 block"></span>
                    <span id="startTimeError" class="text-xs text-red-400 mt-1 block hidden"></span>
                </div>
                <div>
                    <label asp-for="EndTime" class="block text-sm font-medium text-slate-300 mb-1.5">
                        End Time <span class="text-red-400">*</span>
                    </label>
                    <input asp-for="EndTime" type="datetime-local" id="endTime"
                           class="w-full bg-surface border border-surface-border rounded-lg px-3 py-2.5
                                  text-sm text-white focus:outline-none focus:border-brand-500 transition-colors" />
                    <span asp-validation-for="EndTime" class="text-xs text-red-400 mt-1 block"></span>
                    <span id="endTimeError" class="text-xs text-red-400 mt-1 block hidden"></span>
                </div>
            </div>

            <!-- Duration hint (live) -->
            <p id="durationHint" class="text-xs text-slate-500 -mt-3 hidden">
                <i data-lucide="clock" class="w-3 h-3 inline-block mr-1"></i>
                <span id="durationText"></span>
            </p>

            <!-- Color + Meeting row -->
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="Color" class="block text-sm font-medium text-slate-300 mb-1.5">Color</label>
                    <div class="flex items-center gap-3">
                        <input asp-for="Color" type="color" id="colorPicker"
                               class="h-10 w-16 rounded-lg border border-surface-border bg-surface cursor-pointer p-0.5" />
                        <input type="text" id="colorHex"
                               class="flex-1 bg-surface border border-surface-border rounded-lg px-3 py-2.5
                                      text-sm text-white font-mono focus:outline-none focus:border-brand-500"
                               value="@Model.Color" placeholder="#3B82F6" />
                        <input asp-for="Color" type="hidden" id="colorValue" />
                    </div>
                    <div class="flex gap-2 mt-2" id="swatches">
                        @foreach (var c in new[] { "#3B82F6", "#8B5CF6", "#10B981", "#F59E0B", "#EF4444", "#EC4899", "#64748B" })
                        {
                            <button type="button" onclick="pickColor('@c')"
                                    class="w-5 h-5 rounded-full border-2 border-transparent hover:border-white transition-colors"
                                    style="background:@c"></button>
                        }
                    </div>
                    <span asp-validation-for="Color" class="text-xs text-red-400 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="MeetingId" class="block text-sm font-medium text-slate-300 mb-1.5">
                        Link to Meeting
                    </label>
                    <select asp-for="MeetingId" asp-items="Model.Meetings"
                            class="w-full bg-surface border border-surface-border rounded-lg px-3 py-2.5
                                   text-sm text-white focus:outline-none focus:border-brand-500 transition-colors">
                        <option value="">— None —</option>
                    </select>
                </div>
            </div>

            <!-- Actions -->
            <div class="flex items-center justify-end gap-3 pt-2">
                <a href="/Calendar"
                   class="px-4 py-2 text-sm text-slate-400 hover:text-white border border-surface-border
                          hover:border-slate-500 rounded-lg transition-colors">
                    Cancel
                </a>
                <button type="submit" id="submitBtn"
                        class="px-5 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm
                               font-semibold rounded-lg transition-colors shadow-glow
                               disabled:opacity-40 disabled:cursor-not-allowed">
                    Create Event
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // ── Color picker sync ──────────────────────────────────────────────────
        const picker = document.getElementById('colorPicker');
        const hex = document.getElementById('colorHex');
        const hidden = document.getElementById('colorValue');

        function pickColor(val) {
            picker.value = val;
            hex.value = val;
            hidden.value = val;
        }
        picker.addEventListener('input', () => pickColor(picker.value));
        hex.addEventListener('input', () => {
            if (/^#([0-9A-Fa-f]{3}|[0-9A-Fa-f]{6})$/.test(hex.value))
                pickColor(hex.value);
        });
        pickColor('@Model.Color');

        // ── Pre-fill from query string ─────────────────────────────────────────
        (function () {
            const params = new URLSearchParams(window.location.search);
            const startRaw = params.get('start');
            const endRaw = params.get('end');

            function toLocal(raw) {
                if (!raw) return null;
                if (raw.includes('T') && raw.length >= 16) return raw.substring(0, 16);
                return raw + 'T09:00';
            }

            const s = toLocal(startRaw);
            const e = toLocal(endRaw) || (s ? s.substring(0, 11) + '10:00' : null);
            if (s) document.getElementById('startTime').value = s;
            if (e) document.getElementById('endTime').value = e;
        })();

        // ── Live date/time validation ──────────────────────────────────────────
        const startInput = document.getElementById('startTime');
        const endInput = document.getElementById('endTime');
        const startErr = document.getElementById('startTimeError');
        const endErr = document.getElementById('endTimeError');
        const hint = document.getElementById('durationHint');
        const hintText = document.getElementById('durationText');
        const submitBtn = document.getElementById('submitBtn');

        function setError(el, msg) {
            el.textContent = msg;
            el.classList.toggle('hidden', !msg);
        }

        function markInput(input, isError) {
            input.classList.toggle('border-red-500', isError);
            input.classList.toggle('border-surface-border', !isError);
        }

        function formatDuration(minutes) {
            if (minutes < 60) return minutes + ' minutes';
            const h = Math.floor(minutes / 60);
            const m = minutes % 60;
            return m > 0 ? h + 'h ' + m + 'm' : h + (h === 1 ? ' hour' : ' hours');
        }

        function updateDurationHint() {
            const s = startInput.value ? new Date(startInput.value) : null;
            const e = endInput.value ? new Date(endInput.value) : null;
            if (s && e && e > s) {
                const mins = Math.round((e - s) / 60000);
                hintText.textContent = 'Duration: ' + formatDuration(mins);
                hint.classList.remove('hidden');
                lucide.createIcons();
            } else {
                hint.classList.add('hidden');
            }
        }

        function validateTimes() {
            const now = new Date();
            const s = startInput.value ? new Date(startInput.value) : null;
            const e = endInput.value ? new Date(endInput.value) : null;
            let ok = true;

            // ── Start ──────────────────────────────────────────────────────────
            if (!startInput.value) {
                setError(startErr, ''); markInput(startInput, false); // empty = not touched yet, no error shown
            } else if (s <= now) {
                setError(startErr, 'Start time must be in the future.');
                markInput(startInput, true); ok = false;
            } else {
                setError(startErr, ''); markInput(startInput, false);
            }

            // ── End ────────────────────────────────────────────────────────────
            if (!endInput.value) {
                setError(endErr, ''); markInput(endInput, false); // empty = not touched yet
            } else if (s && e <= s) {
                setError(endErr, 'End time must be after start time.');
                markInput(endInput, true); ok = false;
            } else if (s && e && (e - s) / 60000 < 15) {
                setError(endErr, 'Event must be at least 15 minutes long.');
                markInput(endInput, true); ok = false;
            } else {
                setError(endErr, ''); markInput(endInput, false);
            }

            // Only block submit if a field has a value that is actually invalid
            // (not just empty — server validation handles required)
            const startInvalid = startInput.value && s <= now;
            const endInvalid = endInput.value && s && (e <= s || (e - s) / 60000 < 15);
            submitBtn.disabled = !!(startInvalid || endInvalid);

            updateDurationHint();
            return ok;
        }

        // ── Single change handler for startTime ────────────────────────────────
        startInput.addEventListener('change', function () {
            // Auto-fill EndTime with start + 1h if end is still empty
            if (startInput.value && !endInput.value) {
                const s = new Date(startInput.value);
                s.setHours(s.getHours() + 1);
                const pad = n => String(n).padStart(2, '0');
                endInput.value =
                    s.getFullYear() + '-' + pad(s.getMonth() + 1) + '-' + pad(s.getDate()) +
                    'T' + pad(s.getHours()) + ':' + pad(s.getMinutes());
            }
            validateTimes();
        });

        endInput.addEventListener('change', validateTimes);

        // ── Block submit only if values are actually invalid ───────────────────
        document.getElementById('eventForm').addEventListener('submit', function (ev) {
            // On submit, enforce required check too
            let ok = true;
            const now = new Date();
            const s = startInput.value ? new Date(startInput.value) : null;
            const e = endInput.value ? new Date(endInput.value) : null;

            if (!startInput.value) {
                setError(startErr, 'Start time is required.');
                markInput(startInput, true); ok = false;
            } else if (s <= now) {
                setError(startErr, 'Start time must be in the future.');
                markInput(startInput, true); ok = false;
            }

            if (!endInput.value) {
                setError(endErr, 'End time is required.');
                markInput(endInput, true); ok = false;
            } else if (s && e <= s) {
                setError(endErr, 'End time must be after start time.');
                markInput(endInput, true); ok = false;
            } else if (s && e && (e - s) / 60000 < 15) {
                setError(endErr, 'Event must be at least 15 minutes long.');
                markInput(endInput, true); ok = false;
            }

            if (!ok) ev.preventDefault();
        });

    </script>
}
