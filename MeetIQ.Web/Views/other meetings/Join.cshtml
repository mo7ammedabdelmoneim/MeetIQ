@model JitsiRoomViewModel
@{
    ViewData["Title"] = Model.Meeting.Title;
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Meeting.Title – MeetIQ</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        brand:   { 400: '#5a8eff', 500: '#3366ff', 600: '#1a44f5', 700: '#1332e1' },
                        surface: { DEFAULT: '#0f1117', card: '#161b27', border: '#1f2637' }
                    },
                    fontFamily: { sans: ['"DM Sans"', 'sans-serif'] },
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>

    <style>
        *, *::before, *::after { box-sizing: border-box; }

        html, body {
            margin: 0; padding: 0;
            height: 100%; width: 100%;
            overflow: hidden;
            background: #0f1117;
            font-family: 'DM Sans', sans-serif;
            color: #cbd5e1;
        }

        #page-shell {
            display: flex; flex-direction: column;
            height: 100vh; width: 100vw;
        }

        #topbar {
            height: 48px; min-height: 48px; flex-shrink: 0;
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 16px;
            background: #161b27;
            border-bottom: 1px solid #1f2637;
            z-index: 20;
        }

        #room-area {
            position: relative;
            flex: 1 1 0;
            min-height: 0;
            width: 100%;
            overflow: hidden;
        }

        #jitsi-container {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            width: 100%; height: 100%;
        }

        #jitsi-container > iframe {
            width: 100% !important; height: 100% !important;
            border: none !important; display: block !important;
            position: absolute !important;
            top: 0 !important; left: 0 !important;
        }

        #loading-overlay {
            position: absolute; inset: 0;
            background: #0f1117;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            gap: 12px; z-index: 10;
            transition: opacity 0.4s;
        }
        #loading-overlay.hidden-overlay { opacity: 0; pointer-events: none; }

        /* ── Topbar elements ── */
        .tb-btn {
            display: flex; align-items: center; gap: 6px;
            padding: 5px 10px; border-radius: 8px;
            font-size: 12px; font-weight: 600; cursor: pointer;
            border: none; transition: background 0.15s, color 0.15s;
            text-decoration: none; color: #94a3b8; background: transparent;
            font-family: 'DM Sans', sans-serif;
        }
        .tb-btn:hover { background: #1c2235; color: #fff; }
        .tb-btn-red   { background: #dc2626; color: #fff; }
        .tb-btn-red:hover { background: #ef4444; }

        .live-pill {
            display: flex; align-items: center; gap: 6px;
            padding: 4px 10px; border-radius: 99px;
            background: rgba(51,102,255,0.1);
            border: 1px solid rgba(51,102,255,0.3);
            font-size: 11px; font-weight: 600; color: #cbd5e1;
        }
        .live-dot {
            width: 8px; height: 8px; border-radius: 50%;
            background: #ef4444;
            animation: pulse-dot 1.5s ease infinite;
        }
        @@keyframes pulse-dot { 0%,100%{opacity:1} 50%{opacity:0.3} }

        #participant-pill {
            display: none;
            align-items: center; gap: 5px;
            padding: 4px 10px; border-radius: 99px;
            background: rgba(51,102,255,0.08);
            border: 1px solid rgba(51,102,255,0.2);
            font-size: 12px; font-weight: 600; color: #cbd5e1;
            cursor: default;
            position: relative;
        }
        #participant-pill.visible { display: flex; }

        #participant-panel {
            display: none;
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            min-width: 200px;
            background: #161b27;
            border: 1px solid #1f2637;
            border-radius: 12px;
            padding: 8px;
            z-index: 100;
            box-shadow: 0 8px 32px rgba(0,0,0,0.5);
        }
        #participant-pill:hover #participant-panel { display: block; }

        .dot {
            width: 6px; height: 6px; border-radius: 50%;
            background: #3366ff; display: inline-block;
        }
        .dot:nth-child(1) { animation: bounce 0.9s 0.00s ease-in-out infinite; }
        .dot:nth-child(2) { animation: bounce 0.9s 0.15s ease-in-out infinite; }
        .dot:nth-child(3) { animation: bounce 0.9s 0.30s ease-in-out infinite; }
        @@keyframes bounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }

        #end-modal {
            position: fixed; inset: 0;
            background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);
            z-index: 50; display: none;
            align-items: center; justify-content: center; padding: 16px;
        }
        #end-modal.open { display: flex; }

        #copy-toast {
            position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
            background: #161b27; border: 1px solid #1f2637;
            color: #fff; font-size: 12px; padding: 8px 16px; border-radius: 99px;
            opacity: 0; transition: opacity 0.3s; pointer-events: none; z-index: 50;
        }
    </style>
</head>

<body>
<div id="page-shell">

    <!-- ── TOP BAR ── -->
    <div id="topbar">

        <!-- Left: logo + breadcrumb -->
        <div style="display:flex;align-items:center;gap:10px;min-width:0;">
            <a href="/" style="display:flex;align-items:center;gap:6px;color:#fff;font-weight:600;font-size:14px;text-decoration:none;flex-shrink:0;">
                <div style="width:24px;height:24px;border-radius:6px;background:#1332e1;display:flex;align-items:center;justify-content:center;">
                    <i data-lucide="video" style="width:14px;height:14px;color:#5a8eff;"></i>
                </div>
                Meet<span style="color:#5a8eff;">IQ</span>
            </a>
            <span style="color:#334155;flex-shrink:0;">/</span>
            <span style="font-size:13px;color:#94a3b8;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                @Model.Meeting.Title
            </span>
        </div>

        <!-- Right: pills + controls -->
        <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">

            <div class="live-pill">
                <div class="live-dot"></div>
                LIVE
            </div>

            <div id="participant-pill" title="Participants in room">
                <svg xmlns="http://www.w3.org/2000/svg" style="width:13px;height:13px;color:#5a8eff;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                <span id="participant-count">1</span>

                <div id="participant-panel">
                    <p style="font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:#475569;font-weight:600;padding:4px 8px 8px;">In Room</p>
                    <div id="participant-list"></div>
                </div>
            </div>

            <button onclick="copyRoomId()" class="tb-btn" title="Copy join link"
                    style="font-family:monospace;font-size:11px;max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                <i data-lucide="link" style="width:13px;height:13px;"></i>
                @Model.Meeting.JitsiRoomId
            </button>

            <span id="timer" style="font-family:monospace;font-size:12px;color:#475569;min-width:36px;flex-shrink:0;">00:00</span>

            @if (Model.IsHost)
            {
                <form id="endForm" asp-action="End" asp-controller="Meetings" method="post" style="margin:0;">
                    <input type="hidden" name="id" value="@Model.Meeting.Id" />
                    @Html.AntiForgeryToken()
                    <button type="button" onclick="confirmEnd()" class="tb-btn tb-btn-red">
                        <i data-lucide="phone-off" style="width:13px;height:13px;"></i>
                        End Meeting
                    </button>
                </form>
            }
            else
            {
                <form id="leave-form" asp-action="Leave" asp-controller="Meetings" method="post" style="margin:0;">
                    <input type="hidden" name="id" value="@Model.Meeting.Id" />
                    @Html.AntiForgeryToken()
                    <button type="submit" class="tb-btn" style="background:#1e293b;color:#cbd5e1;">
                        <i data-lucide="log-out" style="width:13px;height:13px;"></i>
                        Leave
                    </button>
                </form>
            }
        </div>
    </div>

    <!-- ── ROOM AREA ── -->
    <div id="room-area">
        <div id="jitsi-container"></div>

        <div id="loading-overlay">
            <div style="width:56px;height:56px;border-radius:16px;background:rgba(51,102,255,0.1);border:1px solid rgba(51,102,255,0.25);display:flex;align-items:center;justify-content:center;">
                <i data-lucide="video" style="width:28px;height:28px;color:#5a8eff;"></i>
            </div>
            <div style="text-align:center;">
                <p style="color:#fff;font-weight:500;font-size:14px;margin:0;">Joining @Model.Meeting.Title</p>
                <p style="color:#475569;font-size:12px;margin:4px 0 0;">Setting up your video room…</p>
            </div>
            <div style="display:flex;gap:6px;margin-top:4px;">
                <div class="dot"></div>
                <div class="dot"></div>
                <div class="dot"></div>
            </div>
        </div>
    </div>

</div><!-- /page-shell -->

<!-- ── END MEETING MODAL ── -->
<div id="end-modal">
    <div style="background:#161b27;border:1px solid #1f2637;border-radius:20px;padding:28px;max-width:360px;width:100%;box-shadow:0 24px 64px rgba(0,0,0,0.5);">
        <div style="width:48px;height:48px;border-radius:12px;background:rgba(220,38,38,0.1);border:1px solid rgba(220,38,38,0.2);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
            <i data-lucide="phone-off" style="width:22px;height:22px;color:#f87171;"></i>
        </div>
        <p style="color:#fff;font-weight:600;text-align:center;margin:0 0 6px;">End the meeting?</p>
        <p style="color:#64748b;font-size:13px;text-align:center;margin:0 0 20px;">
            Everyone will be disconnected. You can then generate a transcript &amp; summary.
        </p>
        <div style="display:flex;gap:10px;">
            <button onclick="closeEndModal()"
                    style="flex:1;padding:10px;border-radius:10px;border:1px solid #1f2637;background:transparent;color:#94a3b8;font-size:13px;font-weight:500;cursor:pointer;">
                Cancel
            </button>
            <button onclick="submitEndForm()"
                    style="flex:1;padding:10px;border-radius:10px;border:none;background:#dc2626;color:#fff;font-size:13px;font-weight:600;cursor:pointer;">
                End Meeting
            </button>
        </div>
    </div>
</div>

<div id="copy-toast">Room link copied!</div>

<script>
    // ── Constants from server ─────────────────────────────────────────────────
    const DOMAIN  = '@Model.JitsiDomain';
    const ROOM    = '@Model.Meeting.JitsiRoomId';
    const TOKEN   = '@(Model.JwtToken ?? "")';
    const IS_HOST = @(Model.IsHost.ToString().ToLower());
    const NAME    = '@Html.Raw(Model.DisplayName.Replace("'", "\\'"))';
    const AVATAR  = '@Model.AvatarUrl';

    let api;
    let timerInterval;
    let startTime;

    // ── Participant tracking ──────────────────────────────────────────────────
    const participants = new Map(); // jitsiId → { name }

    function updateParticipantUI() {
        const count = participants.size;
        document.getElementById('participant-count').textContent = count;

        const list = document.getElementById('participant-list');
        list.innerHTML = '';
        participants.forEach(({ name }) => {
            const initial = (name || '?')[0].toUpperCase();
            const row = document.createElement('div');
            row.style.cssText = 'display:flex;align-items:center;gap:8px;padding:5px 8px;border-radius:8px;';
            row.innerHTML = `
                <div style="width:26px;height:26px;border-radius:50%;background:#1332e1;
                            display:flex;align-items:center;justify-content:center;
                            font-size:11px;font-weight:600;color:#a5b4fc;flex-shrink:0;">
                    ${initial}
                </div>
                <span style="font-size:12px;color:#cbd5e1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                    ${name || 'Unknown'}
                </span>`;
            list.appendChild(row);
        });

        const pill = document.getElementById('participant-pill');
        if (count > 0) pill.classList.add('visible');
    }

    // ── Error display ─────────────────────────────────────────────────────────
    function showError(msg) {
        document.getElementById('loading-overlay').innerHTML = `
            <div style="width:56px;height:56px;border-radius:16px;background:rgba(153,27,27,0.2);
                        border:1px solid rgba(153,27,27,0.4);display:flex;align-items:center;justify-content:center;">
                <svg xmlns="http://www.w3.org/2000/svg" style="width:26px;height:26px;color:#f87171;"
                     fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
            </div>
            <div style="text-align:center;">
                <p style="color:#fff;font-weight:500;font-size:14px;margin:0;">Failed to load video room</p>
                <p style="color:#64748b;font-size:12px;margin:6px 0 0;max-width:320px;">${msg}</p>
            </div>
            <a href="/Meetings" style="margin-top:8px;padding:8px 20px;background:#1e293b;color:#cbd5e1;
                                       border-radius:8px;font-size:12px;font-weight:500;text-decoration:none;">
                Back to Meetings
            </a>`;
    }

    // ── Hide loading overlay (called once, guarded) ───────────────────────────
    let overlayHidden = false;
    function hideOverlay() {
        if (overlayHidden) return;
        overlayHidden = true;
        document.getElementById('loading-overlay').style.display = 'none';
        startTimer();
    }

    // ── Init Jitsi ────────────────────────────────────────────────────────────
    function initJitsi() {
        if (typeof JitsiMeetExternalAPI === 'undefined') {
            showError('JitsiMeetExternalAPI not found. Check that ' + DOMAIN + ' is reachable.');
            return;
        }

        const options = {
            roomName:   ROOM,
            width:      '100%',
            height:     '100%',
            parentNode: document.getElementById('jitsi-container'),
            configOverwrite: {
                startWithAudioMuted:     false,
                startWithVideoMuted:     false,
                disableDeepLinking:      true,
                prejoinPageEnabled:      false,
                enableNoisyMicDetection: true,
                toolbarButtons: [
                    'microphone','camera','closedcaptions','desktop',
                    'fullscreen','fodeviceselection','hangup',
                    'chat','raisehand','videoquality','filmstrip',
                    'invite','stats','shortcuts','tileview',
                    'select-background','download','help',
                ],
            },
            interfaceConfigOverwrite: {
                SHOW_JITSI_WATERMARK:             false,
                SHOW_WATERMARK_FOR_GUESTS:        false,
                SHOW_BRAND_WATERMARK:             false,
                DEFAULT_BACKGROUND:               '#0f1117',
                TOOLBAR_ALWAYS_VISIBLE:           false,
                DISABLE_JOIN_LEAVE_NOTIFICATIONS: true,
            },
            userInfo: { displayName: NAME, avatarUrl: AVATAR },
        };

        if (TOKEN) options.jwt = TOKEN;

        try {
            api = new JitsiMeetExternalAPI(DOMAIN, options);
        } catch (e) {
            showError('Init error: ' + e.message);
            return;
        }

        // ── Event: local user joined — hide overlay immediately ───────────────
        api.addEventListener('videoConferenceJoined', hideOverlay);

        // ── Fallback: hide overlay after 5s if event never fires ─────────────
        setTimeout(hideOverlay, 5000);

        // ── Event: someone joined ─────────────────────────────────────────────
        api.addEventListener('participantJoined', (data) => {
            participants.set(data.id, { name: data.displayName || 'Guest' });
            updateParticipantUI();
        });

        // ── Event: someone left ───────────────────────────────────────────────
        api.addEventListener('participantLeft', (data) => {
            participants.delete(data.id);
            updateParticipantUI();
        });

        // ── Event: display name changed ───────────────────────────────────────
        api.addEventListener('displayNameChange', (data) => {
            if (participants.has(data.id)) {
                participants.set(data.id, { name: data.displayname || data.displayName || 'Guest' });
                updateParticipantUI();
            }
        });

        // ── Event: call ended (by host or network) ────────────────────────────
        api.addEventListener('readyToClose', () => {
            if (IS_HOST) confirmEnd();
            else         document.querySelector('#leave-form button')?.click();
        });

        // ── Event: internal Jitsi error ───────────────────────────────────────
        api.addEventListener('errorOccurred', ({ error }) => {
            console.error('Jitsi error:', error);
        });
    }

    // ── Dynamic script loader ─────────────────────────────────────────────────
    function loadJitsiScript() {
        const s   = document.createElement('script');
        s.src     = `https://${DOMAIN}/external_api.js`;
        s.async   = true;
        s.onload  = initJitsi;
        s.onerror = () => showError(
            `Could not load https://${DOMAIN}/external_api.js — ` +
            'check internet connection and Jitsi domain in appsettings.json'
        );
        document.head.appendChild(s);
    }

    // ── Timer ─────────────────────────────────────────────────────────────────
    function startTimer() {
        startTime = Date.now();
        timerInterval = setInterval(() => {
            const secs = Math.floor((Date.now() - startTime) / 1000);
            const m = String(Math.floor(secs / 60)).padStart(2, '0');
            const s = String(secs % 60).padStart(2, '0');
            document.getElementById('timer').textContent = `${m}:${s}`;
        }, 1000);
    }

    // ── Copy room link ────────────────────────────────────────────────────────
    function copyRoomId() {
        navigator.clipboard.writeText(`${location.origin}/Meetings/Join/@Model.Meeting.Id`).then(() => {
            const t = document.getElementById('copy-toast');
            t.style.opacity = '1';
            setTimeout(() => t.style.opacity = '0', 2000);
        });
    }

    // ── End modal ─────────────────────────────────────────────────────────────
    function confirmEnd()    { document.getElementById('end-modal').classList.add('open'); }
    function closeEndModal() { document.getElementById('end-modal').classList.remove('open'); }
    function submitEndForm() { clearInterval(timerInterval); document.getElementById('endForm').submit(); }

    // ── Boot ──────────────────────────────────────────────────────────────────
    lucide.createIcons();
    loadJitsiScript();
</script>
</body>
</html>
